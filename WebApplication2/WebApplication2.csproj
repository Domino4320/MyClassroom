      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <UpToDateCheckInput Remove="Views\Courses\Index.cshtml" />
  </ItemGroup>

  <ItemGroup>
