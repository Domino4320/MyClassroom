@model WebApplication2.Models.CourseConstructorViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Проектирование: @Model.CourseTitle</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        :root {
            --primary: #4fc3f7;
            --bg-dark: #0f172a;
            --bg-card: #162031;
            --sidebar-bg: #111a2e;
            --border: rgba(79, 195, 247, 0.25);
            --text: #e3f2fd;
            --text-muted: #90a4ae;
            --accent-gradient: linear-gradient(135deg, #0288d1, #26c6da);
        }

        body {
            font-family: 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-dark);
            color: var(--text);
            margin: 0;
            display: flex;
            height: 100vh;
        }

        /* ЛЕВАЯ ПАНЕЛЬ */
        .sidebar {
            width: 320px;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            box-shadow: 10px 0 30px rgba(0,0,0,0.3);
        }

        .sidebar-header {
            padding: 25px 20px;
            border-bottom: 1px solid var(--border);
            background: rgba(0,0,0,0.1);
        }

            .sidebar-header h3 {
                font-size: 1.1rem;
                margin: 15px 0;
                color: #fff;
            }

        .module-list {
            overflow-y: auto;
            flex-grow: 1;
            padding: 15px;
        }

        .module-item {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-radius: 12px;
            margin-bottom: 15px;
            padding: 12px;
        }

        .lesson-item {
            margin: 8px 0 8px 15px;
            padding: 10px;
            background: rgba(79, 195, 247, 0.05);
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
            font-size: 0.9rem;
            border: 1px solid transparent;
        }

            .lesson-item:hover {
                background: rgba(79, 195, 247, 0.15);
                border-color: var(--primary);
            }

            .lesson-item.active {
                background: var(--accent-gradient);
                color: white;
            }

        /* ПРАВАЯ ПАНЕЛЬ */
        .editor-area {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            background: radial-gradient(circle at top right, #1e293b, var(--bg-dark));
        }

        .editor-header {
            padding: 20px 40px;
            background: rgba(22, 32, 49, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .editor-content {
            padding: 40px;
            overflow-y: auto;
            flex-grow: 1;
        }

        .content-card {
            background: var(--bg-card);
            padding: 35px;
            border-radius: 24px;
            border: 1px solid var(--border);
            max-width: 900px;
            margin: 0 auto;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
        }

        input, textarea {
            width: 100%;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: white;
            padding: 12px;
            box-sizing: border-box;
            margin-top: 5px;
            outline: none;
        }

            input:focus {
                border-color: var(--primary);
                box-shadow: 0 0 10px rgba(79, 195, 247, 0.2);
            }

            /* Специальный стиль для чекбоксов в квизе */
            input[type="checkbox"] {
                width: 20px;
                height: 20px;
                cursor: pointer;
                accent-color: var(--primary);
            }

        .btn {
            padding: 10px 22px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            transition: 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: var(--accent-gradient);
            color: white;
        }

            .btn-primary:hover {
                transform: scale(1.02);
                box-shadow: 0 5px 15px rgba(2, 136, 209, 0.4);
            }

        .btn-outline {
            background: rgba(79, 195, 247, 0.1);
            border: 1px solid var(--primary);
            color: var(--primary);
        }

            .btn-outline:hover {
                background: var(--primary);
                color: #000;
            }

        .step-card {
            background: rgba(255,255,255,0.02);
            border: 1px solid var(--border);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .badge-type {
            background: var(--primary);
            color: #000;
            padding: 3px 10px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
        }

        .quiz-editor-box {
            background: rgba(0,0,0,0.2);
            padding: 15px;
            border-radius: 12px;
            border: 1px dashed var(--border);
            margin-top: 15px;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-header">
            <a href="/MyCourses/Index" style="color: var(--primary); text-decoration: none; font-size: 0.9rem;">
                <i class="bi bi-arrow-left"></i> К моим курсам
            </a>
            <h3>@Model.CourseTitle</h3>
            <button class="btn btn-outline" style="width: 100%; justify-content: center;" onclick="addModule()">
                <i class="bi bi-folder-plus"></i> Добавить модуль
            </button>
        </div>
        <div class="module-list" id="moduleContainer">
            @foreach (var m in Model.Modules.OrderBy(x => x.Order))
            {
                <div class="module-item">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <strong style="color: var(--primary)">@m.Title</strong>
                        <i class="bi bi-plus-square-dotted" style="cursor:pointer; font-size: 1.2rem;" onclick="addLesson(@m.Id)"></i>
                    </div>
                    <div class="lessons">
                        @foreach (var l in m.Lessons.OrderBy(x => x.Order))
                        {
                            <div class="lesson-item" onclick="loadLessonEditor(@l.Id, this)">
                                <i class="bi bi-file-earmark-text"></i> @l.Title
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="editor-area">
        <div id="editorPlaceholder" class="empty-state" style="text-align: center; margin-top: 150px; color: var(--text-muted);">
            <i class="bi bi-palette2" style="font-size: 5rem; color: var(--primary); opacity: 0.5;"></i>
            <h2>Мастерская курса</h2>
            <p>Выберите урок в левой панели, чтобы наполнить его знаниями</p>
        </div>

        <div id="editorForm" style="display: none; height: 100%; flex-direction: column;">
            <div class="editor-header">
                <div>
                    <span style="color: var(--text-muted); font-size: 0.8rem;">КОНСТРУКТОР КУРСА</span>
                    <h2 id="currentLessonTitle" style="margin: 0;">Панель управления</h2>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button id="publishBtn" class="btn btn-outline" onclick="publishCourse(@Model.CourseId)"
                            style="border-color: #4caf50; color: #4caf50;">
                        <i class="bi bi-send"></i> Опубликовать курс
                    </button>
                    <button class="btn btn-primary" onclick="saveCurrentLesson()">
                        <i class="bi bi-cloud-check"></i> Сохранить урок
                    </button>
                </div>
            </div>
            <div class="editor-content">
                <div class="content-card">
                    <div style="margin-bottom: 30px;">
                        <label>Заголовок урока</label>
                        <input type="text" id="editLessonName" style="font-size: 1.2rem; font-weight: 600;">
                    </div>

                    <div id="stepsContainer"></div>

                    <div style="display:flex; gap:15px; margin-top:40px; border-top:1px solid var(--border); padding-top:30px; justify-content: center;">
                        <button class="btn btn-outline" onclick="addNewStep('Text')"><i class="bi bi-text-paragraph"></i> Текст</button>
                        <button class="btn btn-outline" onclick="addNewStep('Video')"><i class="bi bi-play-btn"></i> Видео</button>
                        <button class="btn btn-outline" onclick="addNewStep('Quiz')"><i class="bi bi-check2-square"></i> Тест</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentLessonId = null;

        function setActiveLesson(element) {
            document.querySelectorAll('.lesson-item').forEach(el => el.classList.remove('active'));
            element.classList.add('active');
        }

        async function addModule() {
            const title = prompt("Введите название модуля:");
            if (!title) return;
            const response = await fetch(`/CourseConstructor/AddModule?courseId=@Model.CourseId&title=${encodeURIComponent(title)}`, { method: 'POST' });
            if (response.ok) location.reload();
        }

        async function addLesson(moduleId) {
            const title = prompt("Название нового урока:");
            if (!title) return;
            await fetch(`/CourseConstructor/AddLesson?moduleId=${moduleId}&title=${encodeURIComponent(title)}`, { method: 'POST' });
            location.reload();
        }

        async function loadLessonEditor(lessonId, element) {
            setActiveLesson(element);
            currentLessonId = lessonId;
            document.getElementById('editorPlaceholder').style.display = 'none';
            document.getElementById('editorForm').style.display = 'flex';

            const response = await fetch(`/CourseConstructor/GetLessonData/${lessonId}`);
            const lesson = await response.json();

            document.getElementById('currentLessonTitle').innerText = lesson.title;
            document.getElementById('editLessonName').value = lesson.title;

            renderSteps(lesson.steps);
        }

        function renderSteps(steps) {
            const container = document.getElementById('stepsContainer');
            container.innerHTML = '';

            steps.forEach((step, index) => {
                const stepDiv = document.createElement('div');
                stepDiv.className = 'step-card';

                const typeLabel = step.type === 0 ? "Текстовая лекция" : step.type === 1 ? "Видео-материал" : "Тестирование";

                stepDiv.innerHTML = `
                            <div style="display:flex; justify-content:space-between; margin-bottom:15px; align-items:center;">
                                <span class="badge-type">${typeLabel}</span>
                                <i class="bi bi-x-circle" style="cursor:pointer; color:#ff453a; font-size:1.2rem;" onclick="deleteStep(${step.id})"></i>
                            </div>
                            <label>Заголовок шага #${index + 1}</label>
                            <input type="text" value="${step.title || ''}" class="step-title" data-id="${step.id}">

                            <div style="margin-top:15px;">
                                ${step.type === 0 ? `<label>Текст лекции</label><textarea rows="8" class="step-content" data-id="${step.id}">${step.textContent || ''}</textarea>` : ''}
                                ${step.type === 1 ? `<label>URL видео (YouTube/Vimeo)</label><input type="text" class="step-video" data-id="${step.id}" value="${step.videoUrl || ''}">` : ''}
                                ${step.type === 2 ? `
                                    <div class="quiz-editor-box">
                                        <label style="font-size: 0.8rem; color: var(--primary); font-weight: bold;">ВАРИАНТЫ ОТВЕТОВ (отметьте правильные)</label>
                                        <div id="quiz-options-${step.id}" style="margin-top:10px;"></div>
                                        <button class="btn btn-outline" style="width:100%; margin-top:10px; font-size: 0.8rem;" onclick="addOption(${step.id})">
                                            <i class="bi bi-plus-circle"></i> Добавить вариант
                                        </button>
                                    </div>
                                ` : ''}
                            </div>
                        `;
                container.appendChild(stepDiv);
            });

            // После отрисовки всех карточек, загружаем данные для квизов
            steps.forEach(step => {
                if (step.type === 2) loadQuizOptions(step.id);
            });
        }

        async function addNewStep(type) {
            if (!currentLessonId) return;
            await fetch(`/CourseConstructor/AddStep?lessonId=${currentLessonId}&type=${type}`, { method: 'POST' });
            loadLessonEditor(currentLessonId, document.querySelector('.lesson-item.active'));
        }

        async function saveCurrentLesson() {
            const steps = [];
            document.querySelectorAll('.step-title').forEach(input => {
                const id = input.dataset.id;
                steps.push({
                    id: parseInt(id),
                    title: input.value,
                    textContent: document.querySelector(`textarea[data-id="${id}"]`)?.value || "",
                    videoUrl: document.querySelector(`input.step-video[data-id="${id}"]`)?.value || ""
                });
            });

            const result = await fetch('/CourseConstructor/SaveLesson', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    lessonId: currentLessonId,
                    title: document.getElementById('editLessonName').value,
                    steps: steps
                })
            });

            if (result.ok) alert("Урок успешно сохранен!");
        }

        async function deleteStep(stepId) {
            if (!confirm("Удалить этот шаг?")) return;
            const response = await fetch(`/CourseConstructor/DeleteStep/${stepId}`, { method: 'POST' });
            if (response.ok) loadLessonEditor(currentLessonId, document.querySelector('.lesson-item.active'));
        }

        async function loadQuizOptions(stepId) {
            const response = await fetch(`/CourseConstructor/GetQuizOptions?stepId=${stepId}`);
            const options = await response.json();
            const container = document.getElementById(`quiz-options-${stepId}`);
            if (!container) return;

            container.innerHTML = options.map(opt => `
                        <div class="quiz-option-row" style="display:flex; gap:10px; margin-bottom:8px; align-items:center;">
                            <input type="checkbox" ${opt.isCorrect ? 'checked' : ''}
                                   onchange="updateOption(${opt.id}, ${stepId}, this.checked, null)">
                            <input type="text" value="${opt.text}" style="margin:0; flex-grow:1;"
                                   onchange="updateOption(${opt.id}, ${stepId}, null, this.value)">
                            <i class="bi bi-trash" style="color:#ff453a; cursor:pointer;" onclick="deleteOption(${opt.id}, ${stepId})"></i>
                        </div>
                    `).join('');
        }

        async function addOption(stepId) {
            const response = await fetch(`/CourseConstructor/AddQuizOption?stepId=${stepId}`, { method: 'POST' });
            if (response.ok) loadQuizOptions(stepId);
        }

        async function updateOption(id, stepId, isCorrect, text) {
            const row = event.target.closest('.quiz-option-row');
            const currentText = text !== null ? text : row.querySelector('input[type="text"]').value;
            const currentCheck = isCorrect !== null ? isCorrect : row.querySelector('input[type="checkbox"]').checked;

            await fetch(`/CourseConstructor/UpdateQuizOption?id=${id}&text=${encodeURIComponent(currentText)}&isCorrect=${currentCheck}`, {
                method: 'POST'
            });
        }

        async function deleteOption(id, stepId) {
            await fetch(`/CourseConstructor/DeleteQuizOption/${id}`, { method: 'POST' });
            loadQuizOptions(stepId);
        }

        async function publishCourse(courseId) {
            if (!confirm("После публикации курс станет доступен всем студентам. Продолжить?")) return;

            const response = await fetch(`/CourseConstructor/PublishCourse?id=${courseId}`, { method: 'POST' });

            if (response.ok) {
                alert("Поздравляем! Курс опубликован.");
                const btn = document.getElementById('publishBtn');
                btn.innerHTML = '<i class="bi bi-check-all"></i> Опубликован';
                btn.disabled = true;
                btn.style.opacity = "0.7";
            } else {
                alert("Ошибка при публикации.");
            }
        }
    </script>
</body>
</html>