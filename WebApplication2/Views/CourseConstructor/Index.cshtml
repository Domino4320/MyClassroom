@model WebApplication2.Models.CourseConstructorViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Проектирование: @Model.CourseTitle</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/course-learn-features.css" asp-append-version="true" />
    <style>
        :root {
            --primary: #4fc3f7;
            --bg-dark: #0f172a;
            --bg-card: #162031;
            --sidebar-bg: #111a2e;
            --border: rgba(79, 195, 247, 0.25);
            --text: #e3f2fd;
            --text-muted: #90a4ae;
            --accent-gradient: linear-gradient(135deg, #0288d1, #26c6da);
            --danger: #ff453a;
            --success: #4caf50;
        }

        body {
            font-family: 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-dark);
            color: var(--text);
            margin: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        .sidebar {
            width: 320px;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            box-shadow: 10px 0 30px rgba(0,0,0,0.3);
        }

        .sidebar-header {
            padding: 25px 20px;
            border-bottom: 1px solid var(--border);
        }

        .module-list {
            overflow-y: auto;
            flex-grow: 1;
            padding: 15px;
        }

        .module-item {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-radius: 12px;
            margin-bottom: 15px;
            padding: 12px;
        }

        .lesson-item {
            margin: 8px 0 8px 15px;
            padding: 10px;
            background: rgba(79, 195, 247, 0.05);
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
            font-size: 0.9rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .lesson-item:hover {
                background: rgba(79, 195, 247, 0.15);
            }

            .lesson-item.active {
                background: var(--accent-gradient);
                color: white;
            }

        .module-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 6px;
        }

        .module-title-text {
            color: var(--primary);
            font-weight: 600;
            flex: 1;
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .sidebar-actions {
            display: flex;
            gap: 4px;
            align-items: center;
            flex-shrink: 0;
        }

        .sidebar-icon-btn {
            width: 26px;
            height: 26px;
            border: none;
            border-radius: 6px;
            background: rgba(255,255,255,0.06);
            color: var(--text-muted);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            font-size: 0.85rem;
            transition: 0.2s;
        }

        .sidebar-icon-btn:hover {
            background: rgba(79, 195, 247, 0.2);
            color: var(--primary);
        }

        .sidebar-icon-btn.danger:hover {
            background: rgba(255, 69, 58, 0.2);
            color: var(--danger);
        }

        .lesson-item-actions {
            display: flex;
            gap: 2px;
            opacity: 0;
            transition: 0.2s;
            position: relative;
            z-index: 2;
            flex-shrink: 0;
        }

        .sidebar-actions {
            position: relative;
            z-index: 2;
        }

        .lesson-item:hover .lesson-item-actions {
            opacity: 1;
        }

        .lesson-item.active .lesson-item-actions {
            opacity: 1;
        }

        .lesson-item-label {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            flex: 1;
            min-width: 0;
        }

        .lesson-item.active .sidebar-icon-btn {
            color: rgba(255,255,255,0.85);
            background: rgba(255,255,255,0.15);
        }

        .editor-area {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            background: radial-gradient(circle at top right, #1e293b, var(--bg-dark));
        }

        .editor-header {
            padding: 20px 40px;
            background: rgba(22, 32, 49, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .editor-content {
            padding: 40px;
            overflow-y: auto;
            flex-grow: 1;
        }

        .content-card {
            background: var(--bg-card);
            padding: 35px;
            border-radius: 24px;
            border: 1px solid var(--border);
            max-width: 900px;
            margin: 0 auto;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
        }

        input[type="text"], input[type="number"], input[type="url"], textarea, select {
            width: 100%;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: white;
            padding: 12px;
            margin-top: 5px;
            outline: none;
            box-sizing: border-box;
        }

        .btn {
            padding: 10px 22px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: var(--accent-gradient);
            color: white;
        }

        .btn-primary:hover {
            filter: brightness(1.07);
            color: #fff;
        }

        .btn-outline {
            background: rgba(79, 195, 247, 0.1);
            border: 1px solid var(--primary);
            color: var(--primary);
        }

        .btn-outline:hover {
            background: rgba(79, 195, 247, 0.22);
            color: #e3f2fd;
            border-color: #7dd3fc;
        }

        .step-card {
            background: rgba(255,255,255,0.02);
            border: 1px solid var(--border);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 25px;
            transition: border-color 0.3s;
        }

        .badge-type {
            background: var(--primary);
            color: #000;
            padding: 3px 10px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 800;
        }

        .step-card-actions {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .step-order-controls {
            display: flex;
            gap: 4px;
        }

        .btn-step-order {
            background: rgba(79, 195, 247, 0.1);
            border: 1px solid var(--border);
            color: var(--primary);
            border-radius: 6px;
            width: 28px;
            height: 28px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            line-height: 1;
        }

        .btn-step-order:hover:not(:disabled) {
            background: rgba(79, 195, 247, 0.22);
        }

        .btn-step-order:disabled {
            opacity: 0.35;
            cursor: not-allowed;
        }

        .quiz-editor-box {
            background: rgba(0,0,0,0.2);
            padding: 20px;
            border-radius: 12px;
            border: 1px dashed var(--border);
            margin-top: 15px;
        }

        .quiz-option-row {
            display: flex;
            gap: 10px;
            margin-bottom: 10px;
            align-items: center;
        }

        .btn-delete-opt.disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

        .quiz-error-msg,
        .step-field-error {
            color: var(--danger);
            font-size: 0.85rem;
            margin-top: 8px;
            display: block;
            line-height: 1.4;
        }

        .lesson-form-error {
            background: rgba(255, 69, 58, 0.12);
            border: 1px solid rgba(255, 69, 58, 0.45);
            color: #ff8a80;
            padding: 12px 16px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 0.9rem;
        }

        .lesson-form-success {
            background: rgba(76, 175, 80, 0.12);
            border: 1px solid rgba(76, 175, 80, 0.45);
            color: #a5d6a7;
            padding: 12px 16px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 0.9rem;
        }

        input.input-invalid,
        textarea.input-invalid {
            border-color: var(--danger) !important;
            box-shadow: 0 0 0 2px rgba(255, 69, 58, 0.2);
        }

        .settings-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 15px;
        }

        .lesson-materials-mount { margin-bottom: 24px; }
        .lesson-materials-block {
            padding: 14px 16px;
            border-radius: 12px;
            border: 1px dashed var(--border);
            background: rgba(0,0,0,0.15);
        }
        .lesson-materials-head {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 10px;
            font-weight: 600;
        }
        .lesson-materials-hint { font-size: 0.75rem; color: var(--text-muted); font-weight: 400; }
        .materials-list { margin-bottom: 10px; }
        .materials-empty { font-size: 0.85rem; color: var(--text-muted); margin: 0; }
        .materials-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 6px;
        }
        .materials-row--file {
            flex-direction: column;
            align-items: stretch;
            padding: 10px 12px;
            border-radius: 8px;
            background: rgba(255,255,255,0.04);
        }
        .materials-file-top {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
        }
        .materials-file-name {
            flex: 1;
            min-width: 0;
            font-size: 0.88rem;
            font-weight: 600;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .materials-file-caption-block {
            width: 100%;
            margin-top: 10px;
            padding-top: 10px;
            border-top: 1px solid var(--border);
        }
        .materials-caption-row {
            display: flex;
            gap: 8px;
            align-items: center;
            margin-top: 4px;
        }
        .materials-caption-row .materials-caption-input {
            flex: 1;
            min-width: 0;
        }
        .materials-caption-label {
            font-size: 0.72rem;
            color: var(--text-muted);
        }
        .materials-caption-input {
            width: 100%;
            padding: 6px 8px;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: rgba(0,0,0,0.2);
            color: inherit;
            font-family: inherit;
            font-size: 0.88rem;
        }
        .materials-upload-caption {
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px dashed var(--border);
        }
        .materials-upload-caption label {
            display: block;
            font-size: 0.78rem;
            color: var(--text-muted);
            margin-bottom: 4px;
        }
        .materials-file-caption {
            width: 100%;
            max-width: 360px;
            padding: 8px 10px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: rgba(0,0,0,0.2);
            color: inherit;
            font-family: inherit;
        }
        .materials-download-btn {
            font-size: 0.8rem;
            padding: 6px 10px;
            white-space: nowrap;
        }
        .materials-caption-save {
            font-size: 0.8rem;
            padding: 6px 10px;
            min-width: 36px;
        }
        .materials-link {
            flex: 1;
            display: flex;
            gap: 10px;
            align-items: center;
            padding: 8px 10px;
            border-radius: 8px;
            background: rgba(255,255,255,0.04);
            color: inherit;
            text-decoration: none;
            font-size: 0.88rem;
        }
        .materials-link--url {
            border: 1px solid rgba(167, 139, 250, 0.35);
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.12), rgba(79, 195, 247, 0.08));
        }
        .materials-link--url:hover {
            border-color: rgba(167, 139, 250, 0.6);
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.2), rgba(79, 195, 247, 0.12));
        }
        .materials-link-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 1rem;
        }
        .materials-link--url .materials-link-icon {
            background: rgba(124, 58, 237, 0.25);
            color: #c4b5fd;
        }
        .materials-link--file .materials-link-icon {
            background: rgba(79, 195, 247, 0.15);
        }
        .materials-link-body { flex: 1; min-width: 0; }
        .materials-title { display: block; font-weight: 600; }
        .materials-sub { font-size: 0.75rem; color: var(--text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .materials-open-badge {
            font-size: 0.7rem;
            font-weight: 700;
            color: #c4b5fd;
            padding: 4px 8px;
            border-radius: 999px;
            background: rgba(124, 58, 237, 0.2);
            flex-shrink: 0;
        }
        .materials-del {
            width: 28px; height: 28px; border: none; border-radius: 6px;
            background: rgba(255,69,58,0.15); color: var(--danger); cursor: pointer;
        }
        .materials-actions { display: flex; gap: 8px; flex-wrap: wrap; }
        .materials-limits {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin: 0 0 10px;
        }
        .materials-upload-btn.is-disabled,
        .materials-add-link-btn.is-disabled {
            opacity: 0.45;
            cursor: not-allowed;
            pointer-events: none;
        }
        .materials-add-link-btn:disabled {
            opacity: 0.45;
            cursor: not-allowed;
        }
        .materials-link-form {
            display: none;
            flex-direction: column;
            gap: 14px;
            margin-top: 12px;
            padding: 16px;
            border-radius: 12px;
            border: 1px dashed var(--border);
            background: rgba(0, 0, 0, 0.15);
        }
        .materials-link-form.is-open {
            display: flex;
        }
        .materials-link-field label {
            display: block;
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 6px;
        }
        .materials-link-field input {
            width: 100%;
            margin-top: 0;
        }
        .materials-link-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        .materials-msg { font-size: 0.85rem; margin-top: 8px; color: #a5d6a7; }
        .materials-msg.is-error { color: #ff8a80; }
        .interactive-img-hint {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin: 6px 0 0;
        }
        .interactive-img-opt-row {
            margin-bottom: 12px;
            padding: 12px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: rgba(0,0,0,0.12);
        }
        .interactive-img-opt-main {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
        }
        .interactive-img-opt-row .interactive-img-label {
            flex: 1;
            min-width: 120px;
            margin-top: 0;
        }
        .interactive-img-preview-box {
            width: 100px;
            height: 70px;
            border-radius: 8px;
            overflow: hidden;
            background: rgba(0,0,0,0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .interactive-img-preview {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .interactive-img-placeholder {
            font-size: 0.7rem;
            color: var(--text-muted);
            text-align: center;
            padding: 4px;
        }
        .interactive-img-upload-btn {
            margin: 0;
            cursor: pointer;
            font-size: 0.85rem;
            padding: 8px 12px;
        }
        .interactive-add-img-opt.is-disabled {
            opacity: 0.45;
            cursor: not-allowed;
            pointer-events: none;
        }
        .interactive-fill-template, .interactive-fill-blanks { width: 100%; }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-header">
            <a href="/MyCourses/Index" style="color: var(--primary); text-decoration: none; font-size: 0.9rem;">
                <i class="bi bi-arrow-left"></i> К моим курсам
            </a>
            <h3 style="margin-top:10px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@Model.CourseTitle</h3>
            <button class="btn btn-outline" style="width: 100%; justify-content: center;" onclick="addModule()">
                <i class="bi bi-folder-plus"></i> Добавить модуль
            </button>
        </div>
        <div class="module-list" id="moduleContainer">
            @foreach (var m in Model.Modules.OrderBy(x => x.Order))
            {
                <div class="module-item" data-module-id="@m.Id">
                    <div class="module-head">
                        <span class="module-title-text" title="@m.Title">@m.Title</span>
                        <div class="sidebar-actions">
                            <button type="button" class="sidebar-icon-btn js-rename-module" data-module-id="@m.Id" data-module-title="@m.Title" title="Переименовать модуль"><i class="bi bi-pencil"></i></button>
                            <button type="button" class="sidebar-icon-btn danger js-delete-module" data-module-id="@m.Id" title="Удалить модуль"><i class="bi bi-trash"></i></button>
                            <button type="button" class="sidebar-icon-btn js-add-lesson" data-module-id="@m.Id" title="Добавить урок"><i class="bi bi-plus-lg"></i></button>
                        </div>
                    </div>
                    <div class="lessons">
                        @foreach (var l in m.Lessons.OrderBy(x => x.Order))
                        {
                            <div class="lesson-item js-lesson-item" data-lesson-id="@l.Id">
                                <span class="lesson-item-label" title="@l.Title"><i class="bi bi-file-earmark-text"></i> @l.Title</span>
                                <div class="lesson-item-actions">
                                    <button type="button" class="sidebar-icon-btn danger js-delete-lesson" data-lesson-id="@l.Id" title="Удалить урок"><i class="bi bi-trash"></i></button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="editor-area">
        <div id="editorPlaceholder" style="text-align: center; margin-top: 150px; color: var(--text-muted);">
            <i class="bi bi-palette2" style="font-size: 5rem; color: var(--primary); opacity: 0.5;"></i>
            <h2>Мастерская курса</h2>
            <p>Выберите урок в левой панели или создайте новый</p>
        </div>

        <div id="editorForm" style="display: none; height: 100%; flex-direction: column;">
            <div class="editor-header">
                <div>
                    <span style="color: var(--text-muted); font-size: 0.8rem;">КОНСТРУКТОР КУРСА</span>
                    <h2 id="currentLessonTitle" style="margin: 0;">Панель управления</h2>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button class="btn btn-outline" onclick="publishCourse(@Model.CourseId)" style="border-color: #4caf50; color: #4caf50;">
                        <i class="bi bi-send"></i> Опубликовать
                    </button>
                    <button class="btn btn-primary" onclick="saveCurrentLesson(true)">
                        <i class="bi bi-cloud-check"></i> Сохранить урок
                    </button>
                </div>
            </div>
            <div class="editor-content">
                <div class="content-card">
                    <div style="margin-bottom: 30px;">
                        <label>Заголовок урока</label>
                        <input type="text" id="editLessonName" oninput="clearLessonTitleError()">
                        <div id="lesson-title-error" class="step-field-error" style="display:none;"></div>
                    </div>

                    <div id="lesson-form-error" class="lesson-form-error" style="display:none;" role="alert"></div>
                    <div id="lesson-form-success" class="lesson-form-success" style="display:none;" role="status"></div>

                    <div id="lessonMaterialsMount" class="lesson-materials-mount"></div>

                    <div id="stepsContainer"></div>

                    <div style="display:flex; gap:15px; margin-top:40px; border-top:1px solid var(--border); padding-top:30px; justify-content: center;">
                        <button class="btn btn-outline" onclick="addNewStep('Text')"><i class="bi bi-text-paragraph"></i> + Текст</button>
                        <button class="btn btn-outline" onclick="addNewStep('Video')"><i class="bi bi-play-btn"></i> + Видео</button>
                        <button class="btn btn-outline" onclick="addNewStep('Quiz')"><i class="bi bi-check2-square"></i> + Тест</button>
                        <button class="btn btn-outline" onclick="addNewStep('Interactive')"><i class="bi bi-puzzle"></i> + Интерактив</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/interactive-step-editor.js" asp-append-version="true"></script>
    <script src="~/js/lesson-materials-editor.js" asp-append-version="true"></script>
    <script>
        let currentLessonId = null;

        function escapeForTemplate(value) {
            return String(value ?? "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#39;")
                .replace(/`/g, "&#96;")
                .replace(/\$/g, "&#36;");
        }

        function showInlineError(elementId, message) {
            const el = document.getElementById(elementId);
            if (!el) return;
            if (message) {
                el.innerHTML = `<i class="bi bi-exclamation-triangle"></i> ${message}`;
                el.style.display = 'block';
            } else {
                el.innerHTML = '';
                el.style.display = 'none';
            }
        }

        function showLessonFormError(message) {
            const success = document.getElementById('lesson-form-success');
            const error = document.getElementById('lesson-form-error');
            if (success) success.style.display = 'none';
            if (error) {
                if (message) {
                    error.innerHTML = `<i class="bi bi-exclamation-triangle"></i> ${message}`;
                    error.style.display = 'block';
                } else {
                    error.innerHTML = '';
                    error.style.display = 'none';
                }
            }
        }

        function showLessonFormSuccess(message) {
            const error = document.getElementById('lesson-form-error');
            const success = document.getElementById('lesson-form-success');
            if (error) error.style.display = 'none';
            if (success) {
                success.textContent = message || '';
                success.style.display = message ? 'block' : 'none';
                if (message) {
                    setTimeout(() => { success.style.display = 'none'; }, 3500);
                }
            }
        }

        function clearLessonTitleError() {
            const input = document.getElementById('editLessonName');
            showInlineError('lesson-title-error', '');
            input?.classList.remove('input-invalid');
        }

        function clearStepFieldError(stepId, prefix) {
            showInlineError(`${prefix}-${stepId}`, '');
            const card = document.querySelector(`.step-card[data-step-id="${stepId}"]`);
            if (!card) return;
            const videoInput = card.querySelector('.step-video');
            if (videoInput) {
                videoInput.classList.remove('input-invalid');
            }
            const titleInput = card.querySelector('.step-title');
            if (titleInput) titleInput.classList.remove('input-invalid');
            const textInput = card.querySelector('.step-content');
            if (textInput) textInput.classList.remove('input-invalid');
            if (!card.querySelector('.step-field-error[style*="block"]')) {
                card.style.borderColor = 'var(--border)';
            }
        }

        function resetStepCardErrors(stepCard) {
            stepCard.style.borderColor = 'var(--border)';
            stepCard.querySelectorAll('.step-field-error').forEach(el => {
                el.style.display = 'none';
                el.innerHTML = '';
            });
            stepCard.querySelectorAll('.input-invalid').forEach(el => el.classList.remove('input-invalid'));
        }

        function markStepInvalid(stepCard, fieldErrorId, message, inputEl) {
            stepCard.style.borderColor = 'var(--danger)';
            showInlineError(fieldErrorId, message);
            if (inputEl) inputEl.classList.add('input-invalid');
            return message;
        }

        function getQuizCorrectTextInput(stepCard, stepId) {
            const isManual = stepCard.querySelector('.step-manual-check')?.value === 'true';
            if (isManual) {
                return document.getElementById(`manual-quiz-settings-${stepId}`)?.querySelector('.step-correct-text') ?? null;
            }
            const mode = stepCard.querySelector('.step-auto-mode')?.value || 'options';
            if (mode === 'text') {
                return document.getElementById(`auto-quiz-text-box-${stepId}`)?.querySelector('.step-correct-text') ?? null;
            }
            return null;
        }

        function validateLessonForm() {
            let isValid = true;
            let summary = '';

            showLessonFormError('');

            const stepCards = document.querySelectorAll('.step-card');
            if (stepCards.length === 0) {
                showLessonFormError('Добавьте хотя бы один шаг в урок.');
                return { isValid: false, summary: 'Добавьте хотя бы один шаг в урок.' };
            }

            const lessonTitleInput = document.getElementById('editLessonName');
            const lessonTitle = (lessonTitleInput?.value || '').trim();
            if (!lessonTitle) {
                isValid = false;
                summary = summary || 'Укажите заголовок урока.';
                lessonTitleInput?.classList.add('input-invalid');
                showInlineError('lesson-title-error', 'Укажите заголовок урока.');
            } else {
                clearLessonTitleError();
            }

            document.querySelectorAll('.step-card').forEach(stepCard => {
                resetStepCardErrors(stepCard);

                const stepId = stepCard.getAttribute('data-step-id');
                const stepType = String(stepCard.getAttribute('data-step-type') ?? '');
                const titleInput = stepCard.querySelector('.step-title');
                const stepTitle = (titleInput?.value || '').trim();

                if (!stepTitle) {
                    isValid = false;
                    summary = summary || 'У каждого шага должен быть заголовок.';
                    markStepInvalid(stepCard, `step-title-error-${stepId}`, 'Укажите заголовок шага.', titleInput);
                }

                if (stepType === '0' || stepType === '3') {
                    const textarea = stepCard.querySelector('.step-content');
                    const textValue = (textarea?.value || '').trim();
                    if (!textValue || textValue === 'Введите текст...') {
                        isValid = false;
                        summary = summary || 'Заполните текстовый контент во всех текстовых шагах.';
                        markStepInvalid(stepCard, `text-error-${stepId}`, 'Введите содержимое шага.', textarea);
                    }
                }

                if (stepType === '1') {
                    const videoInput = stepCard.querySelector('.step-video');
                    const videoValue = (videoInput?.value || '').trim();
                    const hasValidVideoUrl = videoValue.length > 0 && /^https?:\/\/\S+$/i.test(videoValue);
                    if (!hasValidVideoUrl) {
                        isValid = false;
                        summary = summary || 'Укажите корректные ссылки на видео (http/https).';
                        markStepInvalid(stepCard, `video-error-${stepId}`, 'Укажите корректную ссылку на видео.', videoInput);
                    }
                }

                if (stepType === '2') {
                    const manualSelect = stepCard.querySelector('.step-manual-check');
                    const isManual = manualSelect ? manualSelect.value === 'true' : false;
                    const errorSpanId = `quiz-error-${stepId}`;
                    const pointsInput = stepCard.querySelector('.step-points');
                    const points = parseInt(pointsInput?.value, 10);

                    if (!points || points < 1) {
                        isValid = false;
                        summary = summary || 'Укажите количество баллов для каждого теста.';
                        markStepInvalid(stepCard, errorSpanId, 'Укажите количество баллов (минимум 1).', pointsInput);
                    }

                    if (!isManual) {
                        const mode = stepCard.querySelector('.step-auto-mode')?.value || 'options';
                        if (mode === 'text') {
                            const textInput = getQuizCorrectTextInput(stepCard, stepId);
                            const textValue = (textInput?.value || '').trim();
                            if (!textValue) {
                                isValid = false;
                                summary = summary || 'Заполните незаполненные поля в тестах.';
                                markStepInvalid(stepCard, errorSpanId, 'Введите правильный текстовый ответ.', textInput);
                            }
                        } else {
                            const container = document.getElementById(`quiz-options-${stepId}`);
                            if (container) {
                                const optionRows = [...container.querySelectorAll('.quiz-option-row')];
                                const inputType = stepCard.querySelector('.step-is-multiple')?.checked ? 'checkbox' : 'radio';

                                if (optionRows.length < 2) {
                                    isValid = false;
                                    summary = summary || 'В каждом тесте должно быть минимум 2 варианта ответа.';
                                    markStepInvalid(stepCard, errorSpanId, 'Добавьте минимум 2 варианта ответа.');
                                }

                                const emptyOption = optionRows
                                    .map(row => row.querySelector('input[type="text"]'))
                                    .find(i => !(i?.value || '').trim());
                                if (emptyOption) {
                                    isValid = false;
                                    summary = summary || 'Заполните незаполненные поля в тестах.';
                                    markStepInvalid(stepCard, errorSpanId, 'Заполните текст всех вариантов ответа.', emptyOption);
                                }

                                const correctCount = optionRows.filter(row =>
                                    row.querySelector(`input[type="${inputType}"]`)?.checked
                                ).length;
                                if (correctCount === 0) {
                                    isValid = false;
                                    summary = summary || 'Отметьте правильный вариант в каждом тесте.';
                                    markStepInvalid(stepCard, errorSpanId, 'Отметьте хотя бы один правильный вариант.');
                                }
                            } else {
                                isValid = false;
                                summary = summary || 'Настройте варианты ответа в тестах.';
                                markStepInvalid(stepCard, errorSpanId, 'Добавьте варианты ответа.');
                            }
                        }
                    } else {
                        const textInput = getQuizCorrectTextInput(stepCard, stepId);
                        const textValue = (textInput?.value || '').trim();
                        if (!textValue) {
                            isValid = false;
                            summary = summary || 'Заполните незаполненные поля в тестах.';
                            markStepInvalid(stepCard, errorSpanId, 'Введите эталонный ответ для ручной проверки.', textInput);
                        }
                    }
                }

                if (stepType === '4') {
                    if (!window.InteractiveStepEditor) {
                        isValid = false;
                        summary = summary || 'Редактор интерактивных заданий не загружен.';
                        markStepInvalid(stepCard, `interactive-error-${stepId}`, 'Редактор интерактивных заданий не загружен.');
                    } else {
                        const message = window.InteractiveStepEditor.validateFromCard(stepCard);
                        if (message) {
                            isValid = false;
                            summary = summary || 'Заполните все интерактивные задания.';
                            markStepInvalid(stepCard, `interactive-error-${stepId}`, message);
                        }
                    }
                }
            });

            if (!isValid) {
                showLessonFormError(summary || 'Исправьте ошибки в форме урока.');
            }

            return { isValid, summary };
        }

        function scrollToFirstError() {
            const target = document.querySelector(
                '#lesson-form-error[style*="block"], #lesson-title-error[style*="block"], .step-field-error:not([style*="none"])'
            );
            (target || document.getElementById('lesson-form-error'))?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function setActiveLesson(element) {
            document.querySelectorAll('.lesson-item').forEach(el => el.classList.remove('active'));
            element?.classList.add('active');
        }

        function updateSidebarLessonTitle(lessonId, title) {
            const label = document.querySelector(`.js-lesson-item[data-lesson-id="${lessonId}"] .lesson-item-label`);
            if (label) {
                label.innerHTML = `<i class="bi bi-file-earmark-text"></i> ${escapeForTemplate(title)}`;
                label.title = title;
            }
        }

        function initSidebarActions() {
            const container = document.getElementById('moduleContainer');
            if (!container || container.dataset.sidebarBound) return;
            container.dataset.sidebarBound = '1';

            container.addEventListener('click', async (e) => {
                const deleteLessonBtn = e.target.closest('.js-delete-lesson');
                if (deleteLessonBtn) {
                    e.preventDefault();
                    e.stopPropagation();
                    await deleteLesson(Number(deleteLessonBtn.dataset.lessonId));
                    return;
                }

                const deleteModuleBtn = e.target.closest('.js-delete-module');
                if (deleteModuleBtn) {
                    e.preventDefault();
                    e.stopPropagation();
                    await deleteModule(Number(deleteModuleBtn.dataset.moduleId));
                    return;
                }

                const renameModuleBtn = e.target.closest('.js-rename-module');
                if (renameModuleBtn) {
                    e.preventDefault();
                    e.stopPropagation();
                    await renameModule(Number(renameModuleBtn.dataset.moduleId), renameModuleBtn.dataset.moduleTitle || '');
                    return;
                }

                const addLessonBtn = e.target.closest('.js-add-lesson');
                if (addLessonBtn) {
                    e.preventDefault();
                    e.stopPropagation();
                    await addLesson(Number(addLessonBtn.dataset.moduleId));
                    return;
                }

                const lessonItem = e.target.closest('.js-lesson-item');
                if (lessonItem && !e.target.closest('.lesson-item-actions')) {
                    await loadLessonEditor(Number(lessonItem.dataset.lessonId), lessonItem);
                }
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initSidebarActions);
        } else {
            initSidebarActions();
        }

        async function addModule() {
            const title = prompt("Название модуля:");
            if (!title) return;
            const response = await fetch(`/CourseConstructor/AddModule?courseId=@Model.CourseId&title=${encodeURIComponent(title)}`, { method: 'POST' });
            if (response.ok) location.reload();
        }

        async function addLesson(moduleId) {
            const title = prompt("Название урока:");
            if (!title) return;
            const response = await fetch(`/CourseConstructor/AddLesson?moduleId=${moduleId}&title=${encodeURIComponent(title)}`, { method: 'POST' });
            if (response.ok) location.reload();
        }

        async function renameModule(moduleId, currentTitle) {
            const title = prompt("Название модуля:", currentTitle || "");
            if (title === null) return;
            const trimmed = title.trim();
            if (!trimmed) return alert("Название не может быть пустым.");
            const response = await fetch(`/CourseConstructor/RenameModule?moduleId=${moduleId}&title=${encodeURIComponent(trimmed)}`, { method: 'POST' });
            if (response.ok) location.reload();
            else alert((await response.text()) || "Не удалось переименовать модуль.");
        }

        async function deleteModule(moduleId) {
            if (!confirm("Удалить модуль и все уроки внутри?")) return;
            const response = await fetch(`/CourseConstructor/DeleteModule/${moduleId}`, { method: 'POST' });
            if (response.ok) location.reload();
            else alert((await response.text()) || "Не удалось удалить модуль.");
        }

        async function deleteLesson(lessonId) {
            if (!confirm("Удалить этот урок?")) return;
            const response = await fetch(`/CourseConstructor/DeleteLesson/${lessonId}`, { method: 'POST' });
            if (response.ok) location.reload();
            else alert((await response.text()) || "Не удалось удалить урок.");
        }

        async function loadLessonEditor(lessonId, element) {
            if (element) setActiveLesson(element);
            currentLessonId = lessonId;
            document.getElementById('editorPlaceholder').style.display = 'none';
            document.getElementById('editorForm').style.display = 'flex';

            const response = await fetch(`/CourseConstructor/GetLessonData/${lessonId}`);
            const lesson = await response.json();

            document.getElementById('currentLessonTitle').innerText = lesson.title;
            document.getElementById('editLessonName').value = lesson.title;

            showLessonFormError('');
            showLessonFormSuccess('');
            clearLessonTitleError();

            renderSteps(lesson.steps);
            updateStepOrderButtons();

            const materialsMount = document.getElementById('lessonMaterialsMount');
            if (materialsMount && window.LessonMaterialsEditor) {
                window.LessonMaterialsEditor.mount(lessonId, materialsMount);
            }
        }

        function getStepTypeLabel(type) {
            if (type === 0) return "Текст";
            if (type === 1) return "Video";
            if (type === 2) return "Тест";
            if (type === 4) return "Интерактив";
            if (type === 3) return "Код (устар.)";
            return "Шаг";
        }

        function clearStepsContainerPlaceholder() {
            const container = document.getElementById('stepsContainer');
            if (!container.querySelector('.step-card')) {
                container.innerHTML = '';
            }
        }

        function createStepCardElement(step) {
            const stepDiv = document.createElement('div');
            stepDiv.className = 'step-card';
            stepDiv.setAttribute('data-step-id', step.id);
            stepDiv.setAttribute('data-step-type', String(step.type));

            const typeLabel = getStepTypeLabel(step.type);
            const autoQuizMode = (!step.isManualCheck && (step.correctTextAnswer || '').trim().length > 0) ? 'text' : 'options';
            const safeTitle = escapeForTemplate(step.title || '');
            const safeTextContent = escapeForTemplate(step.textContent || '');
            const safeVideoUrl = escapeForTemplate(step.videoUrl || '');
            const safeCorrectText = escapeForTemplate(step.correctTextAnswer || '');

            stepDiv.innerHTML = `
                <div style="display:flex; justify-content:space-between; margin-bottom:15px; align-items:center;">
                    <span class="badge-type">${typeLabel}</span>
                    <div class="step-card-actions">
                        <div class="step-order-controls">
                            <button type="button" class="btn-step-order" data-step-id="${step.id}" data-dir="up" onclick="moveStep(${step.id}, 'up')" title="Переместить выше"><i class="bi bi-chevron-up"></i></button>
                            <button type="button" class="btn-step-order" data-step-id="${step.id}" data-dir="down" onclick="moveStep(${step.id}, 'down')" title="Переместить ниже"><i class="bi bi-chevron-down"></i></button>
                        </div>
                        <i class="bi bi-x-circle" style="cursor:pointer; color:var(--danger);" onclick="deleteStep(${step.id})"></i>
                    </div>
                </div>
                <label>Заголовок шага</label>
                <input type="text" value="${safeTitle}" class="step-title" data-id="${step.id}" oninput="clearStepFieldError(${step.id}, 'step-title-error')">
                <span id="step-title-error-${step.id}" class="step-field-error" style="display:none;"></span>

                ${step.type === 2 ? `
                <div class="settings-grid">
                    <div>
                        <label>Макс. баллов</label>
                        <input type="number" class="step-points" data-id="${step.id}" value="${step.maxPoints || 1}" min="1">
                    </div>
                    <div>
                        <label>Тип проверки</label>
                        <select class="step-manual-check" data-id="${step.id}" onchange="toggleCheckMode(${step.id}, this.value)">
                            <option value="false" ${!step.isManualCheck ? 'selected' : ''}>Автоматическая</option>
                            <option value="true" ${step.isManualCheck ? 'selected' : ''}>Вручную (текст)</option>
                        </select>
                    </div>
                </div>` : ''}

                <div style="margin-top:15px;">
                    ${step.type === 0 || step.type === 3 ? `
                        <textarea rows="6" class="step-content" data-id="${step.id}" oninput="clearStepFieldError(${step.id}, 'text-error')">${safeTextContent}</textarea>
                        <span id="text-error-${step.id}" class="step-field-error" style="display:none;"></span>` : ''}
                    ${step.type === 1 ? `
                        <input type="text" class="step-video" data-id="${step.id}" value="${safeVideoUrl}" placeholder="Ссылка на видео (YouTube / RuTube / любая https-ссылка)" oninput="clearStepFieldError(${step.id}, 'video-error')">
                        <span id="video-error-${step.id}" class="step-field-error" style="display:none;"></span>` : ''}
                    ${step.type === 4 ? `
                        <div id="interactive-editor-${step.id}" class="interactive-editor-mount"></div>
                        <span id="interactive-error-${step.id}" class="quiz-error-msg" style="display:none;"></span>` : ''}
                    ${step.type === 2 ? `
                        <div class="quiz-editor-box">
                            <div id="auto-quiz-settings-${step.id}" style="display: ${step.isManualCheck ? 'none' : 'block'};">
                                <div style="margin-bottom: 15px; padding-bottom: 10px; border-bottom: 1px solid var(--border);">
                                    <label>Формат ответа</label>
                                    <select class="step-auto-mode" data-id="${step.id}" onchange="toggleAutoQuizMode(${step.id}, this.value)">
                                        <option value="options" ${autoQuizMode === 'options' ? 'selected' : ''}>Варианты ответа</option>
                                        <option value="text" ${autoQuizMode === 'text' ? 'selected' : ''}>Текстовый ответ</option>
                                    </select>
                                </div>
                                <div style="margin-bottom: 15px; padding-bottom: 10px; border-bottom: 1px solid var(--border);">
                                    <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                                        <input type="checkbox" class="step-is-multiple" data-id="${step.id}" ${step.isMultipleChoice ? 'checked' : ''} onchange="toggleMultipleChoice(${step.id}, this.checked)">
                                        <span>Множественный выбор</span>
                                    </label>
                                </div>
                                <div id="auto-quiz-options-box-${step.id}" style="display:${autoQuizMode === 'options' ? 'block' : 'none'};">
                                    <div id="quiz-options-${step.id}"></div>
                                    <button class="btn btn-outline" style="width:100%; margin-top:10px;" onclick="addOption(${step.id})">+ Добавить вариант</button>
                                </div>
                                <div id="auto-quiz-text-box-${step.id}" style="display:${autoQuizMode === 'text' ? 'block' : 'none'};">
                                    <label>Правильный ответ (точное совпадение)</label>
                                    <textarea class="step-correct-text" data-id="${step.id}" rows="3" placeholder="Например: 42" oninput="this.closest('.step-card').style.borderColor='var(--border)'">${safeCorrectText}</textarea>
                                </div>
                            </div>
                            <div id="manual-quiz-settings-${step.id}" style="display: ${step.isManualCheck ? 'block' : 'none'};">
                                <label>Эталонный ответ (для учителя)</label>
                                <textarea class="step-correct-text" data-id="${step.id}" rows="3" placeholder="Опишите, каким должен быть правильный ответ..." oninput="this.closest('.step-card').style.borderColor='var(--border)'">${safeCorrectText}</textarea>
                            </div>
                            <span id="quiz-error-${step.id}" class="quiz-error-msg" style="display:none;"><i class="bi bi-exclamation-triangle"></i> Настройте правильные ответы!</span>
                        </div>` : ''}
                </div>`;

            return stepDiv;
        }

        async function initStepCardWidgets(stepDiv, step) {
            if (step.type === 2) {
                await loadQuizOptions(step.id, step.isMultipleChoice);
            }
            if (step.type === 4 && window.InteractiveStepEditor) {
                const mount = stepDiv.querySelector(`#interactive-editor-${step.id}`);
                if (mount) {
                    window.InteractiveStepEditor.render(mount, step.id, step.textContent || "");
                }
            }
        }

        async function appendStepCard(step) {
            clearStepsContainerPlaceholder();
            const container = document.getElementById('stepsContainer');
            const stepDiv = createStepCardElement(step);
            container.appendChild(stepDiv);
            await initStepCardWidgets(stepDiv, step);
            updateStepOrderButtons();
            stepDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        function updateStepOrderButtons() {
            const cards = [...document.querySelectorAll('#stepsContainer .step-card')];
            cards.forEach((card, index) => {
                const stepId = card.getAttribute('data-step-id');
                const upBtn = card.querySelector(`.btn-step-order[data-step-id="${stepId}"][data-dir="up"]`);
                const downBtn = card.querySelector(`.btn-step-order[data-step-id="${stepId}"][data-dir="down"]`);
                if (upBtn) upBtn.disabled = index === 0;
                if (downBtn) downBtn.disabled = index === cards.length - 1;
            });
        }

        async function moveStep(stepId, direction) {
            const container = document.getElementById('stepsContainer');
            const cards = [...container.querySelectorAll('.step-card')];
            const index = cards.findIndex(card => card.getAttribute('data-step-id') === String(stepId));
            if (index < 0) return;

            const targetIndex = direction === 'up' ? index - 1 : index + 1;
            if (targetIndex < 0 || targetIndex >= cards.length) return;

            const card = cards[index];
            const targetCard = cards[targetIndex];
            if (direction === 'up') {
                container.insertBefore(card, targetCard);
            } else {
                container.insertBefore(targetCard, card);
            }

            updateStepOrderButtons();

            const saved = await saveCurrentLesson(false);
            if (!saved) {
                if (direction === 'up') {
                    container.insertBefore(targetCard, card);
                } else {
                    container.insertBefore(card, targetCard);
                }
                updateStepOrderButtons();
            }
        }

        function renderSteps(steps) {
            const container = document.getElementById('stepsContainer');
            container.innerHTML = '';

            if (!steps || steps.length === 0) {
                container.innerHTML = '<div data-empty-steps="true" style="text-align:center; padding: 20px; color: var(--danger); border: 1px dashed var(--danger); border-radius: 12px;">В этом уроке еще нет ни одного шага. Добавьте контент ниже.</div>';
                return;
            }

            steps.forEach((step) => {
                const stepDiv = createStepCardElement(step);
                container.appendChild(stepDiv);
                initStepCardWidgets(stepDiv, step);
            });
        }

        function toggleCheckMode(stepId, isManual) {
            const autoBox = document.getElementById(`auto-quiz-settings-${stepId}`);
            const manualBox = document.getElementById(`manual-quiz-settings-${stepId}`);
            const stepCard = autoBox.closest('.step-card');
            const errorSpan = document.getElementById(`quiz-error-${stepId}`);

            if (stepCard) stepCard.style.borderColor = 'var(--border)';
            if (errorSpan) errorSpan.style.display = 'none';

            if (isManual === "true") {
                autoBox.style.display = 'none';
                manualBox.style.display = 'block';
            } else {
                autoBox.style.display = 'block';
                manualBox.style.display = 'none';
            }
        }

        function toggleAutoQuizMode(stepId, mode) {
            const optionsBox = document.getElementById(`auto-quiz-options-box-${stepId}`);
            const textBox = document.getElementById(`auto-quiz-text-box-${stepId}`);
            const stepCard = document.querySelector(`.step-card[data-step-id="${stepId}"]`);
            const errorSpan = document.getElementById(`quiz-error-${stepId}`);

            if (stepCard) stepCard.style.borderColor = 'var(--border)';
            if (errorSpan) errorSpan.style.display = 'none';

            if (mode === 'text') {
                if (optionsBox) optionsBox.style.display = 'none';
                if (textBox) textBox.style.display = 'block';

                const mult = document.querySelector(`.step-is-multiple[data-id="${stepId}"]`);
                if (mult) mult.checked = false;
            } else {
                if (optionsBox) optionsBox.style.display = 'block';
                if (textBox) textBox.style.display = 'none';

                const txt = stepCard?.querySelector(`textarea.step-correct-text[data-id="${stepId}"]`);
                if (txt) txt.value = '';
            }
        }

        async function syncQuizOptionsFromDom() {
            const tasks = [];
            document.querySelectorAll('.step-card[data-step-type="2"]').forEach(stepCard => {
                const stepId = stepCard.getAttribute('data-step-id');
                const isManual = stepCard.querySelector('.step-manual-check')?.value === 'true';
                const autoMode = stepCard.querySelector('.step-auto-mode')?.value || 'options';
                if (isManual || autoMode === 'text') return;

                const container = document.getElementById(`quiz-options-${stepId}`);
                if (!container) return;

                const inputType = stepCard.querySelector('.step-is-multiple')?.checked ? 'checkbox' : 'radio';
                container.querySelectorAll('.quiz-option-row').forEach(row => {
                    const id = row.getAttribute('data-opt-id');
                    const isCorrect = row.querySelector(`input[type="${inputType}"]`)?.checked || false;
                    const text = row.querySelector('input[type="text"]')?.value || '';
                    tasks.push(
                        fetch(`/CourseConstructor/UpdateQuizOption?id=${id}&text=${encodeURIComponent(text)}&isCorrect=${isCorrect}`, { method: 'POST' })
                    );
                });
            });
            if (tasks.length > 0) {
                await Promise.all(tasks);
            }
        }

        async function saveCurrentLesson(showSuccessMessage = false) {
            if (!currentLessonId) return true;

            await syncQuizOptionsFromDom();

            const validation = validateLessonForm();
            if (!validation.isValid) {
                scrollToFirstError();
                return false;
            }

            const steps = [];
            document.querySelectorAll('.step-card').forEach(card => {
                const id = card.getAttribute('data-step-id');
                const stepType = String(card.getAttribute('data-step-type') ?? '');
                const multCheck = card.querySelector(`.step-is-multiple`);
                const manualCheckSelect = card.querySelector(`.step-manual-check`);
                const isManual = manualCheckSelect?.value === 'true';
                const autoMode = card.querySelector(`.step-auto-mode`)?.value || 'options';
                const correctTextInput = getQuizCorrectTextInput(card, id);
                const correctText = correctTextInput?.value || "";
                const titleInput = card.querySelector('.step-title');

                let textContent = card.querySelector(`textarea.step-content`)?.value || "";
                if (stepType === "4" && window.InteractiveStepEditor) {
                    textContent = window.InteractiveStepEditor.serialize(card);
                }

                steps.push({
                    id: parseInt(id, 10),
                    title: titleInput ? titleInput.value : "",
                    textContent: textContent,
                    videoUrl: card.querySelector(`input.step-video`)?.value || "",
                    isMultipleChoice: multCheck ? multCheck.checked : false,
                    isManualCheck: isManual,
                    correctTextAnswer: (!isManual && autoMode === 'options') ? "" : correctText,
                    maxPoints: parseInt(card.querySelector('.step-points')?.value, 10) || 1
                });
            });

            const response = await fetch('/CourseConstructor/SaveLesson', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    lessonId: currentLessonId,
                    title: document.getElementById('editLessonName').value,
                    steps: steps
                })
            });

            if (!response.ok) {
                const errText = await response.text();
                showLessonFormError(errText || 'Не удалось сохранить урок. Проверьте заполнение полей.');
                scrollToFirstError();
                return false;
            }

            showLessonFormSuccess(showSuccessMessage ? 'Урок сохранён.' : '');
            const lessonTitle = document.getElementById('editLessonName')?.value?.trim() || '';
            if (lessonTitle) {
                document.getElementById('currentLessonTitle').innerText = lessonTitle;
                updateSidebarLessonTitle(currentLessonId, lessonTitle);
            }
            return true;
        }

        async function addNewStep(type) {
            if (!currentLessonId) {
                showLessonFormError('Сначала выберите урок в левой панели.');
                return;
            }

            const hasExistingSteps = document.querySelectorAll('#stepsContainer .step-card').length > 0;
            if (hasExistingSteps) {
                const saved = await saveCurrentLesson(false);
                if (!saved) return;
            }

            const response = await fetch(`/CourseConstructor/AddStep?lessonId=${currentLessonId}&type=${type}`, { method: 'POST' });
            if (!response.ok) {
                const errText = await response.text();
                showLessonFormError(errText || 'Не удалось добавить шаг.');
                return;
            }

            const newStep = await response.json();
            if (type === 'Quiz') {
                await fetch(`/CourseConstructor/AddQuizOption?stepId=${newStep.id}`, { method: 'POST' });
                await fetch(`/CourseConstructor/AddQuizOption?stepId=${newStep.id}`, { method: 'POST' });
            }

            await appendStepCard(newStep);
            showLessonFormSuccess('');
        }

        async function deleteStep(stepId) {
            if (!confirm("Удалить шаг?")) return;
            const response = await fetch(`/CourseConstructor/DeleteStep/${stepId}`, { method: 'POST' });
            if (!response.ok) return;

            const card = document.querySelector(`.step-card[data-step-id="${stepId}"]`);
            card?.remove();

            const container = document.getElementById('stepsContainer');
            if (!container.querySelector('.step-card')) {
                container.innerHTML = '<div data-empty-steps="true" style="text-align:center; padding: 20px; color: var(--danger); border: 1px dashed var(--danger); border-radius: 12px;">В этом уроке еще нет ни одного шага. Добавьте контент ниже.</div>';
            } else {
                updateStepOrderButtons();
            }
        }

        async function loadQuizOptions(stepId, isMultipleChoice) {
            const response = await fetch(`/CourseConstructor/GetQuizOptions?stepId=${stepId}`);
            const options = await response.json();
            const container = document.getElementById(`quiz-options-${stepId}`);
            if (!container) return;

            const inputType = isMultipleChoice ? "checkbox" : "radio";
            const isDeleteDisabled = options.length <= 2;

            container.innerHTML = options.map(opt => `
                                <div class="quiz-option-row" data-opt-id="${opt.id}">
                                    <input type="${inputType}" name="quiz-${stepId}" ${opt.isCorrect ? 'checked' : ''} onchange="handleOptionUpdate(${opt.id}, ${stepId}, '${inputType}')">
                                    <input type="text" value="${opt.text || ''}" onchange="handleOptionUpdate(${opt.id}, ${stepId}, '${inputType}')" style="margin:0;">
                                    <i class="bi bi-trash btn-delete-opt ${isDeleteDisabled ? 'disabled' : ''}"
                                       onclick="${isDeleteDisabled ? '' : `deleteOption(${opt.id}, ${stepId})`}"></i>
                                </div>`).join('');
        }

        async function handleOptionUpdate(optId, stepId, inputType) {
            const container = document.getElementById(`quiz-options-${stepId}`);
            const stepCard = container.closest('.step-card');
            const errorSpan = document.getElementById(`quiz-error-${stepId}`);

            if (stepCard) stepCard.style.borderColor = 'var(--border)';
            if (errorSpan) errorSpan.style.display = 'none';

            if (inputType === 'radio') {
                const rows = container.querySelectorAll('.quiz-option-row');
                for (const row of rows) {
                    const id = row.getAttribute('data-opt-id');
                    const isCorrect = row.querySelector('input[type="radio"]').checked;
                    const text = row.querySelector('input[type="text"]').value;
                    await fetch(`/CourseConstructor/UpdateQuizOption?id=${id}&text=${encodeURIComponent(text)}&isCorrect=${isCorrect}`, { method: 'POST' });
                }
            } else {
                const row = container.querySelector(`.quiz-option-row[data-opt-id="${optId}"]`);
                const isCorrect = row.querySelector('input[type="checkbox"]').checked;
                const text = row.querySelector('input[type="text"]').value;
                await fetch(`/CourseConstructor/UpdateQuizOption?id=${optId}&text=${encodeURIComponent(text)}&isCorrect=${isCorrect}`, { method: 'POST' });
            }
        }

        async function addOption(stepId) {
            const multCheck = document.querySelector(`.step-is-multiple[data-id="${stepId}"]`);
            await fetch(`/CourseConstructor/AddQuizOption?stepId=${stepId}`, { method: 'POST' });
            loadQuizOptions(stepId, multCheck?.checked || false);
        }

        async function deleteOption(id, stepId) {
            const multCheck = document.querySelector(`.step-is-multiple[data-id="${stepId}"]`);
            await fetch(`/CourseConstructor/DeleteQuizOption/${id}`, { method: 'POST' });
            loadQuizOptions(stepId, multCheck?.checked || false);
        }

        async function toggleMultipleChoice(stepId, isMultiple) {
            loadQuizOptions(stepId, isMultiple);
        }

        async function publishCourse(courseId) {
            if (document.querySelectorAll('.lesson-item').length === 0) {
                showLessonFormError('Курс пуст: добавьте хотя бы один урок.');
                return;
            }
            const saved = await saveCurrentLesson(false);
            if (!saved) return;
            if (!confirm("Опубликовать курс?")) return;

            const response = await fetch(`/CourseConstructor/PublishCourse?id=${courseId}`, { method: 'POST' });
            if (response.ok) {
                showLessonFormSuccess('Курс опубликован!');
                setTimeout(() => { window.location.href = '/MyCourses/Index'; }, 800);
            } else {
                const txt = await response.text();
                showLessonFormError(txt || 'Не удалось опубликовать курс.');
            }
        }
    </script>
</body>
</html>