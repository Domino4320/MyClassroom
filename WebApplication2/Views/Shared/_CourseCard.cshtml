@model WebApplication2.Models.CourseCardModel

<div class="course-card" id="course-card-@Model.Id">
    @{
        var isEditable = ViewData["IsEditable"] as bool? ?? false;
        var isEnrolled = ViewData["IsEnrolled"] as bool? ?? false;
        var bannerImg = string.IsNullOrWhiteSpace(Model.CoverImagePath) ? "/images/default-course.jpg" : Model.CoverImagePath;
        var avatarImg = string.IsNullOrWhiteSpace(Model.AuthorAvatar) || Model.AuthorAvatar == "/images/default_avatar.jpg"
        ? "/images/default_avatar.jpg" : Model.AuthorAvatar;
    }

    <div class="card-banner"
         style="background-image: url('@bannerImg'); @(!isEditable ? "cursor:pointer;" : "cursor:default;")"
    @if (!isEditable)
    {
        <text>onclick="location.href='@Url.Action("Details", "Course", new { id = Model.Id })'"</text>
    }>

        <div class="author-avatar-box" style="background-image: url('@avatarImg');"></div>

        @if (isEditable)
        {
                <div class="card-admin-overlay">
                    <a asp-controller="Teacher" asp-action="GradeCourse" asp-route-id="@Model.Id"
                       class="btn-admin-tool grading" title="Проверить ответы студентов"
                       onclick="event.stopPropagation();">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 11l3 3L22 4" />
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                        </svg>
                    </a>

                    <button type="button"
                            class="btn-admin-tool analytics js-course-analytics"
                            title="Аналитика курса"
                            data-course-id="@Model.Id"
                            onclick="event.stopPropagation(); return window.openCourseAnalyticsFromButton?.(this);">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 3v18h18" />
                            <path d="M7 15v4" />
                            <path d="M12 11v8" />
                            <path d="M17 7v12" />
                        </svg>
                    </button>

                    <button type="button"
                            class="btn-admin-tool feedback-stats js-lesson-feedback-stats"
                            title="Оценки уроков"
                            data-course-id="@Model.Id"
                            onclick="event.stopPropagation(); return window.openLessonFeedbackStatsFromButton?.(this);">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19V5" />
                            <path d="M4 19h16" />
                            <path d="M8 17v-5" />
                            <path d="M12 17V8" />
                            <path d="M16 17v-3" />
                            <circle cx="18" cy="6" r="2" fill="currentColor" stroke="none" />
                        </svg>
                    </button>

                @if (!Model.IsPublished)
                {
                            <a asp-controller="CreateCourse" asp-action="Edit" asp-route-id="@Model.Id"
                               class="btn-admin-tool edit" title="Изменить информацию"
                               style="background: rgba(16, 185, 129, 0.6);"
                               onclick="event.stopPropagation();">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 20h9" /><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
                                </svg>
                            </a>

                            <a asp-controller="CourseConstructor" asp-action="Index" asp-route-id="@Model.Id"
                               class="btn-admin-tool edit" title="Конструктор уроков"
                               onclick="event.stopPropagation();">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M11 4H4C2.89543 4 2 4.89543 2 6V20C2 21.1046 2.89543 22 4 22H18C19.1046 22 20 21.1046 20 20V13" />
                                    <path d="M18.5 2.5C19.3284 1.67157 20.6716 1.67157 21.5 2.5C22.3284 3.32843 22.3284 4.67157 21.5 5.5L12 15L8 16L9 12L18.5 2.5Z" />
                                </svg>
                            </a>
                }

                    <button onclick="deleteCourse(@Model.Id); event.stopPropagation();" class="btn-admin-tool delete" title="Удалить курс">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 6H5H21" /><path d="M8 6V4C8 3.46957 8.21071 2.96086 8.58579 2.58579C8.96086 2.21071 9.46957 2 10 2H14C14.5304 2 15.0391 2.21071 15.4142 2.58579C15.7893 2.96086 16 3.46957 16 4V6M19 6V20C19 20.5304 18.7893 21.0391 18.4142 21.4142C18.0391 21.7893 17.5304 22 17 22H7C6.46957 22 5.96086 21.7893 5.58579 21.4142C5.21071 21.0391 5 20.5304 5 20V6H19Z" /><path d="M10 11V17" /><path d="M14 11V17" />
                        </svg>
                    </button>
                </div>
        }
    </div>

    <div class="card-main-content">
        <span class="cat-badge">@Model.Category</span>
        <h3 class="card-course-title">@Model.Title</h3>
        <span class="card-author-handle">@@@Model.AuthorUsername</span>
        @if (WebApplication2.Models.CourseDisplayHelper.HasValidCreatedAt(Model.CreatedAt))
        {
            <span class="card-created-date">Создан @Model.CreatedAt.ToLocalTime().ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"))</span>
        }
        <p class="card-description">@Model.Description</p>
    </div>

    <div class="card-action-footer @(isEditable ? "editable" : "")">
        @if (!isEditable)
        {
            if (isEnrolled)
            {
                <a asp-controller="Course" asp-action="Learn" asp-route-id="@Model.Id" class="btn-start-course btn-start-course--continue">
                    Продолжить обучение
                </a>
            }
            else
            {
                <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.Id" class="btn-start-course">
                    Посмотреть курс
                </a>
            }
        }
        else
        {
            <span class="status-badge @(Model.IsPublished ? "status-published" : "status-draft")">
                @(Model.IsPublished ? "Опубликован" : "Черновик")
            </span>
        }
    </div>
</div>