@model WebApplication2.Models.CourseCardModel

<style>
    /* Основной контейнер карточки */
    .course-card {
        max-width: 360px;
        width: 100%;
        background: linear-gradient(145deg, #162031, #0f172a);
        border-radius: 24px;
        overflow: hidden;
        position: relative;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 1px solid rgba(79, 195, 247, 0.2);
        font-family: 'Segoe UI', Roboto, sans-serif;
        color: #e3f2fd;
        display: flex;
        flex-direction: column;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

        .course-card:hover {
            transform: translateY(-8px);
            border-color: rgba(79, 195, 247, 0.5);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.7);
        }

    /* Стили баннера (обложки) */
    .card-banner {
        width: 100%;
        height: 200px;
        position: relative;
        background: #0a0f1a;
    }

        .card-banner img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* Заполняет блок без искажения пропорций */
            display: block;
        }

    /* Аватар автора */
    .author-avatar-box {
        position: absolute;
        bottom: -25px;
        right: 20px;
        width: 54px;
        height: 54px;
        border-radius: 14px;
        border: 3px solid #162031;
        overflow: hidden;
        background: #1e293b;
        z-index: 10;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }

        .author-avatar-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Кнопки управления (редактировать/удалить) */
    .card-admin-overlay {
        position: absolute;
        top: 15px;
        left: 15px;
        display: flex;
        gap: 8px;
        z-index: 15;
    }

    .btn-admin-tool {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        transition: 0.3s;
        color: white;
        backdrop-filter: blur(4px);
    }

        .btn-admin-tool.edit {
            background: rgba(3, 169, 244, 0.6);
        }

        .btn-admin-tool.delete {
            background: rgba(244, 67, 54, 0.6);
        }

        .btn-admin-tool:hover {
            transform: scale(1.1);
            background: rgba(255, 255, 255, 0.2);
        }

    /* Тело карточки */
    .card-main-content {
        padding: 35px 24px 20px 24px;
        flex-grow: 1;
    }

    .cat-badge {
        background: rgba(79, 195, 247, 0.1);
        color: #4fc3f7;
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .card-course-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 12px 0 4px 0;
        line-height: 1.2;
        color: #ffffff;
    }

    .card-author-handle {
        color: #90a4ae;
        font-size: 0.85rem;
        margin-bottom: 15px;
        display: block;
    }

    /* Выпадающее описание */
    .description-collapse {
        max-height: 0;
        overflow: hidden;
        transition: all 0.4s ease;
        font-size: 0.9rem;
        color: #b0bec5;
        opacity: 0;
        line-height: 1.5;
    }

        .description-collapse.show {
            max-height: 150px;
            opacity: 1;
            margin-top: 15px;
        }

    .toggle-desc-btn {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #e3f2fd;
        width: 100%;
        padding: 8px;
        border-radius: 10px;
        cursor: pointer;
        font-size: 0.8rem;
        transition: 0.3s;
    }

        .toggle-desc-btn:hover {
            background: rgba(255, 255, 255, 0.08);
        }

    /* Футер с кнопкой действия */
    .card-action-footer {
        padding: 20px 24px 24px 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .btn-start-course {
        background: linear-gradient(135deg, #0288d1, #26c6da);
        color: white !important;
        text-decoration: none;
        display: block;
        text-align: center;
        padding: 12px;
        border-radius: 12px;
        font-weight: 600;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(2, 136, 209, 0.3);
    }

        .btn-start-course:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(2, 136, 209, 0.5);
            filter: brightness(1.1);
        }
</style>

<div class="course-card" id="course-card-@Model.Id">
    <div class="card-banner">
        <img src="@(string.IsNullOrEmpty(Model.CoverImagePath) ? "/images/default-course.jpg" : Model.CoverImagePath)"
             alt="Course Cover"
             onerror="this.src='/images/default-course.jpg'">

        <div class="author-avatar-box">
            @if (!string.IsNullOrEmpty(Model.AuthorAvatar) && Model.AuthorAvatar != "/images/default_avatar.jpg")
            {
                @* Если в БД есть путь, используем его *@
                <img src="@Model.AuthorAvatar" alt="Author" onerror="this.src='/images/default_avatar.jpg'">
            }
            else
            {
                @* Если в БД пусто или стоит заглушка — принудительно выводим дефолт *@
                <img src="/images/default_avatar.jpg" alt="Author Default">
            }
        </div>

        @if (ViewData["IsEditable"] != null && (bool)ViewData["IsEditable"])
        {
            <div class="card-admin-overlay">
                <a asp-controller="CourseConstructor" asp-action="Index" asp-route-id="@Model.Id"
                   class="btn-admin-tool edit" title="Редактировать структуру">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M11 4H4C2.89543 4 2 4.89543 2 6V20C2 21.1046 2.89543 22 4 22H18C19.1046 22 20 21.1046 20 20V13"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M18.5 2.5C19.3284 1.67157 20.6716 1.67157 21.5 2.5C22.3284 3.32843 22.3284 4.67157 21.5 5.5L12 15L8 16L9 12L18.5 2.5Z"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>

                <button onclick="deleteCourse(@Model.Id)" class="btn-admin-tool delete" title="Удалить курс">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 6H5H21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M8 6V4C8 3.46957 8.21071 2.96086 8.58579 2.58579C8.96086 2.21071 9.46957 2 10 2H14C14.5304 2 15.0391 2.21071 15.4142 2.58579C15.7893 2.96086 16 3.46957 16 4V6M19 6V20C19 20.5304 18.7893 21.0391 18.4142 21.4142C18.0391 21.7893 17.5304 22 17 22H7C6.46957 22 5.96086 21.7893 5.58579 21.4142C5.21071 21.0391 5 20.5304 5 20V6H19Z"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M10 11V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M14 11V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
            </div>
        }
    </div>

    <div class="card-main-content">
        <span class="cat-badge">@Model.Category</span>
        <h3 class="card-course-title">@Model.Title</h3>
        <span class="card-author-handle">@@@Model.AuthorUsername</span>

        @* Убрали кнопку "Подробнее", описание теперь просто текст (обрезанный или скрытый) *@
        <p style="color: #b0bec5; font-size: 0.9rem; margin-top: 10px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
            @Model.Description
        </p>
    </div>

    <div class="card-action-footer">
        @* Если юзер записан — кнопка ведет в Learn, если нет — в Details *@
        @if (ViewData["IsEnrolled"] != null && (bool)ViewData["IsEnrolled"])
        {
            <a asp-controller="Course" asp-action="Learn" asp-route-id="@Model.Id" class="btn-start-course" style="background: linear-gradient(135deg, #10b981, #059669);">
                Продолжить обучение
            </a>
        }
        else
        {
            <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.Id" class="btn-start-course">
                Посмотреть курс
            </a>
        }
    </div>
</div>

<script>
    // Функция раскрытия описания
    if (typeof toggleCardDescription !== 'function') {
        window.toggleCardDescription = function (id) {
            const desc = document.getElementById('desc-' + id);
            const btnText = document.getElementById('text-' + id);

            if (desc.classList.contains('show')) {
                desc.classList.remove('show');
                btnText.innerText = 'Подробнее';
            } else {
                desc.classList.add('show');
                btnText.innerText = 'Скрыть';
            }
        };
    }
</script>