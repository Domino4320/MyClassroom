
<div class="course-card">
    <!-- Three dots -->
    <button class="course-menu-btn" aria-label="Дополнительные параметры">
        &#8942;
    </button>

    <!-- Dropdown -->
    <div class="course-menu">
        <button>Редактировать</button>
        <button>Участники</button>
        <button class="danger">Удалить</button>
    </div>

    <!-- Header -->
    <div class="course-header">
        <img class="teacher-avatar"
             src="https://i.pravatar.cc/100?img=12"
             alt="Преподаватель">

        <div class="course-title-block">
            <h3 class="course-title">Frontend Development</h3>
            <span class="course-teacher">Иван Иванов</span>
        </div>
    </div>

    <!-- Info -->
    <div class="course-info">
        <div class="info-item">
            <span class="info-label">Участников</span>
            <span class="info-value">24</span>
        </div>

        <div class="info-item">
            <span class="info-label">Статус</span>
            <span class="info-value accent">Активен</span>
        </div>
    </div>
</div>
