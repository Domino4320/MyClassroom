@model IEnumerable<WebApplication2.Controllers.GradingViewModel>

@{
    Layout = null;
    ViewData["Title"] = "Проверка работ";
    var pendingCount = Model?.Count() ?? 0;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Проверка: @ViewBag.CourseTitle</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <style>
        :root {
            --bg: #0f172a;
            --card: #1e293b;
            --card-hover: #243044;
            --border: #334155;
            --text: #f8fafc;
            --muted: #94a3b8;
            --accent: #38bdf8;
            --success: #10b981;
            --danger: #f87171;
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0;
            padding: 0;
            background: var(--bg);
            color: var(--text);
            font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            line-height: 1.5;
        }

        .page {
            max-width: 920px;
            margin: 0 auto;
            padding: 28px 20px 80px;
        }

        .page-top {
            margin-bottom: 32px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--muted);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
            padding: 8px 14px;
            margin: 0 0 16px -14px;
            border-radius: 10px;
            transition: color 0.2s, background 0.2s;
        }

        .back-link:hover {
            color: var(--accent);
            background: rgba(56, 189, 248, 0.08);
        }

        .page-title {
            font-size: clamp(1.5rem, 4vw, 2rem);
            font-weight: 800;
            margin: 0 0 8px;
            letter-spacing: -0.02em;
        }

        .page-subtitle {
            margin: 0;
            color: var(--muted);
            font-size: 0.95rem;
        }

        .page-subtitle strong {
            color: var(--text);
            font-weight: 700;
        }

        .submission-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 24px;
            margin-bottom: 20px;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .submission-card:hover {
            border-color: rgba(56, 189, 248, 0.35);
            box-shadow: 0 12px 32px rgba(0, 0, 0, 0.25);
        }

        .card-head {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            margin-bottom: 22px;
            padding-bottom: 18px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        .avatar {
            width: 48px;
            height: 48px;
            flex-shrink: 0;
            background: rgba(56, 189, 248, 0.12);
            border: 1px solid rgba(56, 189, 248, 0.3);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent);
            font-weight: 800;
            font-size: 1.1rem;
        }

        .card-head-main {
            flex: 1;
            min-width: 0;
        }

        .student-login {
            font-weight: 700;
            font-size: 1.05rem;
            margin-bottom: 4px;
        }

        .submitted-at {
            font-size: 0.85rem;
            color: var(--muted);
        }

        .step-badge {
            flex-shrink: 0;
            max-width: 45%;
            text-align: right;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--accent);
            background: rgba(56, 189, 248, 0.1);
            border: 1px solid rgba(56, 189, 248, 0.25);
            padding: 8px 12px;
            border-radius: 10px;
            line-height: 1.35;
        }

        .field-block {
            margin-bottom: 18px;
        }

        .field-label {
            display: block;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--muted);
            margin-bottom: 8px;
        }

        .answer-box {
            background: rgba(15, 23, 42, 0.65);
            border: 1px solid var(--border);
            border-left: 3px solid var(--accent);
            border-radius: 12px;
            padding: 16px 18px;
            white-space: pre-wrap;
            word-break: break-word;
            line-height: 1.6;
        }

        .reference-box {
            background: rgba(16, 185, 129, 0.06);
            border: 1px dashed rgba(16, 185, 129, 0.35);
            border-radius: 12px;
            padding: 14px 18px;
            white-space: pre-wrap;
            word-break: break-word;
            font-size: 0.95rem;
            line-height: 1.55;
        }

        .grading-form {
            display: grid;
            grid-template-columns: 110px 1fr auto;
            gap: 14px;
            align-items: end;
            margin-top: 22px;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
        }

        @@media (max-width: 720px) {
            .grading-form {
                grid-template-columns: 1fr;
            }

            .step-badge {
                max-width: 100%;
                text-align: left;
                margin-top: 8px;
            }

            .card-head {
                flex-wrap: wrap;
            }
        }

        .input-field {
            width: 100%;
            background: #0f172a;
            border: 1px solid var(--border);
            color: var(--text);
            padding: 11px 14px;
            border-radius: 10px;
            font-size: 0.95rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .input-field:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.12);
        }

        .btn-grade {
            background: linear-gradient(135deg, #10b981, #059669);
            color: #fff;
            border: none;
            padding: 12px 22px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            white-space: nowrap;
            transition: transform 0.15s, box-shadow 0.2s;
        }

        .btn-grade:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(16, 185, 129, 0.35);
        }

        .empty-state {
            text-align: center;
            padding: 72px 24px;
            color: var(--muted);
            border: 1px dashed var(--border);
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.02);
        }

        .empty-state i {
            font-size: 2.5rem;
            color: var(--success);
            opacity: 0.6;
            margin-bottom: 16px;
        }

        .empty-state h3 {
            color: var(--text);
            margin: 0 0 8px;
        }
    </style>
</head>
<body>
    <div class="page">
        <header class="page-top">
            <a class="back-link" href="/Teacher/GradingCenter">
                <i class="fa-solid fa-arrow-left"></i>
                К центру проверки
            </a>
            <h1 class="page-title">@ViewBag.CourseTitle</h1>
            <p class="page-subtitle">
                @if (pendingCount > 0)
                {
                    <text>Ожидают проверки: <strong>@pendingCount</strong> @(pendingCount == 1 ? "ответ" : pendingCount < 5 ? "ответа" : "ответов")</text>
                }
                else
                {
                    <text>Все ответы по этому курсу проверены</text>
                }
            </p>
        </header>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <div><i class="fa-solid fa-circle-check"></i></div>
                <h3>Всё проверено</h3>
                <p>Нет ответов, ожидающих ручной проверки по этому курсу.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <article class="submission-card" id="submission-@item.SubmissionId">
                    <div class="card-head">
                        <div class="avatar">@item.StudentLogin.Substring(0, 1).ToUpper()</div>
                        <div class="card-head-main">
                            <div class="student-login">@item.StudentLogin</div>
                            <div class="submitted-at">
                                <i class="fa-regular fa-clock"></i>
                                @item.SubmittedAt.ToString("dd.MM.yyyy HH:mm")
                            </div>
                        </div>
                        <div class="step-badge">@item.LessonTitle · @item.StepTitle</div>
                    </div>

                    <div class="field-block">
                        <span class="field-label">Ответ студента</span>
                        <div class="answer-box">@item.UserAnswer</div>
                    </div>

                    @if (!string.IsNullOrEmpty(item.ReferenceAnswer))
                    {
                        <div class="field-block">
                            <span class="field-label">Эталонный ответ</span>
                            <div class="reference-box">@item.ReferenceAnswer</div>
                        </div>
                    }

                    <div class="grading-form">
                        <div>
                            <label class="field-label" for="grade-@item.SubmissionId">Баллы (макс. @item.MaxPoints)</label>
                            <input type="number" id="grade-@item.SubmissionId" class="input-field"
                                   min="0" max="@item.MaxPoints" value="@item.MaxPoints" />
                        </div>
                        <div>
                            <label class="field-label" for="comment-@item.SubmissionId">Комментарий</label>
                            <input type="text" id="comment-@item.SubmissionId" class="input-field"
                                   placeholder="Комментарий для студента (необязательно)" />
                        </div>
                        <button type="button" class="btn-grade" onclick="submitGrade(@item.SubmissionId)">
                            <i class="fa-solid fa-check"></i> Подтвердить
                        </button>
                    </div>
                </article>
            }
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function submitGrade(id) {
            const gradeInput = document.getElementById(`grade-${id}`);
            const grade = parseInt(gradeInput?.value, 10);
            const comment = document.getElementById(`comment-${id}`).value;

            if (Number.isNaN(grade) || grade < 0) {
                Swal.fire('Ошибка', 'Баллы не могут быть отрицательными.', 'error');
                if (gradeInput) gradeInput.focus();
                return;
            }

            try {
                const response = await fetch('/Teacher/SubmitGrade', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        submissionId: id,
                        grade: grade,
                        comment: comment
                    })
                });

                if (response.ok) {
                    const card = document.getElementById(`submission-${id}`);
                    card.style.transition = 'opacity 0.3s, transform 0.3s';
                    card.style.opacity = '0';
                    card.style.transform = 'translateX(24px)';
                    setTimeout(() => {
                        card.remove();
                        if (!document.querySelectorAll('.submission-card').length) {
                            location.reload();
                        } else {
                            const subtitle = document.querySelector('.page-subtitle');
                            const left = document.querySelectorAll('.submission-card').length;
                            if (subtitle) {
                                subtitle.innerHTML = `Ожидают проверки: <strong>${left}</strong> ${left === 1 ? 'ответ' : left < 5 ? 'ответа' : 'ответов'}`;
                            }
                        }
                    }, 300);
                } else {
                    Swal.fire('Ошибка', 'Не удалось сохранить оценку', 'error');
                }
            } catch {
                Swal.fire('Ошибка', 'Произошла сетевая ошибка', 'error');
            }
        }
    </script>
</body>
</html>
