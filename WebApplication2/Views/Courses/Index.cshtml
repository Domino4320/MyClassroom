@model IEnumerable<WebApplication2.Models.CourseCardModel>

@{
    ViewData["Title"] = "MyClassroom - Библиотека курсов";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="~/css/style_for_main_page.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <title>@ViewData["Title"]</title>

    <style>
        /* Базовые настройки страницы */
        body {
            margin: 0;
            padding: 0;
            background-color: #f8fafc;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        .main-layout {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        /* Область контента */
        .content-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .main-content {
            padding: 40px;
            width: 100%;
            box-sizing: border-box;
        }

        /* Стили заголовка страницы */
        .page-header {
            margin-bottom: 30px;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 15px;
        }

            .page-header h2 {
                color: #1e293b;
                margin: 0;
                font-size: 1.8rem;
            }

        /* Секция поиска */
        .search-container {
            margin-bottom: 40px;
            display: flex;
            justify-content: center;
        }

        .search-input-wrapper {
            width: 100%;
            max-width: 550px;
        }

        .dynamic-search-input {
            width: 100%;
            padding: 16px 24px;
            background: #1e293b;
            border: 1px solid rgba(79, 195, 247, 0.4);
            border-radius: 14px;
            color: #ffffff;
            font-size: 1rem;
            outline: none;
            transition: all 0.3s ease;
        }

            .dynamic-search-input:focus {
                border-color: #38bdf8;
                box-shadow: 0 0 15px rgba(56, 189, 248, 0.2);
            }

        /* СЕТКА */
        .courses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 30px;
            width: 100%;
        }

        /* Элемент сетки */
        .course-item {
            display: flex;
            justify-content: center;
            width: 100%;
            min-width: 320px;
        }

            /* Форсируем размеры для вложенной карточки */
            .course-item > div,
            .course-item > .course-card {
                width: 100% !important;
                max-width: 360px !important;
            }

            .course-item.hidden {
                display: none !important;
            }

        /* Состояния поиска */
        .no-search-results {
            display: none;
            grid-column: 1 / -1;
            text-align: center;
            padding: 60px 20px;
            color: #64748b;
            background: rgba(226, 232, 240, 0.5);
            border-radius: 20px;
            border: 2px dashed #cbd5e1;
        }

        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 100px 20px;
            color: #94a3b8;
        }

            .empty-state i {
                font-size: 4rem;
                margin-bottom: 20px;
                display: block;
            }

        /* Стили для аватара автора внутри карточки (на случай, если их нет в CSS) */
        .author-avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #38bdf8;
            background-color: #e2e8f0;
        }
    </style>
</head>
<body>

    <div class="main-layout">
        @await Html.PartialAsync("_Sidebar")

        <div class="content-area">
            @await Html.PartialAsync("_Header")

            <main class="main-content">
                <div class="page-header">
                    <h2>Библиотека курсов</h2>
                </div>

                <section class="search-container">
                    <div class="search-input-wrapper">
                        <input type="text"
                               id="librarySearch"
                               class="dynamic-search-input"
                               placeholder="Введите название курса для поиска..."
                               autocomplete="off">
                    </div>
                </section>

                <section class="courses-grid" id="coursesGrid">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var course in Model)
                        {
                            @* Важно: Убедитесь, что в CourseCardModel данные автора подгружены.
                    Если аватар пуст, мы можем передать стандартную заглушку.
                    *@
                            <div class="course-item" data-title="@course.Title.ToLower()">
                                @await Html.PartialAsync("_CourseCard", course)
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fa-solid fa-box-open"></i>
                            <p>В данный момент доступных курсов нет.</p>
                        </div>
                    }

                    @* Сообщение о пустом результате поиска *@
                    <div id="noResults" class="no-search-results">
                        <i class="fa-solid fa-magnifying-glass" style="font-size: 2rem; margin-bottom: 10px; display: block;"></i>
                        <p>По вашему запросу ничего не найдено. Попробуйте другое название.</p>
                    </div>
                </section>
            </main>
        </div>
    </div>

    <script src="~/js/script_for_main_page.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById('librarySearch');
            const items = document.querySelectorAll('.course-item');
            const noResults = document.getElementById('noResults');

            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    const query = this.value.toLowerCase().trim();
                    let foundCount = 0;

                    if (query === "") {
                        items.forEach(item => item.classList.remove('hidden'));
                        if (noResults) noResults.style.display = 'none';
                        return;
                    }

                    items.forEach(item => {
                        const title = item.getAttribute('data-title') || "";
                        if (title.includes(query)) {
                            item.classList.remove('hidden');
                            foundCount++;
                        } else {
                            item.classList.add('hidden');
                        }
                    });

                    if (noResults) {
                        noResults.style.display = (foundCount === 0) ? 'block' : 'none';
                    }
                });
            }
        });
    </script>
</body>
</html>