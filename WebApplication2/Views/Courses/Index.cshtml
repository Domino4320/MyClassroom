@model WebApplication2.Models.CourseListPageViewModel
@using System.Globalization
@using WebApplication2.Models

@{
    ViewData["Title"] = "MyClassroom";
    ViewData["SearchInputId"] = "librarySearch";
    ViewData["AuthorSearchInputId"] = "libraryAuthorSearch";
    ViewData["SearchPlaceholder"] = "Введите название курса...";
    ViewData["AuthorSearchPlaceholder"] = "Введите имя автора...";
    ViewData["FilterCategories"] = Model.Categories;
}

@section Styles {
    <link href="~/css/style_for_main_page.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/course_list_page.css" rel="stylesheet" asp-append-version="true" />
}

<div class="page-header">
    <h2>Библиотека курсов</h2>
</div>

@await Html.PartialAsync("_CourseListFilters")

<section class="courses-grid" id="coursesGrid">
    @if (Model.Items.Any())
    {
        @foreach (var course in Model.Items)
        {
            var createdAt = CourseDisplayHelper.NormalizeCreatedAt(course.CreatedAt);
            <div class="course-item"
                 data-title="@course.Title.ToLower()"
                 data-author="@course.AuthorUsername.ToLower()"
                 data-category="@course.Category"
                 data-rating="@course.AverageRating.ToString(CultureInfo.InvariantCulture)"
                 data-rec="@course.RecPercent"
                 data-created="@createdAt.Ticks">
                @await Html.PartialAsync("_CourseCard", course)
            </div>
        }
    }
    else if (Model.TotalCount == 0)
    {
        <div class="empty-state">
            <i class="fa-solid fa-box-open"></i>
            <p>В данный момент доступных курсов нет.</p>
        </div>
    }

    <div id="noResults" class="no-search-results">
        <i class="fa-solid fa-magnifying-glass" style="font-size: 2rem; margin-bottom: 10px; display: block;"></i>
        <p>По вашему запросу ничего не найдено. Измените фильтры или название.</p>
    </div>
</section>

@await Html.PartialAsync("_CoursePagination", Model)

@section Scripts {
    <script src="~/js/course-list-filters.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            initCourseListFilters("librarySearch", "libraryAuthorSearch");
        });
    </script>
}
