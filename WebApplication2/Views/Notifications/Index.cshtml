@model List<WebApplication2.Models.NotificationModel>
@{
    ViewData["Title"] = "MyClassroom";
}

@section Styles {
    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />
}

<div class="notif-page">
    <div class="page-header">
        <h1>Уведомления</h1>
    </div>

    @Html.AntiForgeryToken()

    @if (Model == null || !Model.Any())
    {
        <div class="notif-empty" role="status">
            <div class="notif-empty-icon" aria-hidden="true">
                <i class="fa-regular fa-bell"></i>
            </div>
            <h3>Пока нет уведомлений</h3>
            <p>Когда кто-то ответит на ваш комментарий или преподаватель ответит вам, сообщение появится здесь.</p>
        </div>
    }
    else
    {
        <div class="notif-actions">
        <button type="button" class="notif-btn notif-btn-ghost" id="markAllReadBtn">Отметить всё прочитанным</button>
        <button type="button" class="notif-btn notif-btn-danger" id="deleteAllNotifBtn">Очистить все</button>
    </div>

    <div class="notif-list" id="notifList">
        @foreach (var n in Model)
        {
            var cardClass = n.IsRead ? "notif-card" : "notif-card notif-card--unread";
            <article class="@cardClass" data-notif-id="@n.Id">
                <div class="notif-card-body">
                    @if (!string.IsNullOrWhiteSpace(n.Url))
                    {
                        <a class="notif-card-link" href="@n.Url">
                            <div class="notif-title">@n.Title</div>
                            @if (!string.IsNullOrWhiteSpace(n.Body))
                            {
                                <div class="notif-body">@n.Body</div>
                            }
                        </a>
                    }
                    else
                    {
                        <div class="notif-title">@n.Title</div>
                        @if (!string.IsNullOrWhiteSpace(n.Body))
                        {
                            <div class="notif-body">@n.Body</div>
                        }
                    }
                    <div class="notif-meta">@n.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                </div>
                <div class="notif-card-actions">
                    @if (!n.IsRead)
                    {
                        <button type="button" class="notif-icon-btn" data-action="read" data-id="@n.Id" title="Отметить прочитанным">
                            <i class="fa-solid fa-check"></i>
                        </button>
                    }
                    <button type="button" class="notif-icon-btn notif-icon-btn--danger" data-action="delete" data-id="@n.Id" title="Удалить">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </div>
            </article>
        }
    </div>
    }
</div>

@section Scripts {
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            window.initNotificationsPage?.();
        });
    </script>
}
