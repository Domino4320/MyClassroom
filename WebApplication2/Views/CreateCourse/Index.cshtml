@model WebApplication2.Models.CourseModel

@{
    bool isEdit = Model != null && Model.Id != 0;
    ViewData["Title"] = isEdit ? "Редактирование курса" : "Создание нового курса";
}

@section Styles {
    <link href="~/css/create_course.css" rel="stylesheet" asp-append-version="true" />
}

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script>
        $(document).ready(function () {
            $("#fileInp").on("change", function () {
                var fileName = $(this).val().split("\\").pop();
                if (fileName) {
                    $("#fileName").text("Выбран файл: " + fileName).css("color", "#4ade80");
                }
            });
            $("form").bind("invalid-form.validate", function () {
                $(".btn-submit-course").addClass("animate-shake");
                setTimeout(function () {
                    $(".btn-submit-course").removeClass("animate-shake");
                }, 500);
            });
        });
    </script>
}

<div class="page-wrapper">
    <div class="course-registration-card animate-in">
        <header class="header-content">
            <div class="icon-circle">
                <i class="fa-solid @(isEdit ? "fa-pen-to-square" : "fa-plus")"></i>
            </div>
            <h1>@(isEdit ? "Редактирование курса" : "Регистрация курса")</h1>
            <p>@(isEdit ? $"Изменение данных курса: {Model.Title}" : "Заполните форму, чтобы создать новую учебную программу")</p>
        </header>

        <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" enctype="multipart/form-data" class="main-course-form">

            @if (isEdit)
            {
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="IsPublished" />
            }

            <div class="field-block">
                <label>Название курса <span class="required_icon">*</span></label>
                <div class="input-with-icon">
                    <input asp-for="Title" type="text" placeholder="Введите название...">
                </div>
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="field-block">
                <label>Краткое описание</label>
                <textarea asp-for="Description" rows="3" placeholder="О чем ваш курс?"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="dual-fields">
                <div class="field-block">
                    <label>Категория <span class="required_icon">*</span></label>
                    <div class="input-with-icon">
                        <select asp-for="Category">
                            <option value="" disabled selected>Выберите категорию</option>

                            <optgroup label="💻 IT и Разработка">
                                <option value="Frontend (React/Vue/Angular)">Frontend (React/Vue/Angular)</option>
                                <option value="Backend (.NET/C#)">Backend (.NET/C#)</option>
                                <option value="Backend (Java/Spring)">Backend (Java/Spring)</option>
                                <option value="Python разработка">Python разработка</option>
                                <option value="Node.js / JavaScript Backend">Node.js / JavaScript Backend</option>
                                <option value="iOS разработка (Swift)">iOS разработка (Swift)</option>
                                <option value="Android разработка (Kotlin)">Android разработка (Kotlin)</option>
                                <option value="Data Science и Machine Learning">Data Science и Machine Learning</option>
                                <option value="Кибербезопасность">Кибербезопасность</option>
                                <option value="DevOps и SRE">DevOps и SRE</option>
                                <option value="Автоматизация тестирования">Автоматизация тестирования</option>
                                <option value="Ручное тестирование">Ручное тестирование</option>
                                <option value="GameDev (Unity)">GameDev (Unity)</option>
                                <option value="GameDev (Unreal Engine)">GameDev (Unreal Engine)</option>
                                <option value="Блокчейн и Смарт-контракты">Блокчейн и Смарт-контракты</option>
                            </optgroup>

                            <optgroup label="🎨 Дизайн и Творчество">
                                <option value="UI/UX Дизайн">UI/UX Дизайн</option>
                                <option value="Графический дизайн">Графический дизайн</option>
                                <option value="Веб-дизайн">Веб-дизайн</option>
                                <option value="Motion Design (After Effects)">Motion Design (After Effects)</option>
                                <option value="3D Моделирование (Blender/Maya)">3D Моделирование (Blender/Maya)</option>
                                <option value="Цифровая иллюстрация">Цифровая иллюстрация</option>
                                <option value="Дизайн интерьеров">Дизайн интерьеров</option>
                                <option value="Профессиональная фотография">Профессиональная фотография</option>
                                <option value="Монтаж видео (Premiere/Resolve)">Монтаж видео (Premiere/Resolve)</option>
                            </optgroup>

                            <optgroup label="📊 Бизнес и Аналитика">
                                <option value="Product Management">Product Management</option>
                                <option value="Project Management (Agile/Scrum)">Project Management (Agile/Scrum)</option>
                                <option value="Бизнес-аналитика">Бизнес-аналитика</option>
                                <option value="Системная аналитика">Системная аналитика</option>
                                <option value="Маркетинговая стратегия">Маркетинговая стратегия</option>
                                <option value="SEO оптимизация">SEO оптимизация</option>
                                <option value="Контекстная реклама">Контекстная реклама</option>
                                <option value="SMM и продвижение">SMM и продвижение</option>
                            </optgroup>

                            <optgroup label="📈 Финансы и Право">
                                <option value="Бухгалтерский учет">Бухгалтерский учет</option>
                                <option value="Финансовый анализ">Финансовый анализ</option>
                                <option value="Инвестиции и Трейдинг">Инвестиции и Трейдинг</option>
                                <option value="Налогообложение">Налогообложение</option>
                                <option value="Право в сфере IT">Право в сфере IT</option>
                                <option value="Криптовалюты и DeFi">Криптовалюты и DeFi</option>
                            </optgroup>

                            <optgroup label="🌍 Языки и Лингвистика">
                                <option value="Английский (общий)">Английский (общий)</option>
                                <option value="Английский для бизнеса">Английский для бизнеса</option>
                                <option value="Английский для IT">Английский для IT</option>
                                <option value="Немецкий язык">Немецкий язык</option>
                                <option value="Французский язык">Французский язык</option>
                                <option value="Китайский язык">Китайский язык</option>
                                <option value="Японский язык">Японский язык</option>
                            </optgroup>

                            <optgroup label="🧪 Наука и Образование">
                                <option value="Высшая математика">Высшая математика</option>
                                <option value="Общая психология">Общая психология</option>
                                <option value="Детская психология">Детская психология</option>
                                <option value="Социология">Социология</option>
                                <option value="Физика/Химия">Физика/Химия</option>
                            </optgroup>

                            <optgroup label="🛠️ Техника и Ремесла">
                                <option value="Робототехника">Робототехника</option>
                                <option value="Электроника и схемотехника">Электроника и схемотехника</option>
                                <option value="Столярное дело">Столярное дело</option>
                                <option value="Ювелирное искусство">Ювелирное искусство</option>
                                <option value="Кройка и шитье">Кройка и шитье</option>
                            </optgroup>

                            <optgroup label="🍏 Здоровье и Спорт">
                                <option value="Фитнес-тренер">Фитнес-тренер</option>
                                <option value="Йога и Пилатес">Йога и Пилатес</option>
                                <option value="Нутрициология">Нутрициология</option>
                                <option value="Медитация и Mindfulness">Медитация и Mindfulness</option>
                            </optgroup>

                            <optgroup label="💡 Soft Skills">
                                <option value="Ораторское мастерство">Ораторское мастерство</option>
                                <option value="Тайм-менеджмент">Тайм-менеджмент</option>
                                <option value="Лидерство">Лидерство</option>
                                <option value="Эмоциональный интеллект">Эмоциональный интеллект</option>
                            </optgroup>

                            <optgroup label="🎸 Хобби и Лайфстайл">
                                <option value="Кулинария/Кондитер">Кулинария/Кондитер</option>
                                <option value="Игра на гитаре/фортепиано">Игра на гитаре/фортепиано</option>
                                <option value="Вокал">Вокал</option>
                                <option value="Рисование">Рисование</option>
                                <option value="Шахматы">Шахматы</option>
                            </optgroup>
                        </select>
                    </div>
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>
            </div>

            <div class="field-block" style="margin-bottom: 30px;">
                <label>Обложка курса</label>

                @if (isEdit && !string.IsNullOrEmpty(Model.CoverImagePath))
                {
                    <div class="current-cover-wrapper">
                        <img src="@Model.CoverImagePath" alt="Текущая обложка" />
                        <div>
                            <span style="display:block;font-size:0.85rem;color:var(--text-muted);">Текущая обложка</span>
                            <span style="font-size:0.75rem;color:var(--text-muted);">Загрузите новый файл для замены</span>
                        </div>
                    </div>
                }

                <div class="upload-box" onclick="document.getElementById('fileInp').click()">
                    <i class="fa-solid fa-image"></i>
                    <p id="fileName">@(isEdit ? "Заменить текущую обложку" : "Нажмите для выбора фото")</p>
                    <input type="file" name="uploadCover" id="fileInp" hidden accept="image/*">
                </div>
            </div>

            <div class="form-actions-row">
                <button type="button" class="btn-ghost" onclick="history.back()">Отмена</button>
                <button type="submit" class="btn-submit-course @(isEdit ? "btn-success" : "")">
                    @(isEdit ? "Сохранить изменения" : "Создать курс")
                </button>
            </div>
        </form>
    </div>
</div>