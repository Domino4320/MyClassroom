
@model WebApplication2.Models.CourseModel

<link href="~/css/create_course.css" rel="stylesheet" />
<link href="~/css/style_for_main_page.css" rel="stylesheet" />
<style>
    /* Стили для текста ошибки */
    .text-danger, .field-validation-error {
        color: #ff4d4d;
        font-size: 0.85rem;
        margin-top: 4px;
        display: block;
        animation: fadeIn 0.3s ease-in;
    }

    /* Подсветка инпута при ошибке */
    .input-validation-error {
        border: 1.5px solid #ff4d4d !important;
        background-color: rgba(255, 77, 77, 0.05) !important;
    }

        /* Иконка ошибки, если нужно (опционально) */
        .input-validation-error + .required_icon {
            color: #ff4d4d;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@section Scripts {
    @* Подключаем стандартные библиотеки валидации (они должны быть в проекте по умолчанию) *@
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script>
        $(document).ready(function () {
            // 1. Скрипт для отображения имени выбранного файла
            $('#fileInp').on('change', function () {
                var fileName = $(this).val().split('\\').pop();
                if (fileName) {
                    $('#fileName').text("Выбран файл: " + fileName).css("color", "#4ade80");
                } else {
                    $('#fileName').text("Нажмите для выбора фото").css("color", "");
                }
            });

            // 2. Настройка валидации "на лету"
            // Переопределяем стандартные классы jquery validate, чтобы они дружили с вашими стилями
            $('form').bind('invalid-form.validate', function () {
                // Можно добавить общую логику, если форма не валидна (например, вибрация кнопки)
                $('.btn-submit-course').addClass('animate-shake');
                setTimeout(function () {
                    $('.btn-submit-course').removeClass('animate-shake');
                }, 500);
            });
        });

         document.getElementById('fileInp').onchange = function () {
            document.getElementById('fileName').innerHTML = this.files[0].name;
        };
    </script>
}

@await Html.PartialAsync("_Header")
@await Html.PartialAsync("_Sidebar")
