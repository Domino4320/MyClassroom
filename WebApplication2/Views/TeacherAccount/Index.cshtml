@model ProfileViewModel
@{
    ViewData["Title"] = "MyClassroom";
}

@section Styles {
    <link rel="stylesheet" href="~/css/teacher_account.css" asp-append-version="true" />
}

<div class="main-gradient-bg"></div>

<div class="teacher-account-container">
    <div class="profile-layout">
        <aside class="side-panel">
            <div class="avatar-wrapper">
                <img src="@(Model.User.Avatar ?? Url.Content("~/images/default_avatar.jpg"))" alt="Avatar" class="profile-img" id="mainAvatar">
            </div>

            <h1 class="teacher-name">@Model.User.Username</h1>

            <div class="profile-field">
                <div class="profile-field-body">
                    <p class="tagline" id="currentJobText">@Model.TeacherInfo.CurrentJob</p>
                </div>
                <button type="button" class="edit-btn" title="Редактировать" onclick="editField('CurrentJob')"><i class="fa-solid fa-pen"></i></button>
            </div>

            <div class="profile-field experience-row">
                <div class="profile-field-body experience-inner">
                    <i class="fa-solid fa-award"></i>
                    <span><span id="experienceText">@Model.TeacherInfo.Experience</span> лет опыта</span>
                </div>
                <button type="button" class="edit-btn" title="Редактировать" onclick="editField('Experience')"><i class="fa-solid fa-pen"></i></button>
            </div>

            <div class="action-buttons">
                <div class="portfolio-row">
                    @if (string.IsNullOrEmpty(Model.TeacherInfo.PortfolioUrl))
                    {
                        <a href="#" id="portfolioUrl" class="btn btn-primary" onclick="editField('PortfolioUrl'); return false;">
                            <i class="fa-solid fa-briefcase"></i> Портфолио
                        </a>
                    }
                    else
                    {
                        <a href="@Model.TeacherInfo.PortfolioUrl" id="portfolioUrl" class="btn btn-primary" target="_blank" rel="noopener">
                            <i class="fa-solid fa-briefcase"></i> Портфолио
                        </a>
                    }
                    <button type="button" class="edit-btn" title="Ссылка на портфолио" onclick="editField('PortfolioUrl')"><i class="fa-solid fa-pen"></i></button>
                </div>
                <a href="@Url.Action("Index", "CreateCourse")" class="btn btn-accent-outline">
                    <i class="fa-solid fa-plus-circle"></i> Создать курс
                </a>
                <a href="@Url.Action("GradingCenter", "Teacher")" class="btn btn-accent-outline">
                    <i class="fa-solid fa-check-double"></i> Проверка ответов
                </a>
            </div>
        </aside>

        <main class="profile-main">
            <section class="glass-card animate-fade-in">
                <div class="section-header">
                    <h2 class="section-title"><i class="fa-solid fa-user-tie"></i> Обо мне</h2>
                    <button type="button" class="edit-btn" title="Редактировать" onclick="editField('About')"><i class="fa-solid fa-pen"></i></button>
                </div>
                <p class="description" id="aboutText">@Model.TeacherInfo.About</p>

                <div class="section-header">
                    <span class="tag-title">Теги (через запятую):</span>
                    <button type="button" class="edit-btn" title="Редактировать" onclick="editField('TeacherTags')"><i class="fa-solid fa-pen"></i></button>
                </div>
                <div class="skills-tags" id="tagsContainer">
                    @if (!string.IsNullOrEmpty(Model.TeacherInfo?.TeacherTags))
                    {
                        @foreach (var tag in Model.TeacherInfo.TeacherTags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <span class="tag">@tag.Trim()</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">Теги не указаны</span>
                    }
                </div>
            </section>

            <section class="glass-card animate-fade-in delay-2">
                <div class="section-header">
                    <h2 class="section-title"><i class="fa-solid fa-rocket"></i> Дополнительная информация</h2>
                    <button type="button" class="edit-btn" title="Редактировать" onclick="editField('ExtraInfo')"><i class="fa-solid fa-pen"></i></button>
                </div>
                <div class="extra-info-list" id="extraInfoText">
                    @(Model.TeacherInfo.ExtraInfo ?? "")
                </div>
            </section>
        </main>
    </div>
</div>

<div id="editModal" class="modal">
    <div class="modal-content glass-card">
        <h3>Редактировать данные</h3>
        <input type="hidden" id="editFieldName">
        <div id="inputContainer"></div>
        <div id="fieldError" class="modal-field-error" role="alert" aria-live="polite"></div>
        <div class="modal-buttons">
            <button class="btn btn-outline" onclick="closeModal()">Отмена</button>
            <button id="saveBtn" class="btn btn-primary" onclick="saveChanges()">Сохранить</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/teacher_account.js" asp-append-version="true"></script>
}
