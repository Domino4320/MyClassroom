@model WebApplication2.Models.CourseLearnViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    Layout = null;
    var tokens = Antiforgery.GetAndStoreTokens(Context);
    var isStepCompleted = Model.CompletedStepIds.Contains(Model.CurrentStep.Id);
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Обучение - @Model.CurrentStep.Title</title>
    <style>
        /* Базовые стили сохранены для дизайна, исправлены только функциональные моменты */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            width: 100%;
            overflow: hidden;
            background-color: #0f172a;
            color: #e2e8f0;
            font-family: 'Inter', sans-serif;
        }

        .learn-container {
            display: flex;
            height: 100vh;
            width: 100%;
        }

        .learn-sidebar {
            width: 300px;
            background: #1e293b;
            border-right: 1px solid #334155;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }

        .back-to-main {
            padding: 15px 20px;
            border-bottom: 1px solid #334155;
        }

        .btn-back {
            color: #94a3b8;
            text-decoration: none;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: 0.2s;
        }

            .btn-back:hover {
                color: #38bdf8;
            }

        .sidebar-header {
            padding: 20px;
            font-weight: bold;
            border-bottom: 1px solid #334155;
            color: #38bdf8;
        }

        .modules-list {
            overflow-y: auto;
            flex-grow: 1;
        }

        .module-item {
            padding: 10px 0;
        }

        .module-title {
            padding: 8px 20px;
            font-size: 0.85rem;
            text-transform: uppercase;
            color: #94a3b8;
        }

        .lesson-link {
            display: block;
            padding: 10px 20px;
            color: #cbd5e1;
            text-decoration: none;
            transition: 0.2s;
            font-size: 0.95rem;
        }

            .lesson-link:hover:not(.locked) {
                background: #334155;
            }

            .lesson-link.active {
                background: #0ea5e9;
                color: white;
            }

            .lesson-link.locked {
                opacity: 0.5;
                cursor: not-allowed;
                color: #64748b;
            }

        .learn-main {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow-y: auto;
            background-color: #0f172a;
        }

        .steps-top-nav {
            position: sticky;
            top: 0;
            z-index: 10;
            display: flex;
            justify-content: center;
            gap: 12px;
            padding: 15px;
            background: #1e293b;
            border-bottom: 1px solid #334155;
        }

        .step-dot {
            width: 14px;
            height: 14px;
            border-radius: 4px;
            background: #475569;
            transition: 0.3s;
            border: 2px solid transparent;
            text-decoration: none;
        }

            .step-dot.active {
                border-color: #38bdf8;
                background: #38bdf8;
                transform: scale(1.2);
            }

            .step-dot.completed {
                background: #10b981;
            }

        .step-content-area {
            max-width: 850px;
            margin: 40px auto 0 auto;
            padding: 0 20px;
            width: 100%;
        }

        .step-body {
            background: #1e293b;
            padding: 30px;
            border-radius: 12px;
            border: 1px solid #334155;
            line-height: 1.6;
        }

        .quiz-option {
            display: flex;
            align-items: center;
            background: #0f172a;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            cursor: pointer;
            border: 1px solid #334155;
            transition: 0.2s;
            user-select: none;
        }

            .quiz-option:hover:not(.disabled) {
                border-color: #475569;
            }

            .quiz-option input {
                margin-right: 12px;
                width: 18px;
                height: 18px;
                cursor: pointer;
            }

            .quiz-option.active-selection {
                border-color: #38bdf8;
                background: rgba(56, 189, 248, 0.1);
            }

            .quiz-option.correct {
                border-color: #10b981 !important;
                background: rgba(16, 185, 129, 0.1);
            }

            .quiz-option.wrong {
                border-color: #ef4444 !important;
                background: rgba(239, 68, 68, 0.1);
            }

            .quiz-option.disabled {
                cursor: default;
                pointer-events: none;
                opacity: 0.9;
            }

        .video-wrapper {
            position: relative;
            padding-bottom: 56.25%;
            height: 0;
            margin-bottom: 25px;
            overflow: hidden;
            border-radius: 12px;
            background: #000;
        }

            .video-wrapper iframe {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
            }

        .step-footer {
            margin-top: 30px;
            display: flex;
            justify-content: flex-end;
            min-height: 50px;
            align-items: center;
        }

        .btn-next {
            background: #0ea5e9;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

            .btn-next:hover:not(:disabled) {
                background: #0284c7;
            }

            .btn-next:disabled {
                opacity: 0.6;
                cursor: not-allowed;
            }

        .finish-message {
            color: #10b981;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(16, 185, 129, 0.1);
            padding: 15px 25px;
            border-radius: 8px;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .comments-section {
            max-width: 850px;
            margin: 50px auto 0 auto;
            width: 100%;
            padding: 0 20px 60px 20px;
        }

        .comment-card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
        }

        .comment-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid #475569;
            background: #334155;
        }

        .author-badge {
            background: #0ea5e9;
            color: white;
            font-size: 0.65rem;
            padding: 2px 6px;
            border-radius: 4px;
            text-transform: uppercase;
            font-weight: 800;
        }

        .comment-input {
            width: 100%;
            background: #0f172a;
            border: 1px solid #334155;
            color: white;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            resize: none;
            outline: none;
        }

            .comment-input:focus {
                border-color: #38bdf8;
            }
    </style>
</head>
<body>

    <div class="learn-container">
        <aside class="learn-sidebar">
            <div class="back-to-main">
                <a href="/" class="btn-back"><span>←</span> На главную</a>
            </div>
            <div class="sidebar-header">Содержание курса</div>
            <div class="modules-list">
                @foreach (var module in Model.AllModules.OrderBy(m => m.Order))
                {
                    <div class="module-item">
                        <div class="module-title">@module.Title</div>
                        @foreach (var lesson in module.Lessons.OrderBy(l => l.Order))
                        {
                            var firstStep = lesson.Steps.OrderBy(s => s.Order).FirstOrDefault();
                            var firstStepId = firstStep?.Id ?? 0;

                            // Урок доступен, если он текущий или если первый шаг урока пройден
                            var isCurrentLesson = lesson.Id == Model.CurrentStep.LessonId;
                            var isLessonStarted = Model.CompletedStepIds.Contains(firstStepId);
                            var isLocked = !isCurrentLesson && !isLessonStarted;

                            <a href="@(isLocked ? "javascript:void(0)" : $"?courseId={Model.CourseId}&stepId={firstStepId}")"
                               class="lesson-link @(isCurrentLesson ? "active" : "") @(isLocked ? "locked" : "")">
                                @lesson.Title @(isLocked ? "🔒" : "")
                            </a>
                        }
                    </div>
                }
            </div>
        </aside>

        <main class="learn-main">
            <nav class="steps-top-nav">
                @foreach (var step in Model.CurrentStep.Lesson.Steps.OrderBy(s => s.Order))
                {
                    var isDone = Model.CompletedStepIds.Contains(step.Id);
                    var isCurrent = step.Id == Model.CurrentStep.Id;
                    <a href="?courseId=@Model.CourseId&stepId=@step.Id"
                       class="step-dot @(isCurrent ? "active" : "") @(isDone ? "completed" : "")"
                       title="@step.Title"></a>
                }
            </nav>

            <div class="step-content-area">
                <div class="step-body">
                    <h2 style="margin-bottom: 15px;">@Model.CurrentStep.Title</h2>
                    <div style="height: 1px; background: #334155; margin-bottom: 25px;"></div>

                    <div class="content-render">
                        @if (!string.IsNullOrEmpty(Model.CurrentStep.VideoUrl))
                        {
                            <div class="video-wrapper">
                                @{
                                    var videoId = "";
                                    var url = Model.CurrentStep.VideoUrl;
                                    if (url.Contains("v=")) { videoId = url.Split("v=")[1].Split("&")[0]; }
                                    else if (url.Contains("youtu.be/")) { videoId = url.Split("be/")[1].Split("?")[0]; }
                                    var embedUrl = !string.IsNullOrEmpty(videoId) ? "https://www.youtube.com/embed/" + videoId : "";
                                }
                                @if (!string.IsNullOrEmpty(embedUrl))
                                {
                                    <iframe src="@embedUrl" frameborder="0" allowfullscreen></iframe>
                                }
                            </div>
                        }

                        <div class="text-content" style="margin-bottom: 20px;">
                            @Html.Raw(Model.CurrentStep.TextContent)
                        </div>

                        @if (Model.CurrentStep.Type == WebApplication2.Models.StepType.Quiz)
                        {
                            <p style="margin-bottom: 15px; font-weight: 500; color: #94a3b8;">
                                @(isStepCompleted ? "Тест пройден. Правильные ответы:" : (Model.CurrentStep.IsMultipleChoice ? "Выберите все верные ответы:" : "Выберите один правильный ответ:"))
                            </p>
                            <div id="quiz-container">
                                @foreach (var opt in Model.CurrentStep.QuizOptions)
                                {
                                    var isCorrectAndDone = isStepCompleted && opt.IsCorrect;
                                    <label class="quiz-option @(isCorrectAndDone ? "correct" : "") @(isStepCompleted ? "disabled" : "")" data-option-id="@opt.Id">
                                        <input type="@(Model.CurrentStep.IsMultipleChoice ? "checkbox" : "radio")"
                                               name="quiz"
                                               value="@opt.Id"
                                        @(isStepCompleted ? "disabled" : "")
                                        @(isCorrectAndDone ? "checked" : "")>
                                        <span>@opt.Text</span>
                                    </label>
                                }
                            </div>
                        }
                    </div>

                    <div class="step-footer">
                        @if (Model.IsLastStep && isStepCompleted)
                        {
                            <div class="finish-message">
                                <span>🎉</span> Курс завершен! &nbsp; <a href="/Course/Details/@Model.CourseId" style="color:#38bdf8; text-decoration:none;">К описанию курса</a>
                            </div>
                        }
                        else
                        {
                            <button id="action-btn" class="btn-next"
                                    onclick="@(Model.CurrentStep.Type == WebApplication2.Models.StepType.Quiz && !isStepCompleted ? $"handleQuizSubmit({Model.CurrentStep.Id})" : $"nextStep({Model.CurrentStep.Id})")">
                                @if (isStepCompleted)
                                {
                                    <span>Продолжить</span>
                                }
                                else if (Model.IsLastStep)
                                {
                                    <span>Завершить обучение</span>
                                }
                                else if (Model.CurrentStep.Type == WebApplication2.Models.StepType.Quiz)
                                {
                                    <span>Проверить ответ</span>
                                }
                                else
                                {
                                    <span>Продолжить</span>
                                }
                            </button>
                        }
                    </div>
                </div>
            </div>

            <section class="comments-section">
                <h3 style="margin-bottom: 20px;">Обсуждения</h3>
                <textarea id="commentText" class="comment-input" rows="3" placeholder="Напишите ваш комментарий..."></textarea>
                <div style="display: flex; justify-content: flex-end;">
                    <button id="send-comment-btn" class="btn-next" style="padding: 8px 20px; font-size: 0.9rem;" onclick="sendComment()">Отправить</button>
                </div>
                <div id="commentsList" style="margin-top: 30px;">
                    @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                    {
                        <div class="comment-card">
                            <div style="display: flex; gap: 12px; align-items: flex-start;">
                                <img src="@(string.IsNullOrEmpty(comment.User?.Avatar) ? Url.Content("~/images/default_avatar.jpg") : comment.User.Avatar)"
                                     class="comment-avatar"
                                     onerror="this.src='@Url.Content("~/images/default_avatar.jpg")';" />

                                <div style="flex-grow: 1;">
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            <span style="color: #38bdf8; font-weight: bold; font-size: 0.95rem;">@@@comment.UserLogin</span>
                                            @if (comment.UserLogin == Model.CurrentStep.Lesson.Module.Course.AuthorLogin)
                                            {
                                                <span class="author-badge">Автор</span>
                                            }
                                        </div>
                                        <span style="color: #64748b; font-size: 0.8rem;">@comment.CreatedAt.ToString("g")</span>
                                    </div>
                                    <div style="color: #cbd5e1; font-size: 0.95rem; line-height: 1.5;">@comment.Text</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        </main>
    </div>

    <script>
        const antiForgeryToken = '@tokens.RequestToken';

        // Подсветка выбранных вариантов в тесте
        document.addEventListener('change', function (e) {
            if (e.target.name === 'quiz' && !e.target.disabled) {
                const container = e.target.closest('#quiz-container');
                const label = e.target.closest('.quiz-option');

                if (e.target.type === 'radio') {
                    container.querySelectorAll('.quiz-option').forEach(el => el.classList.remove('active-selection'));
                }

                if (e.target.checked) label.classList.add('active-selection');
                else label.classList.remove('active-selection');
            }
        });

        function handleQuizSubmit(stepId) {
            const selectedInputs = document.querySelectorAll('input[name="quiz"]:checked');
            if (selectedInputs.length === 0) {
                alert("Пожалуйста, выберите ответ.");
                return;
            }
            const ids = Array.from(selectedInputs).map(i => parseInt(i.value));
            saveProgress(stepId, ids);
        }

        function nextStep(stepId) {
            // Если шаг уже пройден, просто идем дальше по точкам навигации
            if (@isStepCompleted.ToString().ToLower()) {
                const nextDot = document.querySelector('.step-dot.active + .step-dot');
                if (nextDot) {
                    window.location.href = nextDot.href;
                    return;
                }
            }
            saveProgress(stepId, []);
        }

        function saveProgress(stepId, selectedOptionIds) {
            const btn = document.getElementById('action-btn');
            btn.disabled = true;
            btn.innerText = "Загрузка...";

            const formData = new URLSearchParams();
            formData.append('stepId', stepId);
            selectedOptionIds.forEach(id => formData.append('selectedOptionIds', id));

            fetch('/Course/CompleteStep', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': antiForgeryToken
                },
                body: formData
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        if (data.nextStepId) {
                            window.location.href = `?courseId=@Model.CourseId&stepId=${data.nextStepId}`;
                        } else {
                            location.reload(); // Перезагрузка для показа сообщения о финише
                        }
                    } else {
                        alert(data.message || "Ошибка. Возможно, вы выбрали неверные ответы.");
                        btn.disabled = false;
                        btn.innerText = "Проверить еще раз";
                    }
                })
                .catch(err => {
                    console.error(err);
                    btn.disabled = false;
                });
        }

        function sendComment() {
            const textEl = document.getElementById('commentText');
            const btn = document.getElementById('send-comment-btn');
            const text = textEl.value.trim();

            if (!text) return;

            btn.disabled = true;
            const formData = new URLSearchParams();
            formData.append('stepId', '@Model.CurrentStep.Id');
            formData.append('text', text);

            fetch('/Course/AddComment', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': antiForgeryToken
                },
                body: formData
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) location.reload();
                    else {
                        alert("Ошибка при отправке");
                        btn.disabled = false;
                    }
                });
        }
    </script>
</body>
</html>