@model WebApplication2.Models.CourseLearnViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    Layout = null;
    var tokens = Antiforgery.GetAndStoreTokens(Context);

    // Состояние текущего шага
    var isStepCompleted = Model.CompletedStepIds.Contains(Model.CurrentStep.Id);
    var isQuiz = Model.CurrentStep.Type == WebApplication2.Models.StepType.Quiz;

    // Тест может быть:
    // - ручная проверка (IsManualCheck=true) -> текстовый ответ
    // - автопроверка по тексту (CorrectTextAnswer заполнен) -> текстовый ответ
    // - автопроверка по вариантам -> radio/checkbox
    var isTextInputQuiz = isQuiz && (Model.CurrentStep.IsManualCheck || !string.IsNullOrWhiteSpace(Model.CurrentStep.CorrectTextAnswer));
    var isManualCheckQuiz = isQuiz && Model.CurrentStep.IsManualCheck;

    var hasPendingManual = isManualCheckQuiz && Model.HasPendingManualSubmission;
    var submission = Model.LatestSubmission;

    var courseEarnedPoints = Model.EarnedPointsInCourse;
    var courseMaxPoints = Model.MaxPointsInCourse;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.CurrentStep.Title | Обучение</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #0f172a;
            --bg-sidebar: #1e293b;
            --accent-blue: #38bdf8;
            --accent-green: #10b981;
            --accent-red: #ef4444;
            --text-main: #e2e8f0;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
            overflow: hidden;
        }


        /* --- Sidebar --- */
        .learn-sidebar {
            width: 320px;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }

        .back-area {
            padding: 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .btn-back {
            color: var(--text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.9rem;
            transition: var(--transition);
        }

            .btn-back:hover {
                color: var(--accent-blue);
            }

        .modules-container {
            overflow-y: auto;
            flex-grow: 1;
            padding: 20px 0;
        }

        .module-group {
            margin-bottom: 25px;
        }

        .module-label {
            padding: 0 20px 10px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            color: #64748b;
            letter-spacing: 0.05em;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
        }

        .module-title {
            flex: 1;
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .status-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            padding: 4px 10px;
            font-size: 0.65rem;
            font-weight: 800;
            letter-spacing: 0.04em;
            border: 1px solid transparent;
            white-space: nowrap;
        }

        .status-chip.done {
            color: #d1fae5;
            background: rgba(16, 185, 129, 0.18);
            border-color: rgba(16, 185, 129, 0.35);
        }

        .status-chip.todo {
            color: #cbd5e1;
            background: rgba(148, 163, 184, 0.12);
            border-color: rgba(148, 163, 184, 0.35);
        }

        .lesson-item {
            display: block;
            padding: 12px 20px;
            color: #cbd5e1;
            text-decoration: none;
            font-size: 0.95rem;
            border-left: 3px solid transparent;
            transition: var(--transition);
            position: relative;
        }

            .lesson-item:hover {
                background: rgba(255,255,255,0.05);
            }

            .lesson-item.active {
                background: rgba(56, 189, 248, 0.1);
                color: var(--accent-blue);
                border-left-color: var(--accent-blue);
                font-weight: 600;
            }

            .lesson-item.done {
                border-left-color: var(--accent-green);
                background: rgba(16, 185, 129, 0.08);
                color: #d1fae5;
            }

            .lesson-item.todo {
                border-left-color: #64748b;
            }

        .lesson-status {
            margin-left: 8px;
            font-size: 0.75rem;
            font-weight: 700;
            opacity: 0.95;
        }

        /* --- Main Content --- */
        .learn-content {
            flex-grow: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .top-nav {
            position: sticky;
            top: 0;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(10px);
            padding: 20px;
            display: flex;
            justify-content: center;
            gap: 12px;
            border-bottom: 1px solid var(--border-color);
            z-index: 10;
        }

        .step-dot {
            width: 12px;
            height: 12px;
            border-radius: 3px;
            background: #475569;
            transition: var(--transition);
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
        }

            .step-dot.active {
                background: var(--accent-blue);
                transform: scale(1.3);
            }

            .step-dot.completed {
                background: var(--accent-green);
            }

            .step-dot.pending {
                background: #64748b;
            }

        .main-scroll-area {
            max-width: 900px;
            width: 100%;
            margin: 0 auto;
            padding: 60px 30px;
        }

        .content-card {
            background: var(--bg-sidebar);
            border-radius: 24px;
            padding: 45px;
            border: 1px solid var(--border-color);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }


        /* Video Area */
        .video-container {
            position: relative;
            padding-bottom: 56.25%;
            height: 0;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 35px;
            background: #000;
        }

            .video-container iframe {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
            }

        .step-title {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 25px;
            color: #f8fafc;
        }

        .html-text {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #cbd5e1;
            margin-bottom: 40px;
        }


        /* Quiz Styles */
        .quiz-wrapper {
            margin-top: 40px;
            padding-top: 40px;
            border-top: 1px solid var(--border-color);
        }

        .quiz-option {
            display: flex;
            align-items: center;
            padding: 18px 24px;
            background: var(--bg-dark);
            border: 2px solid var(--border-color);
            border-radius: 14px;
            margin-bottom: 12px;
            cursor: pointer;
            transition: var(--transition);
        }

            .quiz-option:hover:not(.disabled) {
                border-color: #475569;
                transform: translateX(4px);
            }

            .quiz-option.selected {
                border-color: var(--accent-blue);
                background: rgba(56, 189, 248, 0.05);
            }

            .quiz-option.correct {
                border-color: var(--accent-green);
                background: rgba(16, 185, 129, 0.1);
            }

            .quiz-option.wrong {
                border-color: var(--accent-red);
                background: rgba(239, 68, 68, 0.1);
            }

            .quiz-option input {
                margin-right: 15px;
                width: 18px;
                height: 18px;
                accent-color: var(--accent-blue);
            }

        /* Comments */
        .comments-wrap {
            margin-top: 40px;
            padding-top: 40px;
            border-top: 1px solid var(--border-color);
        }

        .comment-form {
            display: flex;
            gap: 12px;
            align-items: flex-start;
            margin-bottom: 20px;
        }

        .comment-input {
            flex: 1;
            min-height: 54px;
            background: var(--bg-dark);
            border: 2px solid var(--border-color);
            border-radius: 14px;
            color: #fff;
            padding: 14px 16px;
            font-family: inherit;
            font-size: 0.95rem;
            outline: none;
            resize: vertical;
        }

        .comment-input:focus {
            border-color: var(--accent-blue);
        }

        .comment-item {
            display: flex;
            gap: 14px;
            padding: 16px 18px;
            border-radius: 18px;
            border: 1px solid rgba(255,255,255,0.06);
            background: rgba(255,255,255,0.02);
            margin-bottom: 12px;
        }

        .comment-avatar {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            object-fit: cover;
            border: 1px solid rgba(56, 189, 248, 0.25);
            background: var(--bg-dark);
            flex-shrink: 0;
        }

        .comment-head {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
            margin-bottom: 6px;
        }

        .comment-user {
            font-weight: 800;
            color: var(--accent-blue);
        }

        .comment-date {
            color: var(--text-muted);
            font-size: 0.85rem;
        }

        .author-badge {
            font-size: 0.7rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #d1fae5;
            border: 1px solid rgba(16, 185, 129, 0.35);
            background: rgba(16, 185, 129, 0.12);
            padding: 4px 10px;
            border-radius: 999px;
        }

        .comment-text {
            color: #cbd5e1;
            line-height: 1.6;
            white-space: pre-wrap;
        }

        .comment-reply-preview {
            margin-bottom: 10px;
            padding: 8px 10px;
            border-left: 3px solid var(--accent-blue);
            background: rgba(56, 189, 248, 0.08);
            border-radius: 8px;
            color: var(--text-muted);
            font-size: 0.85rem;
            line-height: 1.4;
        }

        .comment-reply-author {
            color: var(--accent-blue);
            font-weight: 800;
            margin-right: 6px;
        }


        /* Manual Input Area */
        .manual-textarea {
            width: 100%;
            min-height: 200px;
            background: var(--bg-dark);
            border: 2px solid var(--border-color);
            border-radius: 16px;
            color: #fff;
            padding: 20px;
            font-family: inherit;
            font-size: 1rem;
            resize: vertical;
            outline: none;
            transition: border-color 0.3s;
        }

            .manual-textarea:focus {
                border-color: var(--accent-blue);
            }

            .manual-textarea:disabled {
                opacity: 0.7;
                cursor: not-allowed;
            }

        .action-footer {
            margin-top: 40px;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 20px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
            color: white;
            border: none;
            padding: 14px 32px;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-primary:hover:not(:disabled) {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(2, 132, 199, 0.3);
            }

            .btn-primary:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }

        #feedback-msg {
            margin-top: 15px;
            padding: 12px;
            border-radius: 8px;
            display: none;
            font-weight: 500;
        }

            #feedback-msg.error {
                background: rgba(239, 68, 68, 0.1);
                color: var(--accent-red);
            }

        .review-state {
            margin-top: 16px;
            padding: 14px 16px;
            border-radius: 14px;
            border: 1px solid rgba(56, 189, 248, 0.25);
            background: rgba(56, 189, 248, 0.08);
            color: #dbeafe;
            line-height: 1.5;
        }

        .review-result {
            margin-top: 16px;
            padding: 16px 18px;
            border-radius: 16px;
            border: 1px solid rgba(16, 185, 129, 0.25);
            background: rgba(16, 185, 129, 0.08);
        }

        .review-result .score {
            font-weight: 900;
            color: #d1fae5;
            margin-bottom: 6px;
        }

        .review-result .comment {
            color: #cbd5e1;
            white-space: pre-wrap;
            margin-top: 10px;
        }

        .bookmark-toolbar {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .btn-bookmark {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            border-radius: 10px;
            border: 1px solid rgba(251, 191, 36, 0.45);
            background: rgba(251, 191, 36, 0.12);
            color: #fcd34d;
            font-size: 0.88rem;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: background 0.2s, border-color 0.2s;
        }

        .btn-bookmark:hover {
            background: rgba(251, 191, 36, 0.22);
        }

        .btn-bookmark.is-active {
            background: rgba(251, 191, 36, 0.28);
            border-color: #fbbf24;
            color: #fef3c7;
        }

        .bookmark-link-page {
            font-size: 0.85rem;
            color: var(--accent-blue);
            text-decoration: none;
            font-weight: 600;
        }

        .bookmark-link-page:hover {
            text-decoration: underline;
        }

    </style>
</head>
<body>

    <aside class="learn-sidebar">
        <div class="back-area">
            <a href="/Course/Details/@Model.CourseId" class="btn-back">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
                Вернуться к курсу
            </a>
            <div style="margin-top: 14px; color: var(--text-muted); font-size: 0.9rem;">
                <span style="display:inline-flex; align-items:center; gap:8px;">
                    <span style="width:10px; height:10px; border-radius: 3px; background: var(--accent-blue); display:inline-block;"></span>
                    Баллы: <strong style="color: var(--text-main);">@courseEarnedPoints</strong> / <strong style="color: var(--text-main);">@courseMaxPoints</strong>
                </span>
            </div>
            <div style="margin-top: 10px; color: var(--text-muted); font-size: 0.8rem; display:flex; gap:14px; flex-wrap:wrap;">
                <span style="display:inline-flex; align-items:center; gap:6px;">
                    <span style="width:9px; height:9px; border-radius: 3px; background: var(--accent-green); display:inline-block;"></span> Пройдено
                </span>
                <span style="display:inline-flex; align-items:center; gap:6px;">
                    <span style="width:9px; height:9px; border-radius: 3px; background: #64748b; display:inline-block;"></span> Не пройдено
                </span>
            </div>
        </div>
        <div class="modules-container">
            @foreach (var module in Model.AllModules.OrderBy(m => m.Order))
            {
                var moduleSteps = module.Lessons?.SelectMany(l => l.Steps ?? new List<WebApplication2.Models.StepModel>()).ToList()
                                  ?? new List<WebApplication2.Models.StepModel>();
                var moduleCompleted = moduleSteps.Any() && moduleSteps.All(s => Model.CompletedStepIds.Contains(s.Id));
                <div class="module-group">
                    <div class="module-label">
                        <span class="module-title">@module.Title</span>
                        <span class="status-chip @(moduleCompleted ? "done" : "todo")">
                            <span>@(moduleCompleted ? "✓" : "•")</span>
                            <span>@(moduleCompleted ? "Пройден" : "Не пройден")</span>
                        </span>
                    </div>
                    @foreach (var lesson in module.Lessons.OrderBy(l => l.Order))
                    {
                        var firstStepId = lesson.Steps.OrderBy(s => s.Order).FirstOrDefault()?.Id ?? 0;
                        var lessonSteps = lesson.Steps?.ToList() ?? new List<WebApplication2.Models.StepModel>();
                        var lessonCompleted = lessonSteps.Any() && lessonSteps.All(s => Model.CompletedStepIds.Contains(s.Id));
                        <a href="?courseId=@Model.CourseId&stepId=@firstStepId"  
                           class="lesson-item @(lesson.Id == Model.CurrentStep.LessonId ? "active" : "") @(lessonCompleted ? "done" : "todo")">
                            @lesson.Title
                            <span class="lesson-status">@(lessonCompleted ? "✓" : "○")</span>
                        </a>
                    }
                </div>
            }
        </div>
    </aside>

    <main class="learn-content">
        <nav class="top-nav">
            @foreach (var step in Model.CurrentStep.Lesson.Steps.OrderBy(s => s.Order))
            {
                <a href="?courseId=@Model.CourseId&stepId=@step.Id"  
                   class="step-dot @(step.Id == Model.CurrentStep.Id ? "active" : "") @(Model.CompletedStepIds.Contains(step.Id) ? "completed" : "pending")"
                   title="@step.Title"></a>
            }
        </nav>

        <div class="main-scroll-area">
            <div class="content-card">
                <div class="bookmark-toolbar">
                    <button type="button"
                            id="bookmarkToggleBtn"
                            class="btn-bookmark @(Model.IsCurrentStepBookmarked ? "is-active" : "")"
                            data-course-id="@Model.CourseId"
                            data-step-id="@Model.CurrentStep.Id"
                            data-is-bookmarked="@(Model.IsCurrentStepBookmarked ? "true" : "false")">
                        <span id="bookmarkToggleIcon">@(Model.IsCurrentStepBookmarked ? "★" : "☆")</span>
                        <span id="bookmarkToggleLabel">@(Model.IsCurrentStepBookmarked ? "В закладках" : "Добавить в закладки")</span>
                    </button>
                    <a class="bookmark-link-page" href="@Url.Action("Index", "Bookmarks")">Все закладки</a>
                </div>
                <h1 class="step-title">@Model.CurrentStep.Title</h1>

                @if (!string.IsNullOrEmpty(Model.CurrentStep.VideoUrl))
                {
                    <div class="video-container">
                        @{
                            var vidId = "";
                            var url = Model.CurrentStep.VideoUrl;
                            if (url.Contains("v=")) vidId = url.Split("v=")[1].Split("&")[0];
                            else if (url.Contains("youtu.be/")) vidId = url.Split("be/")[1].Split("?")[0];
                        }
                        <iframe src="https://www.youtube.com/embed/@vidId" frameborder="0" allowfullscreen></iframe>
                    </div>
                }

                <div class="html-text">@Html.Raw(Model.CurrentStep.TextContent)</div>

                @if (isQuiz)
                {
                    <div class="quiz-wrapper">
                        <h3 style="margin-bottom: 20px; color: var(--accent-blue);">Практическое задание</h3>

                        @if (isTextInputQuiz)
                        {
                            <div class="manual-block">
                                @if (isManualCheckQuiz)
                                {
                                    <p style="margin-bottom: 15px;">Введите ваш ответ ниже. Преподаватель проверит его в ближайшее время.</p>
                                }
                                else
                                {
                                    <p style="margin-bottom: 15px;">Введите ваш ответ ниже. Система проверит его автоматически.</p>
                                }
                                <textarea id="manualAnswer" class="manual-textarea"  
                                          placeholder="Напишите здесь ваше решение или ответ..."  
                                @(isStepCompleted || hasPendingManual ? "disabled" : "")></textarea>

                                @if (hasPendingManual)
                                {
                                    <div class="review-state">
                                        Ваш ответ отправлен и <strong>ожидает проверки преподавателем</strong>.
                                        Пока проверка не завершена, перейти дальше нельзя.
                                    </div>
                                }
                                else if (isManualCheckQuiz && submission != null && !submission.IsPending)
                                {
                                    <div class="review-result">
                                        <div class="score">Результат проверки: @submission.EarnedPoints / @submission.MaxPoints</div>
                                        <div style="color: var(--text-muted); font-size: 0.9rem;">Проверено: @submission.SubmittedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                                        @if (!string.IsNullOrWhiteSpace(submission.TeacherComment))
                                        {
                                            <div class="comment">@submission.TeacherComment</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p style="margin-bottom: 20px;">@(Model.CurrentStep.IsMultipleChoice ? "Выберите все правильные варианты:" : "Выберите один правильный вариант:")</p>
                            <div id="options-list">
                                @foreach (var opt in Model.CurrentStep.QuizOptions ?? new List<WebApplication2.Models.QuizOptionModel>())
                                {
                                    <label class="quiz-option @(isStepCompleted && opt.IsCorrect ? "correct" : "") @(isStepCompleted ? "disabled" : "")">
                                        <input type="@(Model.CurrentStep.IsMultipleChoice ? "checkbox" : "radio")"  
                                               name="quiz-opt" value="@opt.Id"  
                                        @(isStepCompleted ? "disabled" : "") 
                                        @(isStepCompleted && opt.IsCorrect ? "checked" : "")>
                                        <span>@opt.Text</span>
                                    </label>
                                }
                            </div>
                        }
                        <div id="feedback-msg"></div>
                    </div>
                }

                <div class="action-footer">
                    @if (Model.IsLastStep && isStepCompleted)
                    {
                        <div style="font-weight: 700; color: var(--accent-green);">🎉 Молодцы! Курс завершен.</div>
                    }
                    else
                    {
                        <button id="main-btn" class="btn-primary" onclick="processStep()" @(hasPendingManual ? "disabled" : "")>
                            @if (isStepCompleted)
                            {
                                <span>Следующий шаг</span>
                            }
                            else if (hasPendingManual)
                            {
                                <span>Ожидает проверки</span>
                            }
                            else if (isQuiz)
                            {
                                <span>Проверить</span>
                            }
                            else
                            {
                                <span>Завершить шаг</span>
                            }
                        </button>
                    }
                </div>

                <div class="comments-wrap">
                    <h3 style="margin-bottom: 16px; color: var(--accent-blue);">Комментарии</h3>

                    <div class="comment-form">
                        <input type="hidden" id="parentCommentId" value="">
                        <div id="replyBanner" style="display:none; margin-bottom: 10px; color: var(--text-muted); font-size: 0.9rem;">
                            Ответ на <strong id="replyToName" style="color: var(--accent-blue);"></strong>
                            <a href="javascript:void(0)" onclick="clearReply()" style="margin-left:10px; color: var(--accent-blue); text-decoration:none;">Отменить</a>
                        </div>
                        <textarea id="commentText" class="comment-input" placeholder="Напишите комментарий..."></textarea>
                        <button class="btn-primary" style="height:54px;" onclick="submitComment()">Отправить</button>
                    </div>

                    <div id="comments-list">
                        @if (Model.Comments != null && Model.Comments.Any())
                        {
                            var comments = Model.Comments.OrderByDescending(x => x.CreatedAt).ToList();
                            var commentsById = Model.Comments.ToDictionary(x => x.Id, x => x);

                            @foreach (var c in comments)
                            {
                                <div class="comment-item">
                                    <img class="comment-avatar" src="@(string.IsNullOrEmpty(c.User?.Avatar) ? Url.Content("~/images/default_avatar.jpg") : c.User.Avatar)" alt="">
                                    <div style="flex:1;">
                                        @if (c.ParentCommentId.HasValue && commentsById.TryGetValue(c.ParentCommentId.Value, out var parentComment))
                                        {
                                            var parentAuthor = string.IsNullOrEmpty(parentComment.User?.Username) ? parentComment.UserLogin : parentComment.User.Username;
                                            var sourceText = (parentComment.Text ?? "").Trim();
                                            var snippet = sourceText.Length > 70 ? sourceText.Substring(0, 70) + "..." : sourceText;
                                            <div class="comment-reply-preview">
                                                <span class="comment-reply-author">@parentAuthor</span>
                                                <span>@snippet</span>
                                            </div>
                                        }
                                        <div class="comment-head">
                                            <span class="comment-user">@(!string.IsNullOrEmpty(c.User?.Username) ? c.User.Username : c.UserLogin)</span>
                                            @if (c.UserLogin == Model.AuthorLogin)
                                            {
                                                <span class="author-badge">Автор</span>
                                            }
                                            <span class="comment-date">@c.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                            <a href="javascript:void(0)"
                                               onclick="setReply(@c.Id, '@(string.IsNullOrEmpty(c.User?.Username) ? c.UserLogin : c.User.Username)')"
                                               style="margin-left:auto; color: var(--accent-blue); text-decoration:none; font-weight:700; font-size:0.85rem;">
                                                Ответить
                                            </a>
                                        </div>
                                        <div class="comment-text">@c.Text</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div style="color: var(--text-muted);">Пока нет комментариев. Будьте первым.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        const STEP_DATA = {
            id: @Model.CurrentStep.Id,
            courseId: @Model.CourseId,
            isQuiz: @isQuiz.ToString().ToLower(),
            isTextInputQuiz: @isTextInputQuiz.ToString().ToLower(),
            hasPendingManual: @hasPendingManual.ToString().ToLower(),
            isCompleted: @isStepCompleted.ToString().ToLower(),
            token: '@tokens.RequestToken'
        };

        // Подсветка выбранных вариантов
        document.addEventListener('change', (e) => {
            if (e.target.name === 'quiz-opt') {
                const parent = e.target.closest('.quiz-option');
                if (e.target.type === 'radio') {
                    document.querySelectorAll('.quiz-option').forEach(el => el.classList.remove('selected'));
                }
                parent.classList.toggle('selected', e.target.checked);
            }
        });

        async function processStep() {
            const btn = document.getElementById('main-btn');

            // 1. Если шаг уже пройден — просто переходим дальше
            if (STEP_DATA.isCompleted) {
                const nextStep = document.querySelector('.step-dot.active + .step-dot');
                if (nextStep) {
                    location.href = nextStep.href;
                } else {
                    location.href = "/Course/Details/" + STEP_DATA.courseId;
                }
                return;
            }

            // 1.5 Если ожидает ручной проверки — дальше нельзя
            if (STEP_DATA.hasPendingManual) {
                return;
            }

            // 2. Сбор данных
            const params = new URLSearchParams();
            params.append('stepId', STEP_DATA.id);

            if (STEP_DATA.isQuiz) {
                if (STEP_DATA.isTextInputQuiz) {
                    const text = document.getElementById('manualAnswer').value.trim();
                    if (!text) return alert("Пожалуйста, введите ответ перед отправкой.");
                    params.append('manualAnswer', text);
                } else {
                    const selected = document.querySelectorAll('input[name="quiz-opt"]:checked');
                    if (selected.length === 0) return alert("Выберите хотя бы один вариант ответа.");
                    selected.forEach(s => params.append('selectedOptionIds', s.value));
                }
            }

            // 3. Отправка
            btn.disabled = true;
            try {
                const response = await fetch('/Course/CompleteStep', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': STEP_DATA.token
                    },
                    body: params
                });

                const result = await response.json();

                if (result.success) {
                    location.reload();
                } else {
                    const fb = document.getElementById('feedback-msg');
                    fb.className = 'error';
                    fb.innerText = result.message || "Неверный ответ. Попробуйте еще раз!";
                    fb.style.display = 'block';
                    btn.disabled = false;
                }
            } catch (err) {
                console.error(err);
                alert("Ошибка при отправке данных.");
                btn.disabled = false;
            }
        }

        async function submitComment() {
            const textArea = document.getElementById('commentText');
            const text = (textArea.value || '').trim();
            if (!text) return alert("Введите текст комментария.");

            const params = new URLSearchParams();
            params.append('stepId', STEP_DATA.id);
            params.append('text', text);
            const parentId = (document.getElementById('parentCommentId').value || '').trim();
            if (parentId) params.append('parentCommentId', parentId);

            try {
                const res = await fetch('/Course/AddComment', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': STEP_DATA.token
                    },
                    body: params
                });

                const result = await res.json();
                if (result && result.success) {
                    location.reload();
                } else {
                    alert("Не удалось отправить комментарий.");
                }
            } catch (e) {
                console.error(e);
                alert("Ошибка при отправке комментария.");
            }
        }

        function setReply(commentId, name) {
            document.getElementById('parentCommentId').value = String(commentId);
            document.getElementById('replyToName').innerText = name || '';
            document.getElementById('replyBanner').style.display = 'block';
            document.getElementById('commentText').focus();
        }

        function clearReply() {
            document.getElementById('parentCommentId').value = '';
            document.getElementById('replyToName').innerText = '';
            document.getElementById('replyBanner').style.display = 'none';
        }

        (function initBookmarkToggle() {
            const btn = document.getElementById("bookmarkToggleBtn");
            if (!btn) return;

            const icon = document.getElementById("bookmarkToggleIcon");
            const label = document.getElementById("bookmarkToggleLabel");
            const setUrl = "@Url.Action("Set", "Bookmarks")";
            const removeUrl = "@Url.Action("Remove", "Bookmarks")";

            function setUi(active) {
                btn.classList.toggle("is-active", active);
                btn.dataset.isBookmarked = active ? "true" : "false";
                if (icon) icon.textContent = active ? "★" : "☆";
                if (label) label.textContent = active ? "В закладках" : "Добавить в закладки";
            }

            btn.addEventListener("click", async function () {
                const isBookmarked = btn.dataset.isBookmarked === "true";
                const params = new URLSearchParams();
                params.append("courseId", btn.dataset.courseId);
                params.append("__RequestVerificationToken", STEP_DATA.token);

                if (!isBookmarked) {
                    params.append("stepId", btn.dataset.stepId);
                }

                const url = isBookmarked ? removeUrl : setUrl;
                try {
                    const res = await fetch(url, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/x-www-form-urlencoded",
                            "RequestVerificationToken": STEP_DATA.token
                        },
                        body: params
                    });
                    const data = await res.json();
                    if (data.success) {
                        setUi(!isBookmarked);
                    } else {
                        alert(data.message || "Не удалось обновить закладку.");
                    }
                } catch (e) {
                    console.error(e);
                    alert("Ошибка при сохранении закладки.");
                }
            });
        })();
    </script>
</body>
</html>