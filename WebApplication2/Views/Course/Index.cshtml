@model WebApplication2.Models.CourseLearnViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    Layout = null;
    var tokens = Antiforgery.GetAndStoreTokens(Context);

    // Состояние текущего шага
    var isStepCompleted = Model.CompletedStepIds.Contains(Model.CurrentStep.Id);
    var isQuiz = Model.CurrentStep.Type == WebApplication2.Models.StepType.Quiz;

    // ПРИНУДИТЕЛЬНОЕ РАЗДЕЛЕНИЕ:
    // Если в БД стоит флаг IsManualCheck, мы ИГНОРИРУЕМ наличие вариантов и показываем текстовое поле.
    var isManualInput = isQuiz && Model.CurrentStep.IsManualCheck;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.CurrentStep.Title | Обучение</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #0f172a;
            --bg-sidebar: #1e293b;
            --accent-blue: #38bdf8;
            --accent-green: #10b981;
            --accent-red: #ef4444;
            --text-main: #e2e8f0;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
            overflow: hidden;
        }


        /* --- Sidebar --- */
        .learn-sidebar {
            width: 320px;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }

        .back-area {
            padding: 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .btn-back {
            color: var(--text-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.9rem;
            transition: var(--transition);
        }

            .btn-back:hover {
                color: var(--accent-blue);
            }

        .modules-container {
            overflow-y: auto;
            flex-grow: 1;
            padding: 20px 0;
        }

        .module-group {
            margin-bottom: 25px;
        }

        .module-label {
            padding: 0 20px 10px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            color: #64748b;
            letter-spacing: 0.05em;
        }

        .lesson-item {
            display: block;
            padding: 12px 20px;
            color: #cbd5e1;
            text-decoration: none;
            font-size: 0.95rem;
            border-left: 3px solid transparent;
            transition: var(--transition);
        }

            .lesson-item:hover {
                background: rgba(255,255,255,0.05);
            }

            .lesson-item.active {
                background: rgba(56, 189, 248, 0.1);
                color: var(--accent-blue);
                border-left-color: var(--accent-blue);
                font-weight: 600;
            }


        /* --- Main Content --- */
        .learn-content {
            flex-grow: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .top-nav {
            position: sticky;
            top: 0;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(10px);
            padding: 20px;
            display: flex;
            justify-content: center;
            gap: 12px;
            border-bottom: 1px solid var(--border-color);
            z-index: 10;
        }

        .step-dot {
            width: 12px;
            height: 12px;
            border-radius: 3px;
            background: #475569;
            transition: var(--transition);
        }

            .step-dot.active {
                background: var(--accent-blue);
                transform: scale(1.3);
            }

            .step-dot.completed {
                background: var(--accent-green);
            }

        .main-scroll-area {
            max-width: 900px;
            width: 100%;
            margin: 0 auto;
            padding: 60px 30px;
        }

        .content-card {
            background: var(--bg-sidebar);
            border-radius: 24px;
            padding: 45px;
            border: 1px solid var(--border-color);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }


        /* Video Area */
        .video-container {
            position: relative;
            padding-bottom: 56.25%;
            height: 0;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 35px;
            background: #000;
        }

            .video-container iframe {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
            }

        .step-title {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 25px;
            color: #f8fafc;
        }

        .html-text {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #cbd5e1;
            margin-bottom: 40px;
        }


        /* Quiz Styles */
        .quiz-wrapper {
            margin-top: 40px;
            padding-top: 40px;
            border-top: 1px solid var(--border-color);
        }

        .quiz-option {
            display: flex;
            align-items: center;
            padding: 18px 24px;
            background: var(--bg-dark);
            border: 2px solid var(--border-color);
            border-radius: 14px;
            margin-bottom: 12px;
            cursor: pointer;
            transition: var(--transition);
        }

            .quiz-option:hover:not(.disabled) {
                border-color: #475569;
                transform: translateX(4px);
            }

            .quiz-option.selected {
                border-color: var(--accent-blue);
                background: rgba(56, 189, 248, 0.05);
            }

            .quiz-option.correct {
                border-color: var(--accent-green);
                background: rgba(16, 185, 129, 0.1);
            }

            .quiz-option.wrong {
                border-color: var(--accent-red);
                background: rgba(239, 68, 68, 0.1);
            }

            .quiz-option input {
                margin-right: 15px;
                width: 18px;
                height: 18px;
                accent-color: var(--accent-blue);
            }


        /* Manual Input Area */
        .manual-textarea {
            width: 100%;
            min-height: 200px;
            background: var(--bg-dark);
            border: 2px solid var(--border-color);
            border-radius: 16px;
            color: #fff;
            padding: 20px;
            font-family: inherit;
            font-size: 1rem;
            resize: vertical;
            outline: none;
            transition: border-color 0.3s;
        }

            .manual-textarea:focus {
                border-color: var(--accent-blue);
            }

            .manual-textarea:disabled {
                opacity: 0.7;
                cursor: not-allowed;
            }

        .action-footer {
            margin-top: 40px;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 20px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
            color: white;
            border: none;
            padding: 14px 32px;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-primary:hover:not(:disabled) {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(2, 132, 199, 0.3);
            }

            .btn-primary:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }

        #feedback-msg {
            margin-top: 15px;
            padding: 12px;
            border-radius: 8px;
            display: none;
            font-weight: 500;
        }

            #feedback-msg.error {
                background: rgba(239, 68, 68, 0.1);
                color: var(--accent-red);
            }

    </style>
</head>
<body>

    <aside class="learn-sidebar">
        <div class="back-area">
            <a href="/Course/Details/@Model.CourseId" class="btn-back">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
                Вернуться к курсу
            </a>
        </div>
        <div class="modules-container">
            @foreach (var module in Model.AllModules.OrderBy(m => m.Order))
            {
                <div class="module-group">
                    <div class="module-label">@module.Title</div>
                    @foreach (var lesson in module.Lessons.OrderBy(l => l.Order))
                    {
                        var firstStepId = lesson.Steps.OrderBy(s => s.Order).FirstOrDefault()?.Id ?? 0;
                        <a href="?courseId=@Model.CourseId&stepId=@firstStepId"  
                           class="lesson-item @(lesson.Id == Model.CurrentStep.LessonId ? "active" : "")">
                            @lesson.Title
                        </a>
                    }
                </div>
            }
        </div>
    </aside>

    <main class="learn-content">
        <nav class="top-nav">
            @foreach (var step in Model.CurrentStep.Lesson.Steps.OrderBy(s => s.Order))
            {
                <a href="?courseId=@Model.CourseId&stepId=@step.Id"  
                   class="step-dot @(step.Id == Model.CurrentStep.Id ? "active" : "") @(Model.CompletedStepIds.Contains(step.Id) ? "completed" : "")"
                   title="@step.Title"></a>
            }
        </nav>

        <div class="main-scroll-area">
            <div class="content-card">
                <h1 class="step-title">@Model.CurrentStep.Title</h1>

                @if (!string.IsNullOrEmpty(Model.CurrentStep.VideoUrl))
                {
                    <div class="video-container">
                        @{
                            var vidId = "";
                            var url = Model.CurrentStep.VideoUrl;
                            if (url.Contains("v=")) vidId = url.Split("v=")[1].Split("&")[0];
                            else if (url.Contains("youtu.be/")) vidId = url.Split("be/")[1].Split("?")[0];
                        }
                        <iframe src="https://www.youtube.com/embed/@vidId" frameborder="0" allowfullscreen></iframe>
                    </div>
                }

                <div class="html-text">@Html.Raw(Model.CurrentStep.TextContent)</div>

                @if (isQuiz)
                {
                    <div class="quiz-wrapper">
                        <h3 style="margin-bottom: 20px; color: var(--accent-blue);">Практическое задание</h3>

                        @if (isManualInput)
                        {
                            <div class="manual-block">
                                <p style="margin-bottom: 15px;">Введите ваш ответ ниже. Преподаватель проверит его в ближайшее время.</p>
                                <textarea id="manualAnswer" class="manual-textarea"  
                                          placeholder="Напишите здесь ваше решение или ответ..."  
                                @(isStepCompleted ? "disabled" : "")></textarea>
                            </div>
                        }
                        else
                        {
                            <p style="margin-bottom: 20px;">@(Model.CurrentStep.IsMultipleChoice ? "Выберите все правильные варианты:" : "Выберите один правильный вариант:")</p>
                            <div id="options-list">
                                @foreach (var opt in Model.CurrentStep.QuizOptions ?? new List<WebApplication2.Models.QuizOptionModel>())
                                {
                                    <label class="quiz-option @(isStepCompleted && opt.IsCorrect ? "correct" : "") @(isStepCompleted ? "disabled" : "")">
                                        <input type="@(Model.CurrentStep.IsMultipleChoice ? "checkbox" : "radio")"  
                                               name="quiz-opt" value="@opt.Id"  
                                        @(isStepCompleted ? "disabled" : "") 
                                        @(isStepCompleted && opt.IsCorrect ? "checked" : "")>
                                        <span>@opt.Text</span>
                                    </label>
                                }
                            </div>
                        }
                        <div id="feedback-msg"></div>
                    </div>
                }

                <div class="action-footer">
                    @if (Model.IsLastStep && isStepCompleted)
                    {
                        <div style="font-weight: 700; color: var(--accent-green);">🎉 Молодцы! Курс завершен.</div>
                    }
                    else
                    {
                        <button id="main-btn" class="btn-primary" onclick="processStep()">
                            @if (isStepCompleted)
                            {
                                <span>Следующий шаг</span>
                            }
                            else if (isQuiz)
                            {
                                <span>Проверить</span>
                            }
                            else
                            {
                                <span>Завершить шаг</span>
                            }
                        </button>
                    }
                </div>
            </div>
        </div>
    </main>

    <script>
        const STEP_DATA = {
            id: @Model.CurrentStep.Id,
            courseId: @Model.CourseId,
            isQuiz: @isQuiz.ToString().ToLower(),
            isManual: @isManualInput.ToString().ToLower(),
            isCompleted: @isStepCompleted.ToString().ToLower(),
            token: '@tokens.RequestToken'
        };

        // Подсветка выбранных вариантов
        document.addEventListener('change', (e) => {
            if (e.target.name === 'quiz-opt') {
                const parent = e.target.closest('.quiz-option');
                if (e.target.type === 'radio') {
                    document.querySelectorAll('.quiz-option').forEach(el => el.classList.remove('selected'));
                }
                parent.classList.toggle('selected', e.target.checked);
            }
        });

        async function processStep() {
            const btn = document.getElementById('main-btn');

            // 1. Если шаг уже пройден — просто переходим дальше
            if (STEP_DATA.isCompleted) {
                const nextStep = document.querySelector('.step-dot.active + .step-dot');
                if (nextStep) {
                    location.href = nextStep.href;
                } else {
                    location.href = "/Course/Details/" + STEP_DATA.courseId;
                }
                return;
            }

            // 2. Сбор данных
            const params = new URLSearchParams();
            params.append('stepId', STEP_DATA.id);

            if (STEP_DATA.isQuiz) {
                if (STEP_DATA.isManual) {
                    const text = document.getElementById('manualAnswer').value.trim();
                    if (!text) return alert("Пожалуйста, введите ответ перед отправкой.");
                    params.append('manualAnswer', text);
                } else {
                    const selected = document.querySelectorAll('input[name="quiz-opt"]:checked');
                    if (selected.length === 0) return alert("Выберите хотя бы один вариант ответа.");
                    selected.forEach(s => params.append('selectedOptionIds', s.value));
                }
            }

            // 3. Отправка
            btn.disabled = true;
            try {
                const response = await fetch('/Course/CompleteStep', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': STEP_DATA.token
                    },
                    body: params
                });

                const result = await response.json();

                if (result.success) {
                    location.reload();
                } else {
                    const fb = document.getElementById('feedback-msg');
                    fb.className = 'error';
                    fb.innerText = result.message || "Неверный ответ. Попробуйте еще раз!";
                    fb.style.display = 'block';
                    btn.disabled = false;
                }
            } catch (err) {
                console.error(err);
                alert("Ошибка при отправке данных.");
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>