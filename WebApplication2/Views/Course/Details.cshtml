@model WebApplication2.Models.CourseModel
@inject WebApplication2.Data.ApplicationDBContext _context
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = Model.Title + " — детали курса";
    var tokens = Antiforgery.GetAndStoreTokens(Context);

    // Данные текущего пользователя из сессии
    var currentUserLogin = Context.Session.GetString("Login");

    bool isEnrolled = ViewData["IsEnrolled"] != null && (bool)ViewData["IsEnrolled"];
    bool hasCompletedCourse = ViewData["HasCompletedCourse"] != null && (bool)ViewData["HasCompletedCourse"];
    var courseEarnedPoints = ViewData["CourseEarnedPoints"] as int? ?? 0;
    var courseMaxPoints = ViewData["CourseMaxPoints"] as int? ?? 0;

    // Аналитика из контроллера
    var rank = ViewData["CategoryRank"] ?? "0";
    var totalInCat = ViewData["TotalInCat"] ?? 0;
    var recPercent = ViewData["RecPercent"] ?? 0;
    string displayRating = Model.AverageRating > 0 ? Model.AverageRating.ToString("0.0") : "0";

    bool hasAlreadyReviewed = Model.Reviews != null &&
                               !string.IsNullOrEmpty(currentUserLogin) &&
                               Model.Reviews.Any(r => r.UserLogin == currentUserLogin);

    var teacherAvgRating = ViewData["TeacherAvgRating"] != null ? (double)ViewData["TeacherAvgRating"] : 0d;
    var teacherReviewsCount = ViewData["TeacherReviewsCount"] != null ? (int)ViewData["TeacherReviewsCount"] : 0;

    string TeacherReviewsPhrase(int n)
    {
        if (n <= 0) return "";
        if (n % 100 >= 11 && n % 100 <= 14) return $"{n} отзывов";
        return (n % 10) switch
        {
            1 => $"{n} отзыв",
            2 or 3 or 4 => $"{n} отзыва",
            _ => $"{n} отзывов"
        };
    }

    // ПОЛУЧЕНИЕ ДАННЫХ ПРЕПОДАВАТЕЛЯ
    // Подгружаем профиль учителя (Experience, Specialization и т.д.)
    var teacherProfile = Model.Author;
    // Подгружаем аккаунт пользователя (Username, Avatar)
    var userAccount = _context.Users.FirstOrDefault(u => u.Login == Model.AuthorLogin);

    // Отображаемое имя: берем Username, если нет - Login
    string displayName = userAccount?.Username ?? Model.AuthorLogin;
}

@section Styles {
    <style>
        .main-content:has(.course-details-root) {
            padding: 0;
            max-width: none;
        }
        :root {
            --bg-dark: #0f172a;
            --card-bg: #1e293b;
            --accent: #38bdf8;
            --success: #10b981;
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
            --border: #334155;
        }

        .course-details-root {
            width: 100%;
            background: var(--bg-dark);
            color: var(--text-main);
            font-family: var(--font-family);
            scroll-behavior: smooth;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* HERO SECTION */
        .hero {
            background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
            padding: 60px 0;
            border-bottom: 1px solid var(--border);
        }

        .hero-layout {
            display: flex;
            gap: 50px;
            align-items: flex-start;
        }

        .hero-main {
            flex: 2;
        }

        .hero-side {
            flex: 1;
            position: sticky;
            top: 20px;
        }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--text-dim);
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 25px;
            transition: 0.2s;
        }

            .back-btn:hover {
                color: var(--accent);
            }

        .cat-badge {
            background: var(--accent);
            color: #fff;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 800;
            text-transform: uppercase;
        }

        .title {
            font-size: 3.5rem;
            margin: 15px 0;
            font-weight: 800;
            line-height: 1.1;
            letter-spacing: -1px;
        }

        .stats-row {
            display: flex;
            gap: 12px;
            margin: 30px 0;
            flex-wrap: wrap;
        }

        .stat-box {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            padding: 12px 20px;
            border-radius: 14px;
        }

        .stat-label {
            font-size: 0.65rem;
            color: var(--text-dim);
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .stat-val {
            font-size: 1.2rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .description-short {
            color: var(--text-dim);
            font-size: 1.2rem;
            line-height: 1.6;
            margin-bottom: 40px;
        }

        .btn-action {
            background: var(--success);
            color: white;
            border: none;
            padding: 18px 45px;
            border-radius: 14px;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
            display: inline-block;
        }

            .btn-action:hover {
                background: #059669;
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
            }

        .btn-blue {
            background: var(--accent);
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--accent);
            color: var(--accent);
        }

        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
            margin-top: 8px;
        }

        .hero-actions .btn-action {
            margin-left: 0;
        }

        .hero-actions form {
            display: inline;
        }

        .btn-secondary-outline {
            background: rgba(56, 189, 248, 0.08);
            border: 1px solid var(--accent);
            color: var(--accent);
        }

        .btn-secondary-outline:hover {
            background: rgba(56, 189, 248, 0.18);
            transform: translateY(-2px);
        }

        .teacher-card-footer {
            margin-top: 16px;
            padding-top: 14px;
            border-top: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .teacher-profile-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 16px;
            border-radius: 12px;
            background: rgba(56, 189, 248, 0.12);
            color: var(--accent);
            font-weight: 700;
            text-decoration: none;
            font-size: 0.9rem;
            border: 1px solid rgba(56, 189, 248, 0.35);
            transition: 0.2s;
        }

        .teacher-profile-link:hover {
            background: rgba(56, 189, 248, 0.22);
        }

        .cert-modal {
            position: fixed;
            inset: 0;
            background: rgba(2, 6, 23, 0.82);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            padding: 20px;
        }

        .cert-modal.open {
            display: flex;
        }

        .cert-modal-card {
            width: min(1080px, 100%);
            height: min(90vh, 760px);
            background: #0b1220;
            border: 1px solid var(--border);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
            display: flex;
            flex-direction: column;
        }

        .cert-modal-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
        }

        .cert-preview-frame {
            border: none;
            flex: 1;
            width: 100%;
            background: #111827;
        }

        /* COVER */
        .course-cover img {
            width: 100%;
            border-radius: 24px;
            border: 1px solid var(--border);
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
            aspect-ratio: 16/9;
            object-fit: cover;
        }

        /* TEACHER PROFILE CARD */
        .teacher-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 25px;
            margin-top: 30px;
        }

        .t-header {
            display: flex;
            gap: 15px;
            align-items: center;
            margin-bottom: 20px;
        }

        .t-avatar {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--accent);
            background: var(--bg-dark);
        }

        .t-names h3 {
            margin: 0;
            font-size: 1.3rem;
            color: #fff;
        }

        .t-names span {
            color: var(--accent);
            font-size: 0.9rem;
            font-weight: 600;
        }

        .t-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 20px;
        }

        .t-detail-item {
            background: var(--bg-dark);
            padding: 10px;
            border-radius: 10px;
            border: 1px solid var(--border);
        }

        .t-detail-label {
            font-size: 0.6rem;
            color: var(--text-dim);
            text-transform: uppercase;
            display: block;
        }

        .t-detail-val {
            font-weight: 700;
            font-size: 0.85rem;
            color: var(--text-main);
        }

        .t-detail-item.t-detail-span {
            grid-column: 1 / -1;
        }

        .t-portfolio-link {
            color: var(--accent);
            font-weight: 700;
            text-decoration: none;
            font-size: 0.85rem;
            word-break: break-all;
        }

        .t-portfolio-link:hover {
            text-decoration: underline;
        }

        .t-tags-list {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 15px;
        }

        .t-tag-pill {
            background: rgba(56, 189, 248, 0.1);
            color: var(--accent);
            padding: 3px 10px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .t-bio-title {
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.7rem;
            color: var(--text-dim);
            margin: 15px 0 8px;
            display: block;
            border-top: 1px solid var(--border);
            padding-top: 15px;
        }

        .t-bio-content {
            font-size: 0.9rem;
            line-height: 1.5;
            color: #cbd5e1;
        }

        /* TABS */
        .tabs-nav {
            display: flex;
            flex-wrap: wrap;
            gap: 12px 32px;
            border-bottom: 1px solid var(--border);
            margin: 50px 0 30px;
        }

        .tab-item {
            padding: 15px 0;
            color: var(--text-dim);
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
            border-bottom: 3px solid transparent;
            transition: 0.2s;
        }

            .tab-item.active {
                color: var(--accent);
                border-color: var(--accent);
            }

        .tab-pane {
            display: none;
            animation: fadeIn 0.4s ease;
        }

            .tab-pane.active {
                display: block;
            }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* CURRICULUM */
        .mod-box {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            margin-bottom: 12px;
            overflow: hidden;
        }

        .mod-header {
            padding: 18px 20px;
            background: rgba(255,255,255,0.02);
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 700;
        }

        .les-item {
            padding: 12px 20px 12px 50px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #cbd5e1;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        .les-steps {
            margin-left: auto;
            font-size: 0.7rem;
            color: var(--text-dim);
        }

        /* REVIEWS */
        .rev-item {
            background: var(--card-bg);
            padding: 20px;
            border-radius: 16px;
            border: 1px solid var(--border);
            margin-bottom: 15px;
        }

        .rev-user {
            font-weight: 700;
            color: var(--accent);
            margin-bottom: 5px;
            display: block;
        }

        .rev-stars {
            color: #fbbf24;
            font-size: 0.9rem;
        }

        .form-review {
            background: var(--card-bg);
            padding: 25px;
            border-radius: 20px;
            border: 1px solid var(--accent);
            margin-bottom: 30px;
        }

        .stars-rate {
            display: flex;
            flex-direction: row-reverse;
            gap: 10px;
            margin-bottom: 15px;
            justify-content: flex-end;
        }

            .stars-rate input {
                display: none;
            }

            .stars-rate label {
                font-size: 2rem;
                color: var(--border);
                cursor: pointer;
            }

                .stars-rate label:hover, .stars-rate label:hover ~ label, .stars-rate input:checked ~ label {
                    color: #fbbf24;
                }
    </style>
}

<div class="course-details-root">
    <section class="hero">
        <div class="container">
            <div class="hero-layout">
                <div class="hero-main">
                    <a href="@Url.Action("Index", "Courses")" class="back-btn"><i class="fas fa-chevron-left"></i> К библиотеке курсов</a>
                    <br />
                    <span class="cat-badge">@Model.Category</span>
                    <h1 class="title">@Model.Title</h1>

                    <div class="stats-row">
                        <div class="stat-box">
                            <div class="stat-label">Рейтинг</div>
                            <div class="stat-val" style="color:#fbbf24;">⭐ @displayRating</div>
                        </div>
                        @if (isEnrolled)
                        {
                            <div class="stat-box">
                                <div class="stat-label">Баллы в курсе</div>
                                <div class="stat-val" style="color:var(--accent);">
                                    <i class="fas fa-coins"></i> @courseEarnedPoints / @courseMaxPoints
                                </div>
                            </div>
                        }
                        <div class="stat-box">
                            <div class="stat-label">Рекомендуют</div>
                            <div class="stat-val" style="color:var(--success);"><i class="fas fa-thumbs-up"></i> @recPercent%</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-label">В категории</div>
                            <div class="stat-val" style="color:var(--accent);">#@rank из @totalInCat</div>
                        </div>
                    </div>

                    <p class="description-short">@Model.Description</p>

                    @if (isEnrolled)
                    {
                        <div class="hero-actions">
                            <a asp-action="Index" asp-route-courseId="@Model.Id" class="btn-action btn-blue">
                                <i class="fas fa-play" style="margin-right:10px;"></i> Продолжить обучение
                            </a>
                            @if (hasCompletedCourse)
                            {
                                <button type="button" class="btn-action btn-secondary-outline" onclick="openCertificatePreview()">
                                    <i class="fas fa-eye" style="margin-right:10px;"></i> Предпросмотр сертификата
                                </button>
                                <a asp-action="DownloadCertificate" asp-route-courseId="@Model.Id" class="btn-action btn-secondary-outline">
                                    <i class="fas fa-download" style="margin-right:10px;"></i> Скачать PDF
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="hero-actions">
                            <form asp-action="Enroll" method="post">
                                <input type="hidden" name="courseId" value="@Model.Id" />
                                <button type="submit" class="btn-action">Записаться на курс</button>
                            </form>
                        </div>
                    }
                </div>

                <div class="hero-side">
                    <div class="course-cover">
                        @if (!string.IsNullOrEmpty(Model.CoverImagePath))
                        {
                            <img src="@Model.CoverImagePath" alt="">
                        }
                        else
                        {
                            <div style="height:200px; background:var(--card-bg); border-radius:24px;"></div>
                        }
                    </div>

                    @if (teacherProfile != null)
                    {
                        <div class="teacher-card">
                            <div class="t-header">
                                @if (!string.IsNullOrEmpty(userAccount?.Avatar))
                                {
                                    <img src="@userAccount.Avatar" class="t-avatar" alt="">
                                }
                                else
                                {
                                    <div class="t-avatar" style="display:flex; align-items:center; justify-content:center;"><i class="fas fa-user-tie fa-2x"></i></div>
                                }
                                <div class="t-names">
                                    <h3>@displayName</h3>
                                    <span>@teacherProfile.CurrentJob</span>
                                </div>
                            </div>

                            <div class="t-details">
                                <div class="t-detail-item">
                                    <span class="t-detail-label">Категория</span>
                                    <span class="t-detail-val">@teacherProfile.SpecializationCategory</span>
                                </div>
                                <div class="t-detail-item">
                                    <span class="t-detail-label">Опыт</span>
                                    <span class="t-detail-val">@teacherProfile.Experience лет</span>
                                </div>
                                @if (!string.IsNullOrEmpty(teacherProfile.PortfolioUrl))
                                {
                                    <div class="t-detail-item t-detail-span">
                                        <span class="t-detail-label">Портфолио</span>
                                        <a href="@teacherProfile.PortfolioUrl" target="_blank" rel="noopener" class="t-portfolio-link">
                                            <i class="fas fa-briefcase"></i> @teacherProfile.PortfolioUrl
                                        </a>
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(teacherProfile.TeacherTags))
                            {
                                <div class="t-tags-list">
                                    @foreach (var tag in teacherProfile.TeacherTags.Split(','))
                                    {
                                        <span class="t-tag-pill">#@tag.Trim()</span>
                                    }
                                </div>
                            }

                            <span class="t-bio-title">О преподавателе</span>
                            <div class="t-bio-content">@teacherProfile.About</div>

                            @if (!string.IsNullOrEmpty(Model.AuthorLogin))
                            {
                                <div class="teacher-card-footer">
                                    @if (teacherReviewsCount > 0)
                                    {
                                        <div style="font-size:0.85rem;color:var(--text-dim);line-height:1.4;">
                                            <span style="color:#fbbf24;font-weight:700;">⭐ @teacherAvgRating.ToString("0.0")</span>
                                            · @TeacherReviewsPhrase(teacherReviewsCount) на платформе
                                        </div>
                                    }
                                    <a asp-controller="Teachers" asp-action="PublicProfile" asp-route-id="@Model.AuthorLogin" class="teacher-profile-link">
                                        <i class="fas fa-user-tie"></i> Профиль преподавателя
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        <nav class="tabs-nav">
            <div class="tab-item active" onclick="showTab(event, 'info')">Описание</div>
            <div class="tab-item" onclick="showTab(event, 'plan')">Программа</div>
            <div class="tab-item" onclick="showTab(event, 'feed')">Отзывы (@Model.ReviewsCount)</div>
        </nav>

        <div id="info" class="tab-pane active">
            <div style="max-width:850px; line-height:1.8; color:#cbd5e1; font-size:1.1rem; white-space:pre-line;">
                @Model.Description
                @if (teacherProfile != null && !string.IsNullOrEmpty(teacherProfile.PortfolioUrl))
                {
                    <div style="margin-top:28px;padding-top:20px;border-top:1px solid var(--border);font-size:0.95rem;color:var(--text-dim);">
                        <strong style="color:var(--text-main);">Портфолио преподавателя:</strong>
                        <a href="@teacherProfile.PortfolioUrl" target="_blank" rel="noopener" style="margin-left:8px;color:var(--accent);font-weight:700;text-decoration:none;">
                            @teacherProfile.PortfolioUrl <i class="fas fa-external-link-alt" style="font-size:0.75rem;opacity:0.85;"></i>
                        </a>
                    </div>
                }
            </div>
        </div>

        <div id="plan" class="tab-pane">
            <div style="max-width:850px;">
                @if (Model.Modules != null && Model.Modules.Any())
                {
                    @foreach (var m in Model.Modules.OrderBy(x => x.Order))
                    {
                        <div class="mod-box">
                            <div class="mod-header"><i class="fas fa-book" style="color:var(--accent)"></i> @m.Title</div>
                            @if (m.Lessons != null)
                            {
                                @foreach (var l in m.Lessons.OrderBy(x => x.Order))
                                {
                                    <div class="les-item">
                                        <i class="far fa-play-circle" style="color:var(--success)"></i> @l.Title
                                        <span class="les-steps">@(l.Steps?.Count ?? 0) шагов</span>
                                    </div>
                                }
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <div id="feed" class="tab-pane">
            <div style="max-width:850px;">
                @if (hasCompletedCourse)
                {
                    <div class="form-review">
                        <h3 style="margin-top:0;">Оставить отзыв</h3>
                        @if (hasAlreadyReviewed)
                        {
                            <p style="color:var(--success); font-weight:700;">Ваш отзыв уже принят!</p>
                        }
                        else
                        {
                            <div class="stars-rate">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <input type="radio" id="rt-@i" name="rating" value="@i" />

                                    <label for="rt-@i" class="fas fa-star"></label>
                                }
                            </div>
                            <label style="display:flex; align-items:center; gap:8px; margin-bottom:15px; cursor:pointer;">
                                <input type="checkbox" id="recom" style="accent-color:var(--success); width:18px; height:18px;"> Рекомендую этот курс
                            </label>
                            <textarea id="revMsg" style="width:100%; height:100px; background:var(--bg-dark); border:1px solid var(--border); color:white; padding:15px; border-radius:12px; margin-bottom:15px;" placeholder="Что вам понравилось?"></textarea>
                            <button class="btn-action" onclick="submitReview()">Отправить</button>
                        }
                    </div>
                }

                <div id="reviews-container">
                    @if (Model.Reviews != null && Model.Reviews.Any())
                    {
                        @foreach (var r in Model.Reviews.OrderByDescending(x => x.CreatedAt))
                        {
                            <div class="rev-item">
                                <div style="display:flex; justify-content:space-between;">
                                    <span class="rev-user">@r.UserLogin</span>
                                    <span class="rev-stars">@for (int i = 0; i < r.Rating; i++)
                                        {
                                            <i class="fas fa-star"></i>
                                        }</span>
                                </div>
                                <p style="color:#cbd5e1; margin:10px 0;">@r.Text</p>
                                <div style="display:flex; justify-content:space-between; align-items:center;">
                                    @if (r.IsRecommended)
                                    {
                                        <small style="color:var(--success); font-weight:700;"><i class="fas fa-check"></i> Рекомендует</small>
                                    }
                                    <small style="color:var(--text-dim)">@r.CreatedAt.ToString("dd.MM.yyyy")</small>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="cert-modal" id="certModal">
        <div class="cert-modal-card">
            <div class="cert-modal-head">
                <strong>Сертификат о завершении курса</strong>
                <button type="button" class="btn-action btn-outline" onclick="closeCertificatePreview()">Закрыть</button>
            </div>
            <iframe id="certFrame" class="cert-preview-frame" src=""></iframe>
        </div>
    </div>

@section Scripts {
    <script>
        function showTab(e, id) {
            document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
            e.currentTarget.classList.add('active');
            document.getElementById(id).classList.add('active');
        }

        async function submitReview() {
            const rate = document.querySelector('input[name="rating"]:checked');
            const msg = document.getElementById('revMsg').value;
            const isRec = document.getElementById('recom').checked;

            if (!rate || !msg.trim()) { alert("Заполните оценку и текст"); return; }

            const data = new URLSearchParams();
            data.append('courseId', '@Model.Id');
            data.append('rating', rate.value);
            data.append('text', msg);
            data.append('isRecommended', isRec);

            const res = await fetch('/Course/AddReview', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': '@tokens.RequestToken' },
                body: data
            });

            if ((await res.json()).success) location.reload();
        }

        function openCertificatePreview() {
            const frame = document.getElementById('certFrame');
            frame.src = '/Course/PreviewCertificate?courseId=@Model.Id';
            document.getElementById('certModal').classList.add('open');
        }

        function closeCertificatePreview() {
            const modal = document.getElementById('certModal');
            const frame = document.getElementById('certFrame');
            modal.classList.remove('open');
            frame.src = '';
        }
    </script>
}
</div>