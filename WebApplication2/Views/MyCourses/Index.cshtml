@model IEnumerable<CourseCardModel>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "MyClassroom - Мои курсы";
    var tokens = Antiforgery.GetAndStoreTokens(Context);
}

@section Styles {
    <link href="~/css/style_for_main_page.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/course_list_page.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/course-analytics-modal.css" rel="stylesheet" asp-append-version="true" />
}

<div class="page-header">
    <h2>Управление курсами</h2>
</div>

<section class="courses-grid">
    @if (Model != null && Model.Any())
    {
        @foreach (var course in Model)
        {
            @await Html.PartialAsync("_CourseCard", course, new ViewDataDictionary(ViewData) { { "IsEditable", true } })
        }
    }
    else
    {
        <div class="empty-state">
            <i class="fa-solid fa-graduation-cap"></i>
            <p>Курсов пока нет. Создайте первый курс!</p>
        </div>
    }
</section>

@section Scripts {
    <script src="~/js/course-analytics-modal.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            window.initCourseAnalyticsButtons?.();
        });

        async function deleteCourse(courseId) {
            if (!confirm("Вы уверены, что хотите полностью удалить этот курс? Все модули и уроки внутри него будут стерты.")) {
                return;
            }
            try {
                const response = await fetch(`/MyCourses/DeleteCourse/${courseId}`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": "@tokens.RequestToken"
                    }
                });
                if (response.ok) {
                    window.location.reload();
                } else {
                    const errorData = await response.text();
                    alert("Ошибка при удалении: " + (errorData || "Сервер вернул ошибку " + response.status));
                }
            } catch {
                alert("Не удалось отправить запрос на удаление.");
            }
        }
    </script>
}
