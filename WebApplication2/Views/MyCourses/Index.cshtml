@{
    ViewData["Title"] = "MyClassroom - Мои курсы";
}
@model IEnumerable<CourseCardModel> 

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="~/css/style_for_main_page.css" rel="stylesheet"/>
    <link href="~/css/course_card.css" rel="stylesheet"/>
</head>
<body>

    <div class="main-layout">
        @await Html.PartialAsync("_Sidebar")

        <div class="content-area">
            @await Html.PartialAsync("_Header")

            <main class="main-content">
                <section class="courses-grid">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var course in Model)
                        {
                            @await Html.PartialAsync("_CourseCard", course, new ViewDataDictionary(ViewData) { { "IsEditable", true } })
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fa-solid fa-graduation-cap"></i>
                            <p>Курсов пока нет. Станьте первым!</p>
                        </div>
                    }
                </section>
            </main>
        </div>
    </div>

    <script src="~/js/script_for_main_page.js"></script>

</body>
</html>
