@model IEnumerable<CourseCardModel>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "MyClassroom - Мои курсы";
    var tokens = Antiforgery.GetAndStoreTokens(Context);
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="~/css/variables.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/style_for_main_page.css" rel="stylesheet" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <div class="main-layout">
        @await Html.PartialAsync("_Sidebar")

        <div class="content-area">
            @await Html.PartialAsync("_Header")

            <main class="main-content">
                <section class="courses-grid">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var course in Model)
                        {
                            @await Html.PartialAsync("_CourseCard", course, new ViewDataDictionary(ViewData) { { "IsEditable", true } })
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fa-solid fa-graduation-cap"></i>
                            <p>Курсов пока нет. Станьте первым!</p>
                        </div>
                    }
                </section>
            </main>
        </div>
    </div>

    <script src="~/js/script_for_main_page.js"></script>
    <script>
        async function deleteCourse(courseId) {
            if (!confirm("Вы уверены, что хотите полностью удалить этот курс? Все модули и уроки внутри него будут стерты.")) {
                return;
            }
            try {
                const response = await fetch(`/MyCourses/DeleteCourse/${courseId}`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": "@tokens.RequestToken"
                    }
                });
                if (response.ok) {
                    window.location.reload();
                } else {
                    const errorData = await response.text();
                    alert("Ошибка при удалении: " + (errorData || "Сервер вернул ошибку " + response.status));
                }
            } catch {
                alert("Не удалось отправить запрос на удаление.");
            }
        }
    </script>

</body>
</html>
