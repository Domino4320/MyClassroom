@using WebApplication2.Models
@{
    ViewData["Title"] = "Главная страница";
    bool isGuest = ViewBag.IsGuest ?? true;

    var categoryRecs = ViewBag.CategoryRecs as List<CourseCardModel>;
    var topRated = ViewBag.TopRated as List<CourseCardModel>;
    var popular = ViewBag.Popular as List<CourseCardModel>;
    var highRec = ViewBag.HighRec as List<CourseCardModel>;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    :root {
        --bg-main: #f8fafc;
        --card-bg: #ffffff;
        --text-main: #0f172a;
        --text-muted: #64748b;
    }

    body {
        background-color: var(--bg-main);
        font-family: 'Inter', -apple-system, sans-serif;
        margin: 0;
    }

    .main-content {
        padding: 30px;
        width: 98%;
        max-width: 2400px;
        margin: 0 auto;
        box-sizing: border-box;
        min-height: 80vh;
        display: flex;
        flex-direction: column;
    }

    /* ЦЕНТРИРОВАННЫЙ БЛОК ДЛЯ ГОСТЯ */
    .guest-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .guest-message {
        text-align: center;
        max-width: 500px;
        padding: 60px;
        background: var(--card-bg);
        border-radius: 32px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
    }

        .guest-message i {
            font-size: 3.5rem;
            color: #cbd5e1;
            margin-bottom: 25px;
            display: block;
        }

        .guest-message h1 {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 15px;
        }

        .guest-message p {
            font-size: 1.1rem;
            color: var(--text-muted);
            line-height: 1.6;
            margin: 0;
        }

    /* СТИЛИ СЕКЦИЙ ДЛЯ АВТОРИЗОВАННЫХ */
    .course-section {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 40px;
        margin-bottom: 40px;
        border: 1px solid #e2e8f0;
    }

    .section-header {
        display: flex;
        align-items: center;
        margin-bottom: 35px;
        gap: 20px;
    }

    .icon-box {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
    }

    .header-text h2 {
        font-size: 1.9rem;
        font-weight: 800;
        margin: 0;
        color: var(--text-main);
    }

    .header-text p {
        font-size: 1.1rem;
        color: var(--text-muted);
        margin: 4px 0 0 0;
    }

    .courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
        gap: 30px;
    }

    .course-card-wrapper {
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    }

        .course-card-wrapper:hover {
            transform: translateY(-12px);
            box-shadow: 0 25px 30px -10px rgba(0, 0, 0, 0.1);
        }

    .empty-category {
        grid-column: 1 / -1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px;
        background: #f8fafc;
        border: 2px dashed #e2e8f0;
        border-radius: 20px;
        color: var(--text-muted);
    }

    @@media (max-width: 1200px) {
        .courses-grid {
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        }
    }
</style>

<div class="main-layout">
    @await Html.PartialAsync("_Sidebar")

    <div class="content-area">
        @await Html.PartialAsync("_Header")

        <main class="main-content">

            @if (isGuest)
            {
                <div class="guest-wrapper">
                    <div class="guest-message">
                        <i class="fa-solid fa-lock"></i>
                        <h1>Персональный подбор</h1>
                        <p>Пожалуйста, авторизуйтесь в системе, чтобы получить доступ к рекомендациям и популярным курсам.</p>
                    </div>
                </div>
            }
            else
            {
                @* 1. КАТЕГОРИИ *@
                <section class="course-section">
                    <div class="section-header">
                        <div class="icon-box" style="background: linear-gradient(135deg, #3b82f6, #2563eb);"><i class="fa-solid fa-graduation-cap"></i></div>
                        <div class="header-text">
                            <h2>Продолжайте обучение</h2>
                            <p>На основе категорий, которые вы изучаете</p>
                        </div>
                    </div>
                    <div class="courses-grid">
                        @if (categoryRecs != null && categoryRecs.Any())
                        {
                            @foreach (var c in categoryRecs)
                            {
                                <div class="course-card-wrapper">@await Html.PartialAsync("_CourseCard", c)</div>
                            }
                        }
                        else
                        {
                            <div class="empty-category"><p>Тут для вас пока ничего нет</p></div>
                        }
                    </div>
                </section>

                @* 2. ТОП РЕЙТИНГ *@
                <section class="course-section">
                    <div class="section-header">
                        <div class="icon-box" style="background: linear-gradient(135deg, #f59e0b, #d97706);"><i class="fa-solid fa-star"></i></div>
                        <div class="header-text">
                            <h2>Высшая оценка</h2>
                            <p>Лучшие курсы по мнению сообщества</p>
                        </div>
                    </div>
                    <div class="courses-grid">
                        @if (topRated != null && topRated.Any())
                        {
                            @foreach (var c in topRated)
                            {
                                <div class="course-card-wrapper">@await Html.PartialAsync("_CourseCard", c)</div>
                            }
                        }
                        else
                        {
                            <div class="empty-category"><p>Курсы с высоким рейтингом не найдены</p></div>
                        }
                    </div>
                </section>

                @* 3. ХИТЫ *@
                <section class="course-section">
                    <div class="section-header">
                        <div class="icon-box" style="background: linear-gradient(135deg, #ef4444, #dc2626);"><i class="fa-solid fa-fire"></i></div>
                        <div class="header-text">
                            <h2>Хиты платформы</h2>
                            <p>Самые популярные направления обучения</p>
                        </div>
                    </div>
                    <div class="courses-grid">
                        @if (popular != null && popular.Any())
                        {
                            @foreach (var c in popular)
                            {
                                <div class="course-card-wrapper">@await Html.PartialAsync("_CourseCard", c)</div>
                            }
                        }
                        else
                        {
                            <div class="empty-category"><p>Популярные курсы еще не определены</p></div>
                        }
                    </div>
                </section>

                @* 4. РЕКОМЕНДАЦИИ *@
                <section class="course-section">
                    <div class="section-header">
                        <div class="icon-box" style="background: linear-gradient(135deg, #10b981, #059669);"><i class="fa-solid fa-thumbs-up"></i></div>
                        <div class="header-text">
                            <h2>Студенты рекомендуют</h2>
                            <p>Выбор на основе положительных отзывов</p>
                        </div>
                    </div>
                    <div class="courses-grid">
                        @if (highRec != null && highRec.Any())
                        {
                            @foreach (var c in highRec)
                            {
                                <div class="course-card-wrapper">@await Html.PartialAsync("_CourseCard", c)</div>
                            }
                        }
                        else
                        {
                            <div class="empty-category"><p>Рекомендованные курсы скоро появятся</p></div>
                        }
                    </div>
                </section>
            }

        </main>
    </div>
</div>