@{
    ViewData["Title"] = "MyClassroom - Главная страница";
}
@model IEnumerable<CourseCardModel> 


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="~/css/style_for_main_page.css" rel="stylesheet"/>
    <link href="~/css/course_card.css" rel="stylesheet"/>

    <title>Учебная платформа</title>
</head>
<body>

    @await Html.PartialAsync("_Header")


    @await Html.PartialAsync("_Sidebar")

    <div class="main-content" id="mainContent">
        <h1>Рекомендованные курсы</h1>
        <div class="recommendations">
            @foreach (var course in Model)
            {
                @await Html.PartialAsync("_CourseCard", course)
            }
        </div>
    </div>

    <script src="~/js/script_for_main_page.js"></script>

</body>
</html>
