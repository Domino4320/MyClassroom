@using WebApplication2.Models
@using System.Linq
@{
    ViewData["Title"] = "MyClassroom";
    bool isGuest = ViewBag.IsGuest ?? true;

    var categoryRecs = ViewBag.CategoryRecs as List<CourseCardModel>;
    var topRated = ViewBag.TopRated as List<CourseCardModel>;
    var popular = ViewBag.Popular as List<CourseCardModel>;
    var highRec = ViewBag.HighRec as List<CourseCardModel>;

    var sections = new (string Title, string Subtitle, string IconClass, string Gradient, List<CourseCardModel>? Items, string EmptyText)[]
    {
        ("Продолжайте обучение", "На основе категорий, которые вы изучаете", "fa-graduation-cap", "linear-gradient(135deg, #3b82f6, #2563eb)", categoryRecs, "Тут для вас пока ничего нет"),
        ("Высшая оценка", "Лучшие курсы по мнению сообщества", "fa-star", "linear-gradient(135deg, #f59e0b, #d97706)", topRated, "Курсы с высоким рейтингом не найдены"),
        ("Хиты платформы", "Самые популярные направления обучения", "fa-fire", "linear-gradient(135deg, #ef4444, #dc2626)", popular, "Популярные курсы еще не определены"),
        ("Студенты рекомендуют", "Выбор на основе положительных отзывов", "fa-thumbs-up", "linear-gradient(135deg, #10b981, #059669)", highRec, "Рекомендованные курсы скоро появятся"),
    };
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    .main-content {
        padding: clamp(1rem, 3vw, 30px);
        width: 100%;
        max-width: 2400px;
        margin: 0 auto;
        box-sizing: border-box;
        min-height: 80vh;
        display: flex;
        flex-direction: column;
    }

    .guest-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .guest-message {
        text-align: center;
        max-width: 500px;
        padding: 60px;
        background: var(--home-card);
        border-radius: 32px;
        border: 1px solid var(--home-border);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
    }

    .guest-message i {
        font-size: 3.5rem;
        color: var(--home-muted);
        margin-bottom: 25px;
        display: block;
    }

    .guest-message h1 {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--home-text);
        margin-bottom: 15px;
    }

    .guest-message p {
        font-size: 1.1rem;
        color: var(--home-muted);
        line-height: 1.6;
        margin: 0;
    }

    .course-section {
        background: var(--home-card, var(--surface-card));
        border-radius: 24px;
        padding: 40px;
        margin-bottom: 40px;
        border: 1px solid var(--home-border);
    }

    .section-header {
        display: flex;
        align-items: center;
        margin-bottom: 35px;
        gap: 20px;
    }

    .icon-box {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
    }

    .header-text h2 {
        font-size: 1.9rem;
        font-weight: 800;
        margin: 0;
        color: var(--home-text);
    }

    .header-text p {
        font-size: 1.1rem;
        color: var(--home-muted);
        margin: 4px 0 0 0;
    }

    .courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
        gap: clamp(16px, 3vw, 30px);
    }

    .course-card-wrapper {
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    }

    .course-card-wrapper:hover {
        transform: translateY(-8px);
        filter: brightness(1.03);
    }

    .empty-section {
        grid-column: 1 / -1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px;
        background: var(--surface-hover);
        border: 2px dashed var(--home-border);
        border-radius: 20px;
        color: var(--home-muted);
    }

    @@media (max-width: 1200px) {
        .courses-grid {
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        }
    }
</style>

@if (isGuest)
            {
                <div class="guest-wrapper">
                    <div class="guest-message">
                        <i class="fa-solid fa-lock"></i>
                        <h1>Персональный подбор</h1>
                        <p>Пожалуйста, авторизуйтесь в системе, чтобы получить доступ к рекомендациям и популярным курсам.</p>
                    </div>
                </div>
            }
            else
            {
                @foreach (var s in sections)
                {
                    <section class="course-section">
                        <div class="section-header">
                            <div class="icon-box" style="background: @s.Gradient"><i class="fa-solid @s.IconClass"></i></div>
                            <div class="header-text">
                                <h2>@s.Title</h2>
                                <p>@s.Subtitle</p>
                            </div>
                        </div>
                        <div class="courses-grid">
                            @if (s.Items != null && s.Items.Any())
                            {
                                @foreach (var c in s.Items)
                                {
                                    <div class="course-card-wrapper">@await Html.PartialAsync("_CourseCard", c)</div>
                                }
                            }
                            else
                            {
                                <div class="empty-section"><p>@s.EmptyText</p></div>
                            }
                        </div>
                    </section>
                }
            }
