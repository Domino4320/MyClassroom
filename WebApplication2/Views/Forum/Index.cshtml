@model List<WebApplication2.Models.ForumDiscussionModel>
@{
    ViewData["Title"] = "MyClassroom";
    var login = Context.Session.GetString("Login");
}

@section Styles {
    <link rel="stylesheet" href="~/css/forum.css" asp-append-version="true" />
}

<div class="page-header">
    <h1>Форум</h1>
</div>

<div class="forum-wrap">
    <div class="forum-card">
        @if (!string.IsNullOrEmpty(login))
        {
            <form asp-action="Create" method="post" class="forum-create-row">
                @Html.AntiForgeryToken()
                <input type="text" name="title" placeholder="Название обсуждения..." minlength="3" maxlength="120" required />
                <button class="forum-btn" type="submit">Создать</button>
            </form>
        }
        else
        {
            <div class="forum-guest-hint">
                Чтобы создавать обсуждения, нужно <a href="@Url.Action("Index", "Authorization")">войти</a>.
            </div>
        }
    </div>

    <div class="forum-list">
        @if (Model != null && Model.Any())
        {
            @foreach (var d in Model)
            {
                <div class="forum-card forum-list-item">
                    <div style="min-width:0;">
                        <div class="forum-list-title">
                            <a href="@Url.Action("Discussion", "Forum", new { id = d.Id })">@d.Title</a>
                        </div>
                        <div class="forum-meta">
                            Автор: @(string.IsNullOrEmpty(d.Author?.Username) ? d.AuthorLogin : d.Author.Username)
                            • @d.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </div>
                    </div>
                    <a class="forum-open-link" href="@Url.Action("Discussion", "Forum", new { id = d.Id })">Открыть</a>
                </div>
            }
        }
        else
        {
            <div class="forum-card forum-guest-hint">Пока нет обсуждений.</div>
        }
    </div>
</div>
