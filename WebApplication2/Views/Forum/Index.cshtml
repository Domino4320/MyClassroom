@model List<WebApplication2.Models.ForumDiscussionModel>
@{
    Layout = null;
    var login = Context.Session.GetString("Login");
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Форум</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0f172a;
            --card: #1e293b;
            --accent: #38bdf8;
            --text: #e2e8f0;
            --muted: #94a3b8;
            --border: #334155;
        }
        body { margin:0; font-family:Inter, sans-serif; background:var(--bg); color:var(--text); }
        .wrap { max-width: 1000px; margin: 0 auto; padding: 40px 20px; }
        .top { display:flex; justify-content:space-between; align-items:center; gap: 14px; margin-bottom: 20px; }
        a { color: var(--accent); text-decoration:none; font-weight:700; }
        .card { background: var(--card); border: 1px solid var(--border); border-radius: 18px; padding: 18px; }
        .row { display:flex; gap: 12px; }
        input[type=text] { flex:1; background:#0b1222; border:1px solid var(--border); border-radius: 12px; padding: 12px 14px; color: #fff; outline:none; }
        .btn { background: linear-gradient(135deg, #0ea5e9, #0284c7); border:none; color:#fff; border-radius: 12px; padding: 12px 16px; font-weight:800; cursor:pointer; }
        .list { display:flex; flex-direction:column; gap: 12px; margin-top: 16px; }
        .item { display:flex; justify-content:space-between; gap:12px; align-items:center; }
        .meta { color: var(--muted); font-size: 0.9rem; }
        .title { font-size: 1rem; font-weight: 800; color:#fff; }
    </style>
</head>
<body>
    <div class="wrap">
        <div class="top">
            <div>
                <div style="color:var(--muted); font-weight:800; letter-spacing:0.08em; font-size:0.75rem;">MYCLASSROOM</div>
                <h1 style="margin:6px 0 0;">Форум</h1>
            </div>
            <a href="/">На главную</a>
        </div>

        <div class="card">
            @if (!string.IsNullOrEmpty(login))
            {
                <form asp-action="Create" method="post" class="row">
                    @Html.AntiForgeryToken()
                    <input type="text" name="title" placeholder="Название обсуждения..." minlength="3" maxlength="120" required />
                    <button class="btn" type="submit">Создать</button>
                </form>
            }
            else
            {
                <div style="color:var(--muted);">
                    Чтобы создавать обсуждения, нужно <a href="/Authorization/Index">войти</a>.
                </div>
            }
        </div>

        <div class="list">
            @if (Model != null && Model.Any())
            {
                @foreach (var d in Model)
                {
                    <div class="card item">
                        <div style="min-width:0;">
                            <div class="title" style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                <a href="/Forum/Discussion/@d.Id">@d.Title</a>
                            </div>
                            <div class="meta">
                                Автор: @(string.IsNullOrEmpty(d.Author?.Username) ? d.AuthorLogin : d.Author.Username)
                                • @d.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </div>
                        </div>
                        <a href="/Forum/Discussion/@d.Id">Открыть</a>
                    </div>
                }
            }
            else
            {
                <div class="card" style="color:var(--muted);">Пока нет обсуждений.</div>
            }
        </div>
    </div>
</body>
</html>

