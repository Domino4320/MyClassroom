@model WebApplication2.Models.ForumDiscussionModel
@{
    ViewData["Title"] = Model.Title;
    var login = Context.Session.GetString("Login");
    var messages = (Model.Messages ?? new List<WebApplication2.Models.ForumMessageModel>())
        .OrderBy(m => m.CreatedAt)
        .ToList();
    var byId = messages.ToDictionary(m => m.Id, m => m);
}

@section Styles {
    <link rel="stylesheet" href="~/css/forum.css" asp-append-version="true" />
}

<div class="forum-discussion-page">
    <div class="page-header">
        <a class="forum-back-link" href="@Url.Action("Index", "Forum")">← Назад к форуму</a>
        <h1 class="forum-discussion-title">@Model.Title</h1>
        <div class="forum-meta">
            Автор: @(string.IsNullOrEmpty(Model.Author?.Username) ? Model.AuthorLogin : Model.Author.Username)
            • @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
        </div>
    </div>

    <div class="forum-wrap">
        <div class="forum-messages">
            @foreach (var m in messages)
            {
                <div class="forum-card forum-msg">
                    <img class="forum-avatar"
                         src="@(string.IsNullOrEmpty(m.User?.Avatar) ? Url.Content("~/images/default_avatar.jpg") : m.User.Avatar)"
                         alt="">
                    <div class="forum-msg-body">
                        @if (m.ParentMessageId.HasValue && byId.TryGetValue(m.ParentMessageId.Value, out var parentMsg))
                        {
                            var parentAuthor = string.IsNullOrEmpty(parentMsg.User?.Username) ? parentMsg.UserLogin : parentMsg.User.Username;
                            var sourceText = (parentMsg.Text ?? "").Trim();
                            var snippet = sourceText.Length > 70 ? sourceText.Substring(0, 70) + "..." : sourceText;
                            <div class="forum-reply-preview">
                                <span class="forum-reply-author">@parentAuthor</span>
                                <span>@snippet</span>
                            </div>
                        }
                        <div class="forum-msg-head">
                            <div class="forum-msg-name">@(string.IsNullOrEmpty(m.User?.Username) ? m.UserLogin : m.User.Username)</div>
                            <div class="forum-meta">@m.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                            @if (!string.IsNullOrEmpty(login))
                            {
                                <button type="button"
                                        class="forum-reply-btn js-reply-btn"
                                        data-message-id="@m.Id"
                                        data-message-user="@(string.IsNullOrEmpty(m.User?.Username) ? m.UserLogin : m.User.Username)">
                                    Ответить
                                </button>
                            }
                        </div>
                        <div class="forum-msg-text">@m.Text</div>
                    </div>
                </div>
            }
        </div>

        <div class="forum-composer">
            <div class="forum-card">
                @if (!string.IsNullOrEmpty(login))
                {
                    <input type="hidden" id="parentMessageId" value="">
                    <div id="replyBanner" class="forum-reply-banner">
                        Ответ пользователю <span id="replyToName" class="forum-reply-user"></span>
                        <a href="javascript:void(0)" id="cancelReplyBtn" class="forum-reply-cancel">Отменить</a>
                    </div>
                    <form asp-action="AddMessage" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="discussionId" value="@Model.Id" />
                        <input type="hidden" name="parentMessageId" id="parentMessageIdForm" value="" />
                        <textarea name="text" id="textBox" class="forum-textarea" placeholder="Сообщение..." required maxlength="3000"></textarea>
                        <div class="forum-composer-row">
                            <button class="forum-btn" type="submit">Отправить</button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="forum-guest-hint">
                        Чтобы писать сообщения, нужно <a href="@Url.Action("Index", "Authorization")">войти</a>.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.body.dataset.forumAuth = "@(string.IsNullOrEmpty(login) ? "false" : "true")";
    </script>
    <script src="~/js/forum-discussion.js" asp-append-version="true"></script>
}
